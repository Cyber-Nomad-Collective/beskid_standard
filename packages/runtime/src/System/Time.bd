/// Time types for instants and durations.
pub type Instant {
    i64 ticks,
}

pub type Duration {
    i64 milliseconds,
}

/// UTC wall-clock nanoseconds since Unix epoch.
pub Instant NowUtc() {
    return Instant { ticks: __clock_realtime_nanos() };
}

/// Monotonic nanoseconds since process start (best effort).
pub Instant MonotonicNow() {
    return Instant { ticks: __clock_monotonic_nanos() };
}

pub Duration FromMilliseconds(i64 ms) {
    return Duration { milliseconds: ms };
}
