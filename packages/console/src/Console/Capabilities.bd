/// Terminal capability probing (TTY, color model, NO_COLOR / FORCE_COLOR).
use Platform.Terminal;

pub enum ColorModel {
    Basic8(),
    Basic16(),
    Indexed256(),
    TrueColor(),
}

pub type Capabilities {
    bool isTty,
    bool colorDisabled,
    bool colorForced,
    ColorModel model,
}

pub bool IsStreamTty(i64 fd) {
    return Terminal.IsAtty(fd) != 0;
}

pub bool ShouldStripColor(Capabilities caps) {
    if caps.colorDisabled {
        return true;
    }
    if caps.colorForced {
        return false;
    }
    if !caps.isTty {
        return true;
    }
    return false;
}

pub bool ShouldEmitAnsi() {
    Capabilities caps = ProbeStdout();
    return !ShouldStripColor(caps);
}

pub ColorModel EffectiveColorModel(Capabilities caps) {
    if ShouldStripColor(caps) {
        return ColorModel::Basic16();
    }
    return caps.model;
}

pub Capabilities ProbeStdout() {
    bool tty = Terminal.IsAtty(1) != 0;
    bool noColor = Terminal.EnvFlagSet("NO_COLOR");
    bool forceColor = Terminal.EnvFlagSet("FORCE_COLOR");
    ColorModel model = Terminal.ProbeColorModel();
    return Capabilities {
        isTty: tty,
        colorDisabled: noColor,
        colorForced: forceColor,
        model: model
    };
}
