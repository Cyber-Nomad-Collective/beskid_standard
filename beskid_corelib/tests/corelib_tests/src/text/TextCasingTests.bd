/// Core.Text.Casing conversion tests.
use Core.Text.Casing;
use Testing.Assert;

test snake_to_pascal_maps_rule_names {
    Assert.Equal(Casing.SnakeToPascal("lower_run"), "LowerRun", "snake to pascal");
    Assert.Equal(Casing.SnakeToPascal("digit"), "Digit", "single segment");
}

test pascal_to_snake_round_trip {
    string snake = Casing.PascalToSnake("ParseLowerRun");
    Assert.Equal(snake, "parse_lower_run", "pascal to snake");
}

test callable_from_snake_adds_prefix {
    Assert.Equal(Casing.CallableFromSnake("pat_branch", "Parse"), "ParsePatBranch", "callable prefix");
}

test camel_snake_conversions {
    Assert.Equal(Casing.SnakeToCamel("word_tail"), "wordTail", "snake to camel");
    Assert.Equal(Casing.CamelToSnake("wordTail"), "word_tail", "camel to snake");
}
