/// Stack container measure/render contracts.
test vertical_stack_child_count {
    Console.Controls.VerticalStack.VerticalStack stack =
        Console.Controls.VerticalStack.VerticalStack.WithChild(
            Console.Controls.VerticalStack.VerticalStack.WithChild(
                Console.Controls.VerticalStack.VerticalStack.New(),
                "a"
            ),
            "b"
        );
    if Console.Controls.VerticalStack.VerticalStack.ChildCount(stack) != 2 {
        __panic_str("expected two vertical stack children");
    }
}

test vertical_stack_render_joins_lines {
    Console.Controls.VerticalStack.VerticalStack stack =
        Console.Controls.VerticalStack.VerticalStack.WithChild(
            Console.Controls.VerticalStack.VerticalStack.WithChild(
                Console.Controls.VerticalStack.VerticalStack.New(),
                "one"
            ),
            "two"
        );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 40, rows: 10 };
    string out = Console.Controls.VerticalStack.VerticalStack.Render(stack, size);
    if !Core.String.Contains(out, "one") {
        __panic_str("expected first child line");
    }
    if !Core.String.Contains(out, "two") {
        __panic_str("expected second child line");
    }
}

test horizontal_stack_measure_width {
    Console.Controls.HorizontalStack.HorizontalStack stack =
        Console.Controls.HorizontalStack.HorizontalStack.WithChild(
            Console.Controls.HorizontalStack.HorizontalStack.WithChild(
                Console.Controls.HorizontalStack.HorizontalStack.New(),
                "ab"
            ),
            "cd"
        );
    Console.ConsoleSize available = Console.ConsoleSize { columns: 80, rows: 24 };
    Console.ConsoleSize measured = Console.Controls.HorizontalStack.HorizontalStack.Measure(stack, available);
    if measured.rows != 1 {
        __panic_str("horizontal stack should measure one row");
    }
    if measured.columns < 5 {
        __panic_str("horizontal stack should measure combined segment width");
    }
}
