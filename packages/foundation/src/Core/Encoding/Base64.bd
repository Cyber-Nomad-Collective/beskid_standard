/// RFC 4648 standard Base64 encoding.
/// @tier(standard)
use Core.Bytes.Convert;
use Core.Encoding.EncodingError;
use Core.Results;

pub u8 AlphabetAt(i64 index) {
    if index < 26 {
        return 65 + index;
    }
    if index < 52 {
        return 71 + index;
    }
    if index < 62 {
        return index - 4;
    }
    if index == 62 {
        return 43;
    }
    return 47;
}

pub u8 ValueAt(u8 ch) {
    if ch >= 65 && ch <= 90 {
        return ch - 65;
    }
    if ch >= 97 && ch <= 122 {
        return ch - 71;
    }
    if ch >= 48 && ch <= 57 {
        return ch + 4;
    }
    if ch == 43 {
        return 62;
    }
    if ch == 47 {
        return 63;
    }
    if ch == 61 {
        return 64;
    }
    return 255;
}

pub Core.Results.Result<u8[], EncodingError> EncodeBytes(u8[] data) {
    i64 len = __array_len(data);
    i64 bufLen = ((len + 2) / 3) * 4;
    u8[] buf = Core.Bytes.Slice.New(bufLen);
    mut i64 i = 0;
    mut i64 o = 0;
    while i < len {
        i64 remain = len - i;
        u8 b0 = data[i];
        u8 b1 = 0;
        u8 b2 = 0;
        if remain > 1 {
            b1 = data[i + 1];
        }
        if remain > 2 {
            b2 = data[i + 2];
        }
        u8 v0 = b0 / 4;
        u8 b0Rem = b0 % 4;
        u8 v1 = b0Rem * 16 + b1 / 16;
        u8 b1Rem = b1 % 16;
        u8 v2 = b1Rem * 4 + b2 / 64;
        u8 v3 = b2 % 64;
        Core.Bytes.Slice.Set(buf, o, AlphabetAt(v0));
        Core.Bytes.Slice.Set(buf, o + 1, AlphabetAt(v1));
        if remain == 1 {
            Core.Bytes.Slice.Set(buf, o + 2, 61);
            Core.Bytes.Slice.Set(buf, o + 3, 61);
        } else if remain == 2 {
            Core.Bytes.Slice.Set(buf, o + 2, AlphabetAt(v2));
            Core.Bytes.Slice.Set(buf, o + 3, 61);
        } else {
            Core.Bytes.Slice.Set(buf, o + 2, AlphabetAt(v2));
            Core.Bytes.Slice.Set(buf, o + 3, AlphabetAt(v3));
        }
        o = o + 4;
        i = i + 3;
    }
    return Result::Ok(buf);
}

pub Core.Results.Result<u8[], EncodingError> DecodeBytes(u8[] data) {
    i64 len = __array_len(data);
    if len == 0 {
        return Result::Ok(Core.Bytes.Slice.New(0));
    }
    if len % 4 != 0 {
        return Result::Error(EncodingError::InvalidPadding());
    }
    i64 pad = 0;
    if data[len - 1] == 61 {
        pad = 1;
    }
    if len > 1 && data[len - 2] == 61 {
        pad = 2;
    }
    i64 bufLen = (len / 4) * 3 - pad;
    u8[] buf = Core.Bytes.Slice.New(bufLen);
    mut i64 i = 0;
    mut i64 o = 0;
    while i < len {
        u8 c0 = ValueAt(data[i]);
        u8 c1 = ValueAt(data[i + 1]);
        u8 c2 = ValueAt(data[i + 2]);
        u8 c3 = ValueAt(data[i + 3]);
        if c0 > 63 || c1 > 63 {
            return Result::Error(EncodingError::InvalidSequence());
        }
        if data[i + 2] == 61 {
            c2 = 64;
        } else if c2 > 63 {
            return Result::Error(EncodingError::InvalidSequence());
        }
        if data[i + 3] == 61 {
            c3 = 64;
        } else if c3 > 63 {
            return Result::Error(EncodingError::InvalidSequence());
        }
        u8 b0 = c0 * 4 + c1 / 16;
        if o < bufLen {
            Core.Bytes.Slice.Set(buf, o, b0);
            o = o + 1;
        }
        if pad < 2 && o < bufLen {
            u8 c1Rem = c1 % 16;
            u8 b1 = c1Rem * 16 + c2 / 4;
            Core.Bytes.Slice.Set(buf, o, b1);
            o = o + 1;
        }
        if pad < 1 && o < bufLen {
            u8 c2Rem = c2 % 4;
            u8 b2 = c2Rem * 64 + c3;
            Core.Bytes.Slice.Set(buf, o, b2);
            o = o + 1;
        }
        i = i + 4;
    }
    return Result::Ok(buf);
}

pub Core.Results.Result<u8[], EncodingError> EncodeToBytes(string text) {
    return EncodeBytes(Convert.StringToBytes(text));
}

pub Core.Results.Result<string, EncodingError> DecodeFromBytes(u8[] data) {
    return match DecodeBytes(data) {
        Result::Ok(bytes) => Core.Encoding.Utf8.DecodeFromBytes(bytes),
        Result::Error(err) => Result::Error(err),
    };
}
