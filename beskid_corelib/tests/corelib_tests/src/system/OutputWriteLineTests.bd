/// Smoke test for stdout line output (syscall-backed until cross-module `WriteLine` JIT is wired).
test output_writeline_smoke {
    i64 a = __syscall_write(1, "corelib-output-writeline-smoke");
    i64 b = __syscall_write(1, "
");
    if a < 1 {
        __panic_str("writeline smoke should write message bytes");
    }
    if b < 1 {
        __panic_str("writeline smoke should write newline");
    }
}
