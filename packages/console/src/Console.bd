/// Console facade: formatting, tick loop, and terminal size.
use System.Output;
use Console.Capabilities;
use Console.ConsoleMessage;
use Console.Format;
use Console.Controls.LiveTick;
use Concurrency.Channel;
use Platform.Terminal;

/// Terminal dimensions in character cells.
pub type ConsoleSize {
    i32 columns,
    i32 rows,
}

/// Resize multicast surface; pair with `SubscribeOnResize` and `RunTick`.
/// This same-fiber event hub is separate from `Concurrency.Hub`.
pub type OnResize {
    ConsoleSize lastSize,
    event{16} OnResize(ConsoleSize size),
}

/// Returns whether ANSI styling should be emitted for the current host.
pub bool ShouldStyle() {
    return Console.Capabilities.ShouldEmitAnsi();
}

/// Formats markup and writes to stdout with a trailing newline.
pub unit FormatLine(string text) {
    string styled = Console.Format.Format(text);
    System.Output.WriteLine(styled);
}

/// Writes formatted markup to stdout without a newline.
pub unit FormatWrite(string text) {
    string styled = Console.Format.Format(text);
    System.Output.Write(styled);
}

/// Returns the current terminal size (best-effort per host).
pub ConsoleSize QuerySize() {
    return Platform.Terminal.QuerySize();
}

/// Default unbounded channel for resize and tick messages (cross-fiber UI loop).
pub Channel<ConsoleMessage> MessagesChannel() {
    return Channel<ConsoleMessage>.Create();
}

/// Subscribes to resize notifications and synchronously raises once with the current size.
pub unit SubscribeOnResize(mut OnResize hub, unit(ConsoleSize) handler) {
    hub.OnResize += handler;
    ConsoleSize now = QuerySize();
    hub.lastSize = now;
    hub.OnResize(now);
    return;
}

/// Polls terminal size and **Send**s `ConsoleMessage::Resize` when dimensions change.
pub unit RunTick(Channel<ConsoleMessage> messages, mut ConsoleSize lastSize) {
    Platform.Terminal.PollResize(messages, lastSize);
    return;
}

/// Polls resize, publishes tick to `messages`, and advances registered live controls.
pub LiveTick.LiveTickState RunTickLive(
    Channel<ConsoleMessage> messages,
    mut ConsoleSize lastSize,
    LiveTick.LiveTickState live
) {
    Platform.Terminal.PollResize(messages, lastSize);
    match messages.Send(ConsoleMessage::Tick()) {
        Result::Ok(_) => {},
        Result::Error(_) => {},
    };
    return LiveTick.Pulse(live);
}

/// In-fiber resize multicast (same-fiber handlers only); prefer `MessagesChannel` across fibers.
pub unit RunTickHub(mut OnResize hub) {
    Platform.Terminal.PollResizeHub(hub);
    return;
}

/// Initializes platform terminal probes and seeds resize tracking on the hub.
pub unit Start(mut OnResize hub) {
    Platform.Terminal.EnsureInitialized();
    hub.lastSize = QuerySize();
    return;
}
