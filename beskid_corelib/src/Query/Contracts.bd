/// Query-facing option and iterator contracts.
pub enum Option {
    /// Present value variant.
    Some(i64 value),
    /// Absent value variant.
    None,
}

/// Forward-only query iterator contract.
pub contract Iterator {
    /// Returns the next optional value.
    Option Next();
}

/// Returns true when the option is Some.
pub bool HasValue(Option value) {
    return match value {
        Option::Some(_) => true,
        Option::None => false,
    };
}
