/// Panel measure/render and frame selection.
use Console.Controls.Panel;

test panel_ascii_frame_uses_plus_corners {
    Panel.Panel p = Panel.Panel.WithAsciiFrame(
        Panel.Panel.WithTitle(Panel.Panel.New("hello"), "Title")
    );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 20, rows: 10 };
    string rendered = Panel.Panel.Render(p, size);
    Testing.Assert.Contains(rendered, "+", "expected ASCII frame corners");
}

test panel_measure_respects_available_width {
    Panel.Panel p = Panel.Panel.New("body");
    Console.ConsoleSize available = Console.ConsoleSize { columns: 40, rows: 20 };
    Console.ConsoleSize measured = Panel.Panel.Measure(p, available);
    Testing.Assert.True(
        measured.columns <= available.columns,
        "panel measure should not exceed available columns"
    );
    Testing.Assert.True(measured.rows >= 3, "panel measure should include border rows");
}

test panel_title_left_in_top_border {
    Panel.Panel p = Panel.Panel.WithTitle(
        Panel.Panel.New("x"),
        "Hi"
    );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 16, rows: 8 };
    string rendered = Panel.Panel.Render(p, size);
    Testing.Assert.Contains(rendered, "Hi", "expected title in rendered panel");
}
