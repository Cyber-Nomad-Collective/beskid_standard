/// Golden tests for SGR escape sequences.

use Ansi.Escape;
use Ansi.Osc;
use Ansi.Sgr;
use Ansi.StyleChain;
use Console.Capabilities;
use Testing.Assert;


test ansi_bold_golden {
    string styled = Ansi.StyleChain.Apply(Ansi.StyleChain.Bold(Ansi.StyleChain.New()), "x");
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Contains(styled, "[1m", "bold SGR should contain [1m");
    }
}

test ansi_fg256_golden {
    string styled = Ansi.StyleChain.Apply(
        Ansi.StyleChain.Fg256(Ansi.StyleChain.New(), 196),
        "y"
    );
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Contains(styled, "38;5;196", "256-color fg should contain 38;5;196");
    }
}

test ansi_sgr_apply_reset {
    string styled = Ansi.Sgr.ApplyTo(Ansi.Sgr.Bold(Ansi.Sgr.Start()), "z");
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Contains(styled, "[1m", "Sgr.ApplyTo bold should contain [1m");
        Assert.Contains(styled, "[0m", "Sgr.ApplyTo should end with reset [0m");
    }
}

test ansi_osc_title_golden {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Osc.IntoSequence(
        Ansi.Osc.SetTitle(Ansi.Osc.Start(), "beskid")
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        Assert.Equal(seq, "", "OSC title should be empty when ANSI disabled");
        return;
    }
    Assert.Contains(seq, "${esc}]0;beskid", "OSC title should contain ]0;beskid");
}

test ansi_osc_hyperlink_contains_uri {
    string linked = Ansi.Osc.Hyperlink("https://beskid.dev", "link");
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Contains(linked, "8;;https://beskid.dev", "hyperlink open should embed uri");
        Assert.Contains(linked, "link", "hyperlink should preserve label");
    }
}
