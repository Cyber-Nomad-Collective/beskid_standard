/// Path helper API (POSIX-oriented v1).
/// @tier(supported)

pub string Separator() {
    return "/";
}

pub string Combine(string left, string right) {
    if left === "" {
        return right;
    }
    if right === "" {
        return left;
    }
    return left + "/" + right;
}

pub string FileName(string path) {
    if path == "" {
        return "";
    }
    i64 slash = Core.String.IndexOfFrom(path, 0, "/");
    if slash < 0 {
        return path;
    }
    i64 last = slash;
    i64 next = Core.String.IndexOfFrom(path, last + 1, "/");
    while !(next < 0) {
        last = next;
        next = Core.String.IndexOfFrom(path, last + 1, "/");
    }
    if last + 1 >= Core.String.Len(path) {
        return "";
    }
    return __str_slice(path, last + 1, Core.String.Len(path) - last - 1);
}

pub string DirectoryName(string path) {
    if path == "" {
        return "";
    }
    i64 slash = Core.String.IndexOfFrom(path, 0, "/");
    if slash < 0 {
        return "";
    }
    i64 last = slash;
    i64 next = Core.String.IndexOfFrom(path, last + 1, "/");
    while !(next < 0) {
        last = next;
        next = Core.String.IndexOfFrom(path, last + 1, "/");
    }
    if last == 0 {
        return "/";
    }
    return __str_slice(path, 0, last);
}

pub string Extension(string path) {
    string name = FileName(path);
    i64 dot = Core.String.IndexOfFrom(name, 0, ".");
    if dot < 0 {
        return "";
    }
    return __str_slice(name, dot + 1, Core.String.Len(name) - dot - 1);
}

pub bool HasExtension(string path) {
    return !Core.String.IsEmpty(Extension(path));
}

pub bool IsAbsolute(string path) {
    if path == "" {
        return false;
    }
    if path == "/" {
        return true;
    }
    if Core.String.Len(path) > 1 && Core.String.ByteAt(path, 0) == 47 {
        return true;
    }
    return false;
}

pub bool IsEmpty(string path) {
    return path == "";
}

pub string ChangeExtension(string path, string extension) {
    string name = FileName(path);
    string dir = DirectoryName(path);
    i64 dot = Core.String.IndexOfFrom(name, 0, ".");
    string stem = name;
    if dot >= 0 {
        stem = __str_slice(name, 0, dot);
    }
    if Core.String.IsEmpty(extension) {
        if Core.String.IsEmpty(dir) {
            return stem;
        }
        return Combine(dir, stem);
    }
    string file = stem + "." + extension;
    if Core.String.IsEmpty(dir) {
        return file;
    }
    return Combine(dir, file);
}
