/// Fiber handle runtime wrapper tests.

use Concurrency.Fiber;
use Core.Results;
use Testing.Assert;


i64 child_value() {
    return 42;
}

test fiber_spawn_join_returns_value {
    Concurrency.Fiber<i64> fiber = spawn child_value;
    Core.Results.Result<i64, Concurrency.FiberError> joined = fiber.Join();
    match joined {
        Result::Ok(value) => {
            Assert.Equal(value, 42, "fiber join value mismatch");
        },
        Result::Error(_) => {
            Assert.Fail("fiber join should succeed");
        }
    };
}

/// Fiber module exposes `OnCancelled` on the handle struct (compile-time contract).

test fiber_module_compiles {
    return;
}
