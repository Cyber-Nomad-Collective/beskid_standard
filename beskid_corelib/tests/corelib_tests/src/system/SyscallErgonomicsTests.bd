/// Runtime-backed syscall contract checks aligned with platform-spec panic-io-and-syscalls.
/// Typed `Core.Syscall` wrapper tests (match / `Result`) require project dependency symbols
/// in the JIT pipeline; until then this target validates stdin read, stdout write, and invalid fd
/// behavior via runtime builtins used by the wrappers.

test syscall_write_stdout_builtin_smoke {
    i64 written = __syscall_write(1_i64, "ergonomic-write");
    if written < 1 {
        __panic_str("stdout write should return at least one byte");
    }
}

test syscall_read_stdout_builtin_returns_empty_on_stub {
    string text = __syscall_read(1_i64, 4_i64);
    i64 len = __str_len(text);
    if len < 0 {
        __panic_str("unsupported read fd should yield empty string with non-negative length");
    }
}

test syscall_write_invalid_fd_builtin_returns_negative {
    i64 written = __syscall_write(-1_i64, "x");
    if written >= 0 {
        __panic_str("invalid fd write should return negative byte count");
    }
}
