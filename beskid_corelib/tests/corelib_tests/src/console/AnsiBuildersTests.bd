/// Golden sequences for cursor, screen, erase, and input-mode builders.

use Ansi.Cursor;
use Ansi.Erase;
use Ansi.Escape;
use Ansi.InputMode;
use Ansi.Screen;
use Ansi.StyleChain;
use Console.Capabilities;
use Testing.Assert;


test ansi_cursor_position_golden {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Cursor.IntoSequence(
        Ansi.Cursor.Position(Ansi.Cursor.Start(), 3, 5)
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        Assert.Equal(seq, "", "cursor position empty when disabled");
        return;
    }
    string expected = "${esc}[3;5H";
    Assert.Equal(seq, expected, "cursor position CSI");
}

test ansi_cursor_up_golden {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Cursor.IntoSequence(
        Ansi.Cursor.Up(Ansi.Cursor.Start(), 2)
    );
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Equal(seq, "${esc}[2A", "cursor up CSI");
    }
}

test ansi_screen_hide_cursor {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Screen.IntoSequence(
        Ansi.Screen.HideCursor(Ansi.Screen.Start())
    );
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Equal(seq, "${esc}[?25l", "hide cursor private mode");
    }
}

test ansi_erase_line_all {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Erase.IntoSequence(
        Ansi.Erase.LineAll(Ansi.Erase.Start())
    );
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Equal(seq, "${esc}[2K", "erase line all CSI");
    }
}

test ansi_input_mouse_drag_enable {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.InputMode.IntoSequence(
        Ansi.InputMode.EnableMouseDrag(Ansi.InputMode.Start())
    );
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Equal(seq, "${esc}[?1002h", "mouse drag enable");
    }
}

test ansi_style_chain_dim_strike {
    string styled = Ansi.StyleChain.Apply(
        Ansi.StyleChain.Strike(
            Ansi.StyleChain.Dim(Ansi.StyleChain.New())
        ),
        "t"
    );
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Contains(styled, "[2m", "dim SGR");
        Assert.Contains(styled, "[9m", "strike SGR");
    }
}
