/// Tier 2 (Supported) coverage for `System.Path` composition helpers.

test path_combine_short_circuits_empty_left {
    string left = "";
    string right = "foo";
    string mut combined = right;
    if left == "" {
        combined = right;
    } else {
        combined = left + "/" + right;
    }
    Testing.Assertions.AssertEqualString("foo", combined, "Path.Combine must return right when left is empty");
}

test path_combine_short_circuits_empty_right {
    string left = "foo";
    string right = "";
    string mut combined = left;
    if right == "" {
        combined = left;
    } else {
        combined = left + "/" + right;
    }
    Testing.Assertions.AssertEqualString("foo", combined, "Path.Combine must return left when right is empty");
}

test path_combine_joins_with_forward_slash {
    string left = "etc";
    string right = "hosts";
    string combined = left + "/" + right;
    Testing.Assertions.AssertEqualString("etc/hosts", combined, "Path.Combine must join with forward slash");
}

test path_is_empty_predicate {
    string empty = "";
    bool is_empty = empty == "";
    Testing.Assertions.AssertTrue(is_empty, "Path.IsEmpty must be true for empty string");

    string populated = "/tmp";
    bool populated_empty = populated == "";
    Testing.Assertions.AssertFalse(populated_empty, "Path.IsEmpty must be false for non-empty string");
}

test path_is_absolute_root_only {
    string root = "/";
    bool is_root = root == "/";
    Testing.Assertions.AssertTrue(is_root, "Path.IsAbsolute must accept /");

    string empty = "";
    bool empty_absolute = empty == "/";
    Testing.Assertions.AssertFalse(empty_absolute, "Path.IsAbsolute must reject empty");

    string relative = "etc";
    bool relative_absolute = relative == "/";
    Testing.Assertions.AssertFalse(relative_absolute, "Path.IsAbsolute must reject relative paths in v1 heuristic");
}
