/// Predicate helpers on `Core.Results.Result`.
test result_is_ok_detects_ok {
    Core.Results.Result<i64, string> ok = Result::Ok(7);
    if !Core.Results.IsOk(ok) {
        __panic_str("IsOk expected true for Ok");
    }
}

test result_is_ok_detects_error {
    Core.Results.Result<i64, string> err = Result::Error("e");
    if Core.Results.IsOk(err) {
        __panic_str("IsOk expected false for Error");
    }
}

test result_is_error_detects_error {
    Core.Results.Result<i64, string> err = Result::Error("e");
    if !Core.Results.IsError(err) {
        __panic_str("IsError expected true for Error");
    }
}

test result_is_error_detects_ok {
    Core.Results.Result<i64, string> ok = Result::Ok(1);
    if Core.Results.IsError(ok) {
        __panic_str("IsError expected false for Ok");
    }
}
