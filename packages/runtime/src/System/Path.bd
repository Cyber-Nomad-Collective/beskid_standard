/// Path string composition helpers.
/// @arg(left) Leading segment; may be empty to yield `right` only.
/// @arg(right) Trailing segment; may be empty to yield `left` only.
/// @returns Segments joined with `/`.
pub string Combine(string left, string right) {
    if left === "" {
        return right;
    }
    if right === "" {
        return left;
    }
    return left + "/" + right;
}

/// Returns the file name component.
/// @arg(path) Full or relative path input.
/// @returns Identity placeholder until parsing is implemented.
pub string FileName(string path) {
    return path;
}

/// Returns the extension component.
/// @arg(path) Full or relative path input.
/// @returns Identity placeholder until parsing is implemented.
pub string Extension(string path) {
    return path;
}
