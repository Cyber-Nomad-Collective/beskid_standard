/// Fluent style chain applies SGR wrappers when ANSI is enabled.
test style_chain_bold_wraps {
    string out = Ansi.StyleChain.Apply(
        Ansi.StyleChain.Bold(Ansi.StyleChain.New()),
        "x"
    );
    if Console.Capabilities.ShouldEmitAnsi() && out == "x" {
        __panic_str("expected styled output when capabilities allow ANSI");
    }
}

test style_chain_inverse_prefix {
    string prefix = Ansi.StyleChain.IntoPrefix(
        Ansi.StyleChain.Inverse(Ansi.StyleChain.New())
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        if prefix != "" {
            __panic_str("inverse prefix should be empty when ANSI disabled");
        }
        return;
    }
    if !Core.String.Contains(prefix, "[7m") {
        __panic_str("inverse SGR should contain [7m");
    }
}

test sgr_builder_fg_basic_golden {
    string prefix = Ansi.Sgr.IntoPrefix(
        Ansi.Sgr.FgBasic(Ansi.Sgr.Start(), 31)
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        if prefix != "" {
            __panic_str("SGR prefix should be empty when ANSI disabled");
        }
        return;
    }
    if !Core.String.Contains(prefix, "[31m") {
        __panic_str("basic red fg should contain [31m");
    }
}
