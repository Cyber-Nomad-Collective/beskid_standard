/// Tier 2 (Supported) coverage for `Core.Path` composition helpers.

use Testing.Assert;


test path_combine_short_circuits_empty_left {
    string left = "";
    string right = "foo";
    mut string combined = right;
    if left == "" {
        combined = right;
    } else {
        combined = left + "/" + right;
    }
    Assert.Equal(combined, right, "Path.Combine must return right when left is empty");
}

test path_combine_short_circuits_empty_right {
    string left = "foo";
    string right = "";
    mut string combined = left;
    if right == "" {
        combined = left;
    } else {
        combined = left + "/" + right;
    }
    Assert.Equal(combined, left, "Path.Combine must return left when right is empty");
}

test path_combine_joins_with_forward_slash {
    string left = "etc";
    string right = "hosts";
    string combined = left + "/" + right;
    string expected = left + "/" + right;
    Assert.Equal(combined, expected, "Path.Combine must join with forward slash");
}

test path_is_empty_predicate {
    string empty = "";
    bool isEmpty = empty == "";
    Assert.True(isEmpty, "Path.IsEmpty must be true for empty string");

    string populated = "/tmp";
    bool populatedEmpty = populated == "";
    Assert.False(populatedEmpty, "Path.IsEmpty must be false for non-empty string");
}

test path_is_absolute_root_only {
    string root = "/";
    bool isRoot = root == "/";
    Assert.True(isRoot, "Path.IsAbsolute must accept /");

    string empty = "";
    bool emptyAbsolute = empty == "/";
    Assert.False(emptyAbsolute, "Path.IsAbsolute must reject empty");

    string relative = "etc";
    bool relativeAbsolute = relative == "/";
    Assert.False(relativeAbsolute, "Path.IsAbsolute must reject relative paths in v1 heuristic");
}
