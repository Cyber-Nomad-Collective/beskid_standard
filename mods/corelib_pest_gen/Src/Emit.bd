/// Code contribution emit for grammar combinator modules.
use Beskid.Compiler.Collect;
use Beskid.Compiler.Emitter.Contribution;

pub GeneratedSyntaxContribution BuildAll() {
    return Contribution.FromCodeOutputs([
        Contribution.CodeOutput(
            "Core.Text.Regex.Generated",
            "Generated",
            Contribution.CodeBody("beskid", RegexGeneratedHeader())
        ),
    ]);
}

pub string RegexGeneratedHeader() {
    return "// CHECKED IN: materialized combinator parser from grammars/regex.pest (corelib_pest_gen)\n/// Generated combinator parser module for `regex`.\nuse Core.Text.Cursor;\nuse Core.Text.Parser;\n";
}
