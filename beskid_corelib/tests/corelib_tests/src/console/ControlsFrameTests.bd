/// Frame glyphs and repeat helper for bordered controls.
use Console.Controls.Frame;

test unicode_frame_corners {
    Frame.FrameChars chars = Frame.Unicode();
    Testing.Assertions.AssertEqualString("┌", chars.topLeft, "unicode top-left");
    Testing.Assertions.AssertEqualString("│", chars.side, "unicode side");
}

test ascii_frame_corners {
    Frame.FrameChars chars = Frame.Ascii();
    Testing.Assertions.AssertEqualString("+", chars.topLeft, "ascii top-left");
    Testing.Assertions.AssertEqualString("-", chars.top, "ascii horizontal");
}

test repeat_builds_string {
    string line = Frame.Repeat("-", 4);
    Testing.Assertions.AssertEqualString("----", line, "Repeat four dashes");
}

test prefer_unicode_follows_ansi_capability {
    bool prefer = Frame.PreferUnicodeFrame();
    bool emit = Console.Capabilities.ShouldEmitAnsi();
    Testing.Assertions.AssertTrue(
        prefer == emit,
        "PreferUnicodeFrame should track ShouldEmitAnsi"
    );
}

test panel_unicode_frame_when_preferred {
    Console.Controls.Panel.Panel p = Console.Controls.Panel.Panel.WithTitle(
        Console.Controls.Panel.Panel.New("body"),
        "T"
    );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 24, rows: 8 };
    string rendered = Console.Controls.Panel.Panel.Render(p, size);
    if Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertContains(
            rendered,
            "┌",
            "unicode panel should use box drawing when ANSI enabled"
        );
    }
}
