/// Fluent style chain applies SGR wrappers when ANSI is enabled.
test style_chain_bold_wraps {
    string styled = Ansi.StyleChain.Apply(
        Ansi.StyleChain.Bold(Ansi.StyleChain.New()),
        "x"
    );
    if Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertTrue(styled != "x", "expected styled output when capabilities allow ANSI");
    }
}

test style_chain_inverse_prefix {
    string prefix = Ansi.StyleChain.IntoPrefix(
        Ansi.StyleChain.Inverse(Ansi.StyleChain.New())
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertEqualString("", prefix, "inverse prefix should be empty when ANSI disabled");
        return;
    }
    Testing.Assertions.AssertContains(prefix, "[7m", "inverse SGR should contain [7m");
}

test sgr_builder_fg_basic_golden {
    string prefix = Ansi.Sgr.IntoPrefix(
        Ansi.Sgr.FgBasic(Ansi.Sgr.Start(), 31)
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertEqualString("", prefix, "SGR prefix should be empty when ANSI disabled");
        return;
    }
    Testing.Assertions.AssertContains(prefix, "[31m", "basic red fg should contain [31m");
}
