/// Query execution helpers for deferred state checks and materialization.
/// Reports whether a query state is treated as deferred.
pub bool IsDeferred<T>(Query.Operators.QueryState<T> state) {
    return state.count > -1;
}

/// Materializes and returns element count.
pub i64 MaterializeCount<T>(Query.Operators.QueryState<T> state) {
    return Query.Operators.Count<T>(state);
}
