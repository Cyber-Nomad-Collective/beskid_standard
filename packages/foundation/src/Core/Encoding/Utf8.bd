/// UTF-8 encoding (language default).
/// @tier(standard)
use Core.Bytes.Slice;
use Core.Encoding.EncodingError;
use Core.Results;
use Core.String;

pub i64 RuneByteLen(u8 lead) {
    if lead < 128 {
        return 1;
    }
    if lead < 192 {
        return 0;
    }
    if lead < 224 {
        return 2;
    }
    if lead < 240 {
        return 3;
    }
    if lead < 248 {
        return 4;
    }
    return 0;
}

pub u8[] CopyCodeUnits(string text) {
    i64 len = String.Len(text);
    u8[] buf = Slice.New(len);
    mut i64 i = 0;
    while i < len {
        Slice.Set(buf, i, String.ByteAt(text, i));
        i = i + 1;
    }
    return buf;
}

pub Core.Results.Result<u8[], EncodingError> EncodeToBytes(string text) {
    return Result::Ok(CopyCodeUnits(text));
}

pub bool IsValid(u8[] data) {
    i64 len = Slice.Len(data);
    mut i64 i = 0;
    while i < len {
        u8 b = Slice.Get(data, i);
        if b < 128 {
            i = i + 1;
            continue;
        }
        i64 need = RuneByteLen(b);
        if need < 2 {
            return false;
        }
        if i + need - 1 >= len {
            return false;
        }
        mut i64 j = 1;
        while j < need {
            u8 cont = Slice.Get(data, i + j);
            if cont < 128 || cont >= 192 {
                return false;
            }
            j = j + 1;
        }
        i = i + need;
    }
    return true;
}

pub Core.Results.Result<string, EncodingError> DecodeFromBytes(u8[] data) {
    if !IsValid(data) {
        return Result::Error(EncodingError::InvalidSequence());
    }
    return Result::Ok(String.FromUtf8CodeUnits(data));
}
