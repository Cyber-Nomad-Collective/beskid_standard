/// `Console.Capabilities` color/TTY policy helpers.

use Console;
use Console.Capabilities;
use Testing.Assert;



test should_strip_when_no_color_set {
    Capabilities.Capabilities caps = Capabilities.Capabilities {
        isTty: true,
        colorDisabled: true,
        colorForced: false,
        model: Capabilities.ColorModel::Indexed256(),
    };
    Assert.True(Capabilities.ShouldStripColor(caps), "NO_COLOR should force strip");
}

test should_strip_when_not_tty_and_not_forced {
    Capabilities.Capabilities caps = Capabilities.Capabilities {
        isTty: false,
        colorDisabled: false,
        colorForced: false,
        model: Capabilities.ColorModel::TrueColor(),
    };
    Assert.True(Capabilities.ShouldStripColor(caps), "non-TTY without FORCE_COLOR should strip");
}

test should_not_strip_when_force_color_on_pipe {
    Capabilities.Capabilities caps = Capabilities.Capabilities {
        isTty: false,
        colorDisabled: false,
        colorForced: true,
        model: Capabilities.ColorModel::Indexed256(),
    };
    Assert.False(Capabilities.ShouldStripColor(caps), "FORCE_COLOR should allow ANSI on non-TTY");
}

test probe_stdout_returns_capabilities_record {
    Capabilities.Capabilities caps = Capabilities.ProbeStdout();
    Assert.True(
        caps.isTty || !caps.isTty,
        "ProbeStdout should return a populated capabilities record"
    );
}

test should_style_matches_should_emit_ansi {
    bool style = Console.ShouldStyle();
    bool emit = Capabilities.ShouldEmitAnsi();
    Assert.True(style == emit, "ShouldStyle should mirror ShouldEmitAnsi");
}
