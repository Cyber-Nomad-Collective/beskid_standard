/// Progress bar clamping, render, and incremental cursor output.
use Console.Controls.ProgressBar;
use Console.Controls.LiveTick;
use Testing.Assert;

test progress_bar_clamps_percent {
    ProgressBar.ProgressBar bar = ProgressBar.ProgressBar.WithPercent(
        ProgressBar.ProgressBar.New(),
        150
    );
    Testing.Assert.Equal(bar.percent, 100, "expected percent clamped to 100");
    ProgressBar.ProgressBar low = ProgressBar.ProgressBar.WithPercent(
        ProgressBar.ProgressBar.New(),
        -5
    );
    Testing.Assert.Equal(low.percent, 0, "expected percent clamped to 0");
}

test progress_bar_render_includes_percent_label {
    ProgressBar.ProgressBar bar = ProgressBar.ProgressBar.WithPercent(
        ProgressBar.ProgressBar.New(),
        42
    );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 20, rows: 5 };
    string rendered = ProgressBar.ProgressBar.Render(bar, size);
    Testing.Assert.Contains(rendered, "42%", "expected percent label in progress bar output");
}

test progress_bar_incremental_emits_cursor_csi {
    ProgressBar.ProgressBar bar = ProgressBar.ProgressBar.WithPercent(
        ProgressBar.ProgressBar.WithAnchor(
            ProgressBar.ProgressBar.New(),
            2,
            3
        ),
        50
    );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 16, rows: 8 };
    string rendered = ProgressBar.ProgressBar.RenderIncremental(bar, size);
    Testing.Assert.Contains(rendered, "[", "expected CSI cursor prefix in incremental render");
}

test progress_bar_live_tick_pulse {
    LiveTick.LiveTickState state = LiveTick.LiveTickState.RegisterProgressBar(
        LiveTick.LiveTickState.New(),
        ProgressBar.ProgressBar.WithPercent(
            ProgressBar.ProgressBar.New(),
            10
        )
    );
    LiveTick.LiveTickState next = LiveTick.LiveTickState.Pulse(state);
    Testing.Assert.True(next.hasProgressBar, "expected progress bar to remain registered after pulse");
}