/// Optional value carrier for query iterators and environment probes.
/// @par(T) Element type stored in `Some`.
/// @variant(Some) Carries a present `value`.
/// @variant(None) Represents absence.
pub enum Option<T> {
    /// Present value variant.
    Some(T value),
    /// Absent value variant.
    None,
}

/// Returns true when the option is `Some`.
/// @arg(value) Option to inspect.
/// @returns `true` when `value` is `Some`.
pub bool HasValue<T>(Option<T> value) {
    return match value {
        Option::Some(_) => true,
        Option::None => false,
    };
}
