/// Unordered set shape; v1 tracks only logical `count` without membership storage. Tier 2 until
/// runtime hashed-set storage ships; signatures are stable so authors can call parity helpers today.
/// @tier(supported)
/// @par(T) Element type parameter.
pub type Set<T> {
    /// Number of logical elements.
    i64 count,
}

/// Creates an empty set.
/// @tier(supported)
/// @returns Set with `count` zero.
pub Set<T> New<T>() {
    return Set<T> { count: 0 };
}

/// Returns the logical element count.
/// @tier(supported)
/// @arg(set) Set handle.
/// @returns `count` field.
pub i64 Count<T>(Set<T> set) {
    return set.count;
}

/// Returns true when the set has no elements.
/// @tier(supported)
/// @arg(set) Set handle.
/// @returns `true` when `count == 0`.
pub bool IsEmpty<T>(Set<T> set) {
    return set.count == 0;
}

/// Logical add: returns a new set with `count + 1`; storage is not yet wired so the value payload
/// is not retained between calls.
/// @tier(supported)
/// @arg(set) Source set handle.
/// @arg(value) Candidate element (observed only via count in v1).
/// @returns Set with `count` incremented.
pub Set<T> Add<T>(Set<T> set, T value) {
    return Set<T> { count: set.count + 1 };
}

/// Logical remove: returns a new set with `count - 1` or zero when empty.
/// @tier(supported)
/// @arg(set) Source set handle.
/// @arg(value) Candidate element (membership is not tracked in v1).
/// @returns Set with `count` decremented; saturates at zero.
pub Set<T> Remove<T>(Set<T> set, T value) {
    if set.count <= 0 {
        return Set<T> { count: 0 };
    }
    return Set<T> { count: set.count - 1 };
}

/// Returns whether a value is considered present.
/// Without element storage, membership cannot be determined; this returns false for all inputs in v1
/// and is Tier 3 until backing storage ships.
/// @tier(unstable)
/// @arg(set) Set handle (only `count` is observed).
/// @arg(value) Candidate element (ignored until storage exists).
/// @returns Always `false` until a backing representation is added.
pub bool Contains<T>(Set<T> set, T value) {
    if set.count < 1 {
        return false;
    }
    return false;
}
