/// Tier 2 (Supported) coverage for `System.Time` UTC civil helpers.

use Testing.Assert;
use System.Time.Date;
use System.Time.DateTime;
use System.Time.Instant;
use System.Time.TimeError;


test time_parse_iso8601_date_accepts_epoch {
    Core.Results.Result<Date, TimeError> parsed = System.Time.ParseIso8601Date("1970-01-01");
    match parsed {
        Result::Ok(date) => {
            Assert.Equal(date.year, 1970, "year");
            Assert.Equal(date.month, 1, "month");
            Assert.Equal(date.day, 1, "day");
        },
        Result::Error(_) => {
            __panic_str("ParseIso8601Date must accept epoch date");
        },
    };
}

test time_format_date_iso_roundtrip_shape {
    Date date = Date { year: 2024, month: 6, day: 9 };
    string formatted = System.Time.FormatDateIso(date);
    Assert.Equal(formatted, "2024-06-09", "FormatDateIso");
}

test time_from_utc_datetime_epoch_instant {
    Date date = Date { year: 1970, month: 1, day: 1 };
    System.Time.TimeOfDay time = System.Time.TimeOfDay {
        hour: 0,
        minute: 0,
        second: 0,
        nanosecond: 0,
    };
    DateTime value = DateTime { date: date, time: time };
    Instant instant = System.Time.FromUtcDateTime(value);
    Assert.Equal(instant.nanos, 0, "epoch instant");
}

test time_duration_from_milliseconds {
    System.Time.Duration duration = System.Time.FromMilliseconds(1500);
    i64 millis = System.Time.DurationToMilliseconds(duration);
    Assert.Equal(millis, 1500, "DurationToMilliseconds");
}
