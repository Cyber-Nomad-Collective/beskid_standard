/// UTF-8 string helpers backed by runtime string builtins.
/// Returns the number of UTF-8 code units in text.
pub i64 Len(string text) {
    return __str_len(text);
}

/// Returns true when text is empty.
pub bool IsEmpty(string text) {
    return Len(text) == 0;
}

/// Returns true when needle is treated as present in text.
pub bool Contains(string text, string needle) {
    if needle == "" {
        return true;
    }
    if Len(needle) > Len(text) {
        return false;
    }
    if text == needle {
        return true;
    }
    return false;
}
