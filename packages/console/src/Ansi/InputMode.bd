/// Mouse and keyboard reporting mode builder implementing `Ansi.Contracts.AnsiInputModeStep` shapes.
use Ansi.Escape;

pub type InputModeBuilder {
    string parts,

    pub InputModeBuilder EnableMouseClick() {
        return Append(Escape.PrivateMode("1000", true));
    }

    pub InputModeBuilder DisableMouseClick() {
        return Append(Escape.PrivateMode("1000", false));
    }

    pub InputModeBuilder EnableMouseDrag() {
        return Append(Escape.PrivateMode("1002", true));
    }

    pub InputModeBuilder DisableMouseDrag() {
        return Append(Escape.PrivateMode("1002", false));
    }

    pub InputModeBuilder EnableMouseMotion() {
        return Append(Escape.PrivateMode("1003", true));
    }

    pub InputModeBuilder DisableMouseMotion() {
        return Append(Escape.PrivateMode("1003", false));
    }

    pub InputModeBuilder EnableSgrMouse() {
        return Append(Escape.PrivateMode("1006", true));
    }

    pub InputModeBuilder DisableSgrMouse() {
        return Append(Escape.PrivateMode("1006", false));
    }

    pub InputModeBuilder RedefineKey(i64 code, string binding) {
        return Append(Escape.Csi("${code};${binding}", "p"));
    }

    pub string IntoSequence() {
        return Escape.WhenEnabled(parts);
    }

    pub InputModeBuilder Append(string fragment) {
        return InputModeBuilder { parts: "${parts}${fragment}" };
    }
}

pub InputModeBuilder Start() {
    return InputModeBuilder { parts: "" };
}

pub InputModeBuilder EnableMouseClick(InputModeBuilder self) {
    return self.EnableMouseClick();
}

pub InputModeBuilder DisableMouseClick(InputModeBuilder self) {
    return self.DisableMouseClick();
}

pub InputModeBuilder EnableMouseDrag(InputModeBuilder self) {
    return self.EnableMouseDrag();
}

pub InputModeBuilder DisableMouseDrag(InputModeBuilder self) {
    return self.DisableMouseDrag();
}

pub InputModeBuilder EnableMouseMotion(InputModeBuilder self) {
    return self.EnableMouseMotion();
}

pub InputModeBuilder DisableMouseMotion(InputModeBuilder self) {
    return self.DisableMouseMotion();
}

pub InputModeBuilder EnableSgrMouse(InputModeBuilder self) {
    return self.EnableSgrMouse();
}

pub InputModeBuilder DisableSgrMouse(InputModeBuilder self) {
    return self.DisableSgrMouse();
}

pub InputModeBuilder RedefineKey(InputModeBuilder self, i64 code, string binding) {
    return self.RedefineKey(code, binding);
}

pub string IntoSequence(InputModeBuilder self) {
    return self.IntoSequence();
}

pub InputModeBuilder Append(InputModeBuilder self, string fragment) {
    return self.Append(fragment);
}
