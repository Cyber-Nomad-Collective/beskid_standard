/// Fluent cursor movement builder implementing `Ansi.Contracts.AnsiCursorStep` shapes.
use Ansi.Escape;

pub type CursorBuilder {
    string parts,

    pub CursorBuilder Up(i64 count) {
        return Append(Escape.Csi("${count}", "A"));
    }

    pub CursorBuilder Down(i64 count) {
        return Append(Escape.Csi("${count}", "B"));
    }

    pub CursorBuilder Right(i64 count) {
        return Append(Escape.Csi("${count}", "C"));
    }

    pub CursorBuilder Left(i64 count) {
        return Append(Escape.Csi("${count}", "D"));
    }

    pub CursorBuilder NextLine(i64 count) {
        return Append(Escape.Csi("${count}", "E"));
    }

    pub CursorBuilder PrevLine(i64 count) {
        return Append(Escape.Csi("${count}", "F"));
    }

    pub CursorBuilder Column(i64 col) {
        return Append(Escape.Csi("${col}", "G"));
    }

    pub CursorBuilder Home() {
        return Append(Escape.CsiSequence("", "H"));
    }

    pub CursorBuilder Position(i64 row, i64 col) {
        return Append(Escape.Csi("${row};${col}", "H"));
    }

    pub CursorBuilder SaveDec() {
        return Append(Escape.DecSaveCursor());
    }

    pub CursorBuilder RestoreDec() {
        return Append(Escape.DecRestoreCursor());
    }

    pub string IntoSequence() {
        return Escape.WhenEnabled(parts);
    }

    pub CursorBuilder Append(string fragment) {
        return CursorBuilder { parts: "${parts}${fragment}" };
    }
}

pub CursorBuilder Start() {
    return CursorBuilder { parts: "" };
}

pub CursorBuilder Up(CursorBuilder self, i64 count) {
    return self.Up(count);
}

pub CursorBuilder Down(CursorBuilder self, i64 count) {
    return self.Down(count);
}

pub CursorBuilder Right(CursorBuilder self, i64 count) {
    return self.Right(count);
}

pub CursorBuilder Left(CursorBuilder self, i64 count) {
    return self.Left(count);
}

pub CursorBuilder NextLine(CursorBuilder self, i64 count) {
    return self.NextLine(count);
}

pub CursorBuilder PrevLine(CursorBuilder self, i64 count) {
    return self.PrevLine(count);
}

pub CursorBuilder Column(CursorBuilder self, i64 col) {
    return self.Column(col);
}

pub CursorBuilder Home(CursorBuilder self) {
    return Append(self, Escape.CsiSequence("", "H"));
}

pub CursorBuilder Position(CursorBuilder self, i64 row, i64 col) {
    return self.Position(row, col);
}

pub CursorBuilder SaveDec(CursorBuilder self) {
    return self.SaveDec();
}

pub CursorBuilder RestoreDec(CursorBuilder self) {
    return self.RestoreDec();
}

pub string IntoSequence(CursorBuilder self) {
    return self.IntoSequence();
}

pub CursorBuilder Append(CursorBuilder self, string fragment) {
    return self.Append(fragment);
}
