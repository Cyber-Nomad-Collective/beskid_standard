/// High-level stdout output helpers.
/// @ref(System.Syscall) syscall-backed write path used by `Print` / `PrintLine`.

use System.Syscall.SyscallError;
use System.Syscall.Descriptor;
use System.Syscall.StandardStream;
use System.Syscall.WriteRequest;

/// Writes text to standard output.
/// @arg(text) UTF-8 payload written without an implicit newline.
/// @returns Unit; panics when the underlying write returns an error in v1.
pub unit Print(string text) {
    StandardStream stream = StandardStream::Stdout();
    Descriptor descriptor = Descriptor::Standard(stream);
    Core.Results.Result<i64, SyscallError> result =
        System.Syscall.WriteWith(
            WriteRequest {
                descriptor: descriptor,
                data: text
            }
        );
    match result {
        Result::Ok(_) => {},
        Result::Error(_) => __panic_str("System.IO.Print failed"),
    };
    return;
}

/// Writes text followed by a newline.
/// @arg(text) UTF-8 payload; a platform newline is appended after `Print(text)`.
/// @returns Unit; panics when either write returns an error in v1.
pub unit PrintLine(string text) {
    Print(text);
    Print("
");
}
