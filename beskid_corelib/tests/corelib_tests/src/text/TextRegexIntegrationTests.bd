/// Integration smoke for Core.Text.Regex over generated combinator parsers.

use Core.Text.Regex;
use Core.Optional;
use Testing.Assert;


test generated_parse_digit_compiles_via_regex_facade {
    bool valid = Regex.IsValidPattern("a");
    Assert.True(valid, "simple alpha pattern should validate");
}

test regex_match_finds_prefix {
    Option<Regex.MatchSpan> matched = Regex.Match("ab", "abxyz");
    bool ok = match matched {
        Option<Regex.MatchSpan>::Some(span) => span.end == 2,
        Option<Regex.MatchSpan>::None => false,
    };
    Assert.True(ok, "Match should succeed at prefix");
}
