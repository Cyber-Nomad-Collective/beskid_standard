/// Construction options for `Channel<T>.Create`.
/// Capacity selector: default is unbounded.
pub enum ChannelCapacity {
    Unbounded(),
    Bounded(i64 capacity),
}

/// Channel factory options (capacity plus v1 optimization hints).
pub type ChannelOptions {
    ChannelCapacity capacity,
    bool singleReader,
    bool singleWriter,
}

/// Default options: unbounded queue, no single-reader/writer hints.
pub ChannelOptions Default() {
    return ChannelOptions {
        capacity: ChannelCapacity::Unbounded(),
        singleReader: false,
        singleWriter: false,
    };
}

/// Explicit unbounded queue (equivalent to default).
pub ChannelOptions Unbounded() {
    return Default();
}

/// Bounded queue with `capacity > 0`; senders park when full.
pub ChannelOptions Bounded(i64 capacity) {
    return ChannelOptions {
        capacity: ChannelCapacity::Bounded(capacity),
        singleReader: false,
        singleWriter: false,
    };
}

/// Unbounded queue optimized for a single reader.
pub ChannelOptions SingleReader() {
    return ChannelOptions {
        capacity: ChannelCapacity::Unbounded(),
        singleReader: true,
        singleWriter: false,
    };
}

/// Unbounded queue optimized for a single writer.
pub ChannelOptions SingleWriter() {
    return ChannelOptions {
        capacity: ChannelCapacity::Unbounded(),
        singleReader: false,
        singleWriter: true,
    };
}

/// Encodes capacity for `__channel_create` (`0` = unbounded).
pub i64 EncodeCapacity(ChannelOptions options) {
    return match options.capacity {
        ChannelCapacity::Unbounded() => 0,
        ChannelCapacity::Bounded(capacity) => capacity,
    };
}

/// Encodes reader/writer hint flags for `__channel_create`.
pub i64 EncodeFlags(ChannelOptions options) {
    i64 flags = 0;
    if options.singleReader {
        flags = flags + 1;
    }
    if options.singleWriter {
        flags = flags + 2;
    }
    return flags;
}
