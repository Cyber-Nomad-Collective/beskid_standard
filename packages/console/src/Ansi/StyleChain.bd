/// Concrete fluent SGR builder implementing `Ansi.Contracts.AnsiStyleStep` shapes.
use Ansi.Escape;
use Console.Capabilities;

pub type StyleChain {
    string openCodes,

    pub StyleChain Bold() {
        return AppendCode("1");
    }

    pub StyleChain Dim() {
        return AppendCode("2");
    }

    pub StyleChain Italic() {
        return AppendCode("3");
    }

    pub StyleChain Underline() {
        return AppendCode("4");
    }

    pub StyleChain Inverse() {
        return AppendCode("7");
    }

    pub StyleChain Strike() {
        return AppendCode("9");
    }

    pub StyleChain FgBasic(i64 code) {
        return AppendCode("${code}");
    }

    pub StyleChain BgBasic(i64 code) {
        return AppendCode("${code}");
    }

    pub StyleChain Fg256(i64 index) {
        return AppendCode("38;5;${index}");
    }

    pub StyleChain Bg256(i64 index) {
        return AppendCode("48;5;${index}");
    }

    pub StyleChain FgRgb(i64 r, i64 g, i64 b) {
        return AppendCode(Ansi.Sgr.ForegroundColorArgs(r, g, b));
    }

    pub StyleChain BgRgb(i64 r, i64 g, i64 b) {
        return AppendCode(Ansi.Sgr.BackgroundColorArgs(r, g, b));
    }

    pub StyleChain Foreground256(i64 index) {
        return Fg256(index);
    }

    pub StyleChain Background256(i64 index) {
        return Bg256(index);
    }

    pub StyleChain ForegroundRgb(i64 r, i64 g, i64 b) {
        return FgRgb(r, g, b);
    }

    pub StyleChain BackgroundRgb(i64 r, i64 g, i64 b) {
        return BgRgb(r, g, b);
    }

    pub string IntoPrefix() {
        return Open();
    }

    pub string Open() {
        if openCodes == "" {
            return "";
        }
        return Escape.EmitCsi(openCodes, "m");
    }

    pub string ApplyTo(string text) {
        return Apply(text);
    }

    pub string Apply(string text) {
        if !Capabilities.ShouldEmitAnsi() {
            return text;
        }
        return "${Open()}${text}${Reset()}";
    }

    pub StyleChain AppendCode(string code) {
        if openCodes == "" {
            return StyleChain { openCodes: code };
        }
        return StyleChain { openCodes: "${openCodes};${code}" };
    }
}

/// Starts a new style chain.
pub StyleChain New() {
    return StyleChain { openCodes: "" };
}

pub string Reset() {
    return Escape.EmitCsi("0", "m");
}

pub StyleChain Bold(StyleChain chain) {
    return chain.Bold();
}

pub StyleChain Dim(StyleChain chain) {
    return chain.Dim();
}

pub StyleChain Italic(StyleChain chain) {
    return chain.Italic();
}

pub StyleChain Underline(StyleChain chain) {
    return chain.Underline();
}

pub StyleChain Inverse(StyleChain chain) {
    return chain.Inverse();
}

pub StyleChain Strike(StyleChain chain) {
    return chain.Strike();
}

pub StyleChain FgBasic(StyleChain chain, i64 code) {
    return chain.FgBasic(code);
}

pub StyleChain BgBasic(StyleChain chain, i64 code) {
    return chain.BgBasic(code);
}

pub StyleChain Fg256(StyleChain chain, i64 index) {
    return chain.Fg256(index);
}

pub StyleChain Bg256(StyleChain chain, i64 index) {
    return chain.Bg256(index);
}

pub StyleChain FgRgb(StyleChain chain, i64 r, i64 g, i64 b) {
    return chain.FgRgb(r, g, b);
}

pub StyleChain BgRgb(StyleChain chain, i64 r, i64 g, i64 b) {
    return chain.BgRgb(r, g, b);
}

pub StyleChain Foreground256(StyleChain chain, i64 index) {
    return chain.Foreground256(index);
}

pub StyleChain Background256(StyleChain chain, i64 index) {
    return chain.Background256(index);
}

pub StyleChain ForegroundRgb(StyleChain chain, i64 r, i64 g, i64 b) {
    return chain.ForegroundRgb(r, g, b);
}

pub StyleChain BackgroundRgb(StyleChain chain, i64 r, i64 g, i64 b) {
    return chain.BackgroundRgb(r, g, b);
}

pub string IntoPrefix(StyleChain chain) {
    return chain.IntoPrefix();
}

pub string Open(StyleChain chain) {
    return chain.Open();
}

pub string ApplyTo(StyleChain chain, string text) {
    return chain.ApplyTo(text);
}

pub string Apply(StyleChain chain, string text) {
    return chain.Apply(text);
}

pub StyleChain AppendCode(StyleChain chain, string code) {
    return chain.AppendCode(code);
}
