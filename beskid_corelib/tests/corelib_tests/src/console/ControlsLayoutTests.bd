/// Stack container smoke (render path deferred until JIT struct typing lands).

use Console.Controls.HorizontalStack;
use Console.Controls.VerticalStack;
use Testing.Assert;


test vertical_stack_child_count {
    VerticalStack.VerticalStack stack =
        VerticalStack.VerticalStack.WithChild(
            VerticalStack.VerticalStack.WithChild(
                VerticalStack.VerticalStack.New(),
                "a"
            ),
            "b"
        );
    Assert.Equal(VerticalStack.VerticalStack.ChildCount(stack), 2, "expected two vertical stack children");
}

test horizontal_stack_measure_width {
    HorizontalStack.HorizontalStack stack =
        HorizontalStack.HorizontalStack.WithChild(
            HorizontalStack.HorizontalStack.WithChild(
                HorizontalStack.HorizontalStack.New(),
                "ab"
            ),
            "cd"
        );
    ConsoleSize available = ConsoleSize { columns: 80, rows: 24 };
    ConsoleSize measured = HorizontalStack.HorizontalStack.Measure(stack, available);
    Assert.Equal(measured.rows, 1, "horizontal stack should measure one row");
    Assert.True(measured.columns >= 5, "horizontal stack should measure combined segment width");
}

test vertical_stack_render_smoke {
    bool smoke = true;
    Assert.True(smoke, "VerticalStack render deferred smoke");
}
