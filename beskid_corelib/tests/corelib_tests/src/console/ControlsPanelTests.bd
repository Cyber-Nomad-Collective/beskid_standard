/// Panel measure/render and frame selection.

use Console;
use Console.Controls.Panel;
use Testing.Assert;



test panel_ascii_frame_uses_plus_corners {
    Panel.Panel p = Panel.Panel.WithAsciiFrame(
        Panel.Panel.WithTitle(Panel.Panel.New("hello"), "Title")
    );
    ConsoleSize size = ConsoleSize { columns: 20, rows: 10 };
    string rendered = Panel.Panel.Render(p, size);
    Assert.Contains(rendered, "+", "expected ASCII frame corners");
}

test panel_measure_respects_available_width {
    Panel.Panel p = Panel.Panel.New("body");
    ConsoleSize available = ConsoleSize { columns: 40, rows: 20 };
    ConsoleSize measured = Panel.Panel.Measure(p, available);
    Assert.True(
        measured.columns <= available.columns,
        "panel measure should not exceed available columns"
    );
    Assert.True(measured.rows >= 3, "panel measure should include border rows");
}

test panel_title_left_in_top_border {
    Panel.Panel p = Panel.Panel.WithTitle(
        Panel.Panel.New("x"),
        "Hi"
    );
    ConsoleSize size = ConsoleSize { columns: 16, rows: 8 };
    string rendered = Panel.Panel.Render(p, size);
    Assert.Contains(rendered, "Hi", "expected title in rendered panel");
}
