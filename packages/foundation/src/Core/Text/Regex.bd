/// Regex matching via combinator parsers generated from `regex.pest`.
use Core.Text.Cursor;
use Core.Text.Parser;
use Core.Optional.Option;

pub mod Core.Text.Regex.Generated;

pub type MatchSpan {
    i64 start,
    i64 end,
}

pub enum MatchSpanList {
    Nil,
    Cons(MatchSpan head, MatchSpanList tail),
}

pub i64 MaxInputLen() {
    return 1048576;
}

pub bool InputTooLong(string text) {
    return Core.String.Len(text) > MaxInputLen();
}

pub bool IsValidPattern(string pattern) {
    if Core.String.Len(pattern) < 1 {
        return false;
    }
    Parser.Result.TextParseResult<string> parsed = Core.Text.Regex.Generated.ParsePat(Cursor.From(pattern));
    if !Parser.IsOk(parsed) {
        return false;
    }
    Cursor.TextCursor rest = Parser.RestOnOk(parsed, Cursor.From(pattern));
    return Cursor.AtEnd(rest);
}

pub Option<MatchSpan> Match(string pattern, string text) {
    if InputTooLong(text) {
        return Option<MatchSpan>::None;
    }
    if !IsValidPattern(pattern) {
        return Option<MatchSpan>::None;
    }
    MatchStep step = MatchPat(pattern, 0, text, 0);
    if !step.ok {
        return Option<MatchSpan>::None;
    }
    if step.text_pos < 1 {
        return Option<MatchSpan>::None;
    }
    return Option<MatchSpan>::Some(MatchSpan { start: 0, end: step.text_pos });
}

pub Option<MatchSpan> Find(string pattern, string text) {
    if InputTooLong(text) {
        return Option<MatchSpan>::None;
    }
    if !IsValidPattern(pattern) {
        return Option<MatchSpan>::None;
    }
    i64 n = Core.String.Len(text);
    i64 pos = 0;
    while pos <= n {
        MatchStep step = MatchPat(pattern, 0, text, pos);
        if step.ok && step.text_pos > pos {
            return Option<MatchSpan>::Some(MatchSpan { start: pos, end: step.text_pos });
        }
        pos = pos + 1;
    }
    return Option<MatchSpan>::None;
}

pub bool IsFindAllEmpty(MatchSpanList list) {
    return match list {
        MatchSpanList::Nil => true,
        MatchSpanList::Cons(_, _) => false,
    };
}

pub MatchSpanList FindAll(string pattern, string text) {
    if InputTooLong(text) {
        return MatchSpanList::Nil;
    }
    if !IsValidPattern(pattern) {
        return MatchSpanList::Nil;
    }
    return FindAllFrom(pattern, text, 0, MatchSpanList::Nil);
}

pub Option<MatchSpan> MatchLowerRun(string pattern, string text) {
    return Match(pattern, text);
}

/// Predicate helper so callers can avoid spelling `Option.HasValue<MatchSpan>`.
pub bool HasMatch(Option<MatchSpan> value) {
    return match value {
        Option::Some(_) => true,
        Option::None => false,
    };
}

/// True when `Match(pattern, text)` yields a span.
pub bool Matches(string pattern, string text) {
    return HasMatch(Match(pattern, text));
}

/// True when `Find(pattern, text)` yields a span.
pub bool Finds(string pattern, string text) {
    return HasMatch(Find(pattern, text));
}

pub type MatchStep {
    i64 pat_pos,
    i64 text_pos,
    bool ok,
}

MatchSpanList FindAllFrom(string pattern, string text, i64 start, MatchSpanList acc) {
    i64 n = Core.String.Len(text);
    if start > n {
        return acc;
    }
    MatchStep step = MatchPat(pattern, 0, text, start);
    if step.ok && step.text_pos > start {
        MatchSpan span = MatchSpan { start: start, end: step.text_pos };
        MatchSpanList next = MatchSpanList::Cons(span, acc);
        return FindAllFrom(pattern, text, step.text_pos, next);
    }
    return FindAllFrom(pattern, text, start + 1, acc);
}

MatchStep MatchPat(string pattern, i64 pat_pos, string text, i64 text_pos) {
    i64 branch_start = pat_pos;
    while branch_start < PatLen(pattern) {
        MatchStep branch = MatchBranch(pattern, branch_start, text, text_pos);
        if branch.ok {
            return branch;
        }
        i64 next_branch = NextPatBranch(pattern, branch_start);
        if next_branch < 0 {
            break;
        }
        branch_start = next_branch;
    }
    return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
}

MatchStep MatchBranch(string pattern, i64 pat_pos, string text, i64 text_pos) {
    i64 pos = pat_pos;
    i64 cur_text = text_pos;
    while pos < PatLen(pattern) {
        if PatAt(pattern, pos) == "|" {
            break;
        }
        MatchStep piece = MatchPiece(pattern, pos, text, cur_text);
        if !piece.ok {
            return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
        }
        pos = piece.pat_pos;
        cur_text = piece.text_pos;
    }
    return MatchStep { pat_pos: pos, text_pos: cur_text, ok: true };
}

MatchStep MatchPiece(string pattern, i64 pat_pos, string text, i64 text_pos) {
    if pat_pos >= PatLen(pattern) {
        return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
    }
    i64 piece_end = 0;
    string quant = "";
    MatchStep one = MatchPieceCore(pattern, pat_pos, text, text_pos);
    if !one.ok {
        return one;
    }
    piece_end = one.pat_pos;
    if piece_end < PatLen(pattern) {
        string q = PatAt(pattern, piece_end);
        if q == "*" || q == "+" || q == "?" {
            quant = q;
            piece_end = piece_end + 1;
        }
    }
    if quant == "" {
        return MatchStep { pat_pos: piece_end, text_pos: one.text_pos, ok: true };
    }
    return MatchQuant(pattern, pat_pos, piece_end, text, text_pos, quant);
}

MatchStep MatchPieceCore(string pattern, i64 pat_pos, string text, i64 text_pos) {
    string ch = PatAt(pattern, pat_pos);
    if ch == "^" {
        if text_pos != 0 {
            return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
        }
        return MatchStep { pat_pos: pat_pos + 1, text_pos: text_pos, ok: true };
    }
    if ch == "$" {
        if text_pos != PatLen(text) {
            return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
        }
        return MatchStep { pat_pos: pat_pos + 1, text_pos: text_pos, ok: true };
    }
    if ch == "(" {
        i64 close = FindClosingParen(pattern, pat_pos);
        if close < 0 {
            return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
        }
        MatchStep inner = MatchPat(pattern, pat_pos + 1, text, text_pos);
        if !inner.ok {
            return inner;
        }
        return MatchStep { pat_pos: close + 1, text_pos: inner.text_pos, ok: true };
    }
    if ch == "[" {
        i64 close = FindClosingBracket(pattern, pat_pos);
        if close < 0 {
            return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
        }
        return MatchClass(pattern, pat_pos + 1, close, text, text_pos);
    }
    if ch == "\\" {
        return MatchEscape(pattern, pat_pos, text, text_pos);
    }
    if ch == "." {
        return MatchDot(text, text_pos, pat_pos + 1);
    }
    return MatchLiteral(pattern, pat_pos, text, text_pos);
}

MatchStep MatchQuant(string pattern, i64 piece_start, i64 pat_after, string text, i64 text_pos, string quant) {
    i64 min = 1;
    i64 max = 1000000;
    if quant == "*" {
        min = 0;
    }
    if quant == "?" {
        min = 0;
        max = 1;
    }
    i64 count = 0;
    i64 cur_text = text_pos;
    i64 last_good = text_pos;
    while count < max {
        MatchStep one = MatchPieceCore(pattern, piece_start, text, cur_text);
        if !one.ok {
            break;
        }
        if one.text_pos == cur_text {
            return MatchStep { pat_pos: piece_start, text_pos: text_pos, ok: false };
        }
        count = count + 1;
        cur_text = one.text_pos;
        if count >= min {
            last_good = cur_text;
        }
    }
    if count < min {
        return MatchStep { pat_pos: piece_start, text_pos: text_pos, ok: false };
    }
    return MatchStep { pat_pos: pat_after, text_pos: last_good, ok: true };
}

MatchStep MatchDot(string text, i64 text_pos, i64 pat_after) {
    Cursor.TextCursor c = Cursor.Advance(Cursor.From(text), text_pos);
    Parser.Result.TextParseResult<string> parsed = Core.Text.Regex.Generated.ParseAnyUnit(c);
    if !Parser.IsOk(parsed) {
        return MatchStep { pat_pos: pat_after, text_pos: text_pos, ok: false };
    }
    Cursor.TextCursor rest = Parser.RestOnOk(parsed, c);
    return MatchStep { pat_pos: pat_after, text_pos: Cursor.Position(rest), ok: true };
}

MatchStep MatchEscape(string pattern, i64 pat_pos, string text, i64 text_pos) {
    if pat_pos + 1 >= PatLen(pattern) {
        return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
    }
    string esc = PatAt(pattern, pat_pos + 1);
    Cursor.TextCursor c = Cursor.Advance(Cursor.From(text), text_pos);
    Parser.Result.TextParseResult<string> parsed = Core.Text.Regex.Generated.ParseDigit(c);
    if esc == "d" {
        parsed = Core.Text.Regex.Generated.ParseDigit(c);
    } else if esc == "D" {
        parsed = MatchNotDigit(c);
    } else if esc == "w" {
        parsed = Core.Text.Regex.Generated.ParseWordTail(c);
    } else if esc == "W" {
        parsed = MatchNotWord(c);
    } else if esc == "s" {
        parsed = Core.Text.Regex.Generated.ParseSpace(c);
    } else if esc == "S" {
        parsed = MatchNotSpace(c);
    } else if esc == "." || esc == "\\" || esc == "/" || esc == "-" || esc == "+" || esc == "|" || esc == "(" || esc == ")" || esc == "[" || esc == "]" {
        string lit = PatAt(pattern, pat_pos + 1);
        parsed = Parser.Literal(c, lit, "escape");
    } else {
        return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
    }
    if !Parser.IsOk(parsed) {
        return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
    }
    Cursor.TextCursor rest = Parser.RestOnOk(parsed, c);
    return MatchStep { pat_pos: pat_pos + 2, text_pos: Cursor.Position(rest), ok: true };
}

Parser.Result.TextParseResult<string> MatchNotDigit(Cursor.TextCursor c) {
    Parser.Result.TextParseResult<string> digit = Core.Text.Regex.Generated.ParseDigit(c);
    if Parser.IsOk(digit) {
        return Parser.Fail(c, ParseErrorKind::ExpectedRule, "not_digit");
    }
    return Core.Text.Regex.Generated.ParseAnyUnit(c);
}

Parser.Result.TextParseResult<string> MatchNotWord(Cursor.TextCursor c) {
    Parser.Result.TextParseResult<string> word = Core.Text.Regex.Generated.ParseWordTail(c);
    if Parser.IsOk(word) {
        return Parser.Fail(c, ParseErrorKind::ExpectedRule, "not_word");
    }
    return Core.Text.Regex.Generated.ParseAnyUnit(c);
}

Parser.Result.TextParseResult<string> MatchNotSpace(Cursor.TextCursor c) {
    Parser.Result.TextParseResult<string> space = Core.Text.Regex.Generated.ParseSpace(c);
    if Parser.IsOk(space) {
        return Parser.Fail(c, ParseErrorKind::ExpectedRule, "not_space");
    }
    return Core.Text.Regex.Generated.ParseAnyUnit(c);
}

MatchStep MatchClass(string pattern, i64 start, i64 close, string text, i64 text_pos) {
    bool neg = false;
    i64 pos = start;
    if pos < close && PatAt(pattern, pos) == "^" {
        neg = true;
        pos = pos + 1;
    }
    Cursor.TextCursor c = Cursor.Advance(Cursor.From(text), text_pos);
    if Cursor.AtEnd(c) {
        return MatchStep { pat_pos: close + 1, text_pos: text_pos, ok: false };
    }
    string ch = Cursor.Slice(c, c.pos, 1);
    bool matched = ClassMatches(pattern, pos, close, ch, neg);
    if !matched {
        return MatchStep { pat_pos: close + 1, text_pos: text_pos, ok: false };
    }
    return MatchStep { pat_pos: close + 1, text_pos: text_pos + 1, ok: true };
}

bool ClassMatches(string pattern, i64 start, i64 close, string ch, bool neg) {
    i64 pos = start;
    bool found = false;
    while pos < close {
        string first = PatAt(pattern, pos);
        if pos + 2 < close && PatAt(pattern, pos + 1) == "-" {
            string last = PatAt(pattern, pos + 2);
            if CharInRange(ch, first, last) {
                found = true;
            }
            pos = pos + 3;
            continue;
        }
        if first == ch {
            found = true;
        }
        pos = pos + 1;
    }
    if neg {
        return !found;
    }
    return found;
}

bool CharInRange(string ch, string lo, string hi) {
    u8 cb = Core.String.ByteAt(ch, 0);
    u8 lb = Core.String.ByteAt(lo, 0);
    u8 hb = Core.String.ByteAt(hi, 0);
    if cb >= lb && cb <= hb {
        return true;
    }
    return false;
}

MatchStep MatchLiteral(string pattern, i64 pat_pos, string text, i64 text_pos) {
    i64 end = pat_pos;
    while end < PatLen(pattern) {
        string ch = PatAt(pattern, end);
        if ch == "|" || ch == "(" || ch == ")" || ch == "[" || ch == "]" || ch == "*" || ch == "+" || ch == "?" || ch == "^" || ch == "$" || ch == "." || ch == "\\" {
            break;
        }
        end = end + 1;
    }
    if end == pat_pos {
        return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
    }
    string lit = Cursor.Slice(Cursor.From(pattern), pat_pos, end - pat_pos);
    Cursor.TextCursor c = Cursor.Advance(Cursor.From(text), text_pos);
    Parser.Result.TextParseResult<string> parsed = Parser.Literal(c, lit, "literal");
    if !Parser.IsOk(parsed) {
        return MatchStep { pat_pos: pat_pos, text_pos: text_pos, ok: false };
    }
    Cursor.TextCursor rest = Parser.RestOnOk(parsed, c);
    return MatchStep { pat_pos: end, text_pos: Cursor.Position(rest), ok: true };
}

i64 NextPatBranch(string pattern, i64 pat_pos) {
    i64 pos = pat_pos;
    i64 depth = 0;
    while pos < PatLen(pattern) {
        string ch = PatAt(pattern, pos);
        if ch == "(" {
            depth = depth + 1;
        } else if ch == ")" {
            if depth > 0 {
                depth = depth - 1;
            }
        } else if ch == "|" && depth == 0 {
            return pos + 1;
        }
        pos = pos + 1;
    }
    return -1;
}

i64 FindClosingParen(string pattern, i64 open_pos) {
    i64 pos = open_pos + 1;
    i64 depth = 1;
    while pos < PatLen(pattern) {
        string ch = PatAt(pattern, pos);
        if ch == "(" {
            depth = depth + 1;
        } else if ch == ")" {
            depth = depth - 1;
            if depth == 0 {
                return pos;
            }
        }
        pos = pos + 1;
    }
    return -1;
}

i64 FindClosingBracket(string pattern, i64 open_pos) {
    i64 pos = open_pos + 1;
    while pos < PatLen(pattern) {
        if PatAt(pattern, pos) == "]" {
            return pos;
        }
        pos = pos + 1;
    }
    return -1;
}

i64 PatLen(string pattern) {
    return Core.String.Len(pattern);
}

string PatAt(string pattern, i64 index) {
    return Cursor.Slice(Cursor.From(pattern), index, 1);
}
