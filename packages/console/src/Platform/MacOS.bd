/// macOS terminal probes via libc Extern (`isatty`) and runtime `__tty_winsize`.
[Extern(Abi:"C", Library:"libc")]
pub contract Libc {
    i32 isatty(i32 fd);
}

pub bool IsAtty(i64 fd) {
    if fd < 0 {
        return false;
    }
    if fd > 2147483647 {
        return false;
    }
    return Libc.isatty(fd) == 1;
}

pub Console.ConsoleSize Winsize() {
    if !IsAtty(1) {
        return Console.ConsoleSize { columns: 0, rows: 0 };
    }
    i64 packed = __tty_winsize(1);
    if packed == 0 {
        return Console.ConsoleSize { columns: 80, rows: 24 };
    }
    i32 columns = packed / 65536;
    i32 rows = packed % 65536;
    return Console.ConsoleSize { columns: columns, rows: rows };
}
