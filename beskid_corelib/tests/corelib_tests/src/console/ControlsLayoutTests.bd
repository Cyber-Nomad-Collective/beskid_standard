/// Stack container measure/render contracts.
use Console.Controls.VerticalStack;
use Console.Controls.HorizontalStack;

test vertical_stack_child_count {
    VerticalStack.VerticalStack stack =
        VerticalStack.VerticalStack.WithChild(
            VerticalStack.VerticalStack.WithChild(
                VerticalStack.VerticalStack.New(),
                "a"
            ),
            "b"
        );
    Testing.Assertions.AssertEqualI64(
        2,
        VerticalStack.VerticalStack.ChildCount(stack),
        "expected two vertical stack children"
    );
}

test vertical_stack_render_joins_lines {
    VerticalStack.VerticalStack stack =
        VerticalStack.VerticalStack.WithChild(
            VerticalStack.VerticalStack.WithChild(
                VerticalStack.VerticalStack.New(),
                "one"
            ),
            "two"
        );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 40, rows: 10 };
    string rendered = VerticalStack.VerticalStack.Render(stack, size);
    Testing.Assertions.AssertContains(rendered, "one", "expected first child line");
    Testing.Assertions.AssertContains(rendered, "two", "expected second child line");
}

test horizontal_stack_measure_width {
    HorizontalStack.HorizontalStack stack =
        HorizontalStack.HorizontalStack.WithChild(
            HorizontalStack.HorizontalStack.WithChild(
                HorizontalStack.HorizontalStack.New(),
                "ab"
            ),
            "cd"
        );
    Console.ConsoleSize available = Console.ConsoleSize { columns: 80, rows: 24 };
    Console.ConsoleSize measured = HorizontalStack.HorizontalStack.Measure(stack, available);
    Testing.Assertions.AssertEqualI64(1, measured.rows, "horizontal stack should measure one row");
    Testing.Assertions.AssertTrue(measured.columns >= 5, "horizontal stack should measure combined segment width");
}