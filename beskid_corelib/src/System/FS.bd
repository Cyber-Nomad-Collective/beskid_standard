/// File system helper API.
pub enum FsError {
    /// Path cannot be found.
    NotFound(string path),
    /// Access rights are insufficient.
    PermissionDenied(string path),
    /// Uncategorized file system failure.
    Unknown(string message),
}

/// Reads full text content from a path.
pub Core.Results.Result<string, FsError> ReadAllText(string path) {
    if path == "" {
        return Result::Error(FsError::NotFound(path));
    }
    return Result::Error(FsError::Unknown("not implemented"));
}

/// Writes full text content to a path.
pub Core.Results.Result<bool, FsError> WriteAllText(string path, string text) {
    if path == "" {
        return Result::Error(FsError::NotFound(path));
    }
    if text == "" {
        return Result::Ok(true);
    }
    return Result::Error(FsError::Unknown("not implemented"));
}

/// Reports whether a path is considered to exist.
pub bool Exists(string path) {
    return path != "";
}
