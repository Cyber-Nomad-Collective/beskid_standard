use Core.Bytes.Convert;
use Core.Encoding.EncodingError;
use Core.Encoding.Utf8;
use Core.Results;
use Testing.Assert;


test utf8_encode_decode_round_trip {
    Result<u8[], EncodingError> encoded = Utf8.EncodeToBytes("hello");
    match encoded {
        Result::Ok(bytes) => {
            Assert.True(Utf8.IsValid(bytes), "encoded bytes should be valid utf8");
            Result<string, EncodingError> decoded = Utf8.DecodeFromBytes(bytes);
            match decoded {
                Result::Ok(text) => {
                    Assert.Equal(text, "hello", "Utf8 round trip");
                },
                Result::Error(_) => {
                    Assert.Fail("Utf8.DecodeFromBytes should succeed");
                },
            };
        },
        Result::Error(_) => {
            Assert.Fail("Utf8.EncodeToBytes should succeed");
        },
    };
}

test utf8_convert_helpers_round_trip {
    u8[] bytes = Convert.StringToBytes("hi");
    Result<string, EncodingError> text = Convert.BytesToString(bytes);
    match text {
        Result::Ok(value) => {
            Assert.Equal(value, "hi", "Convert round trip");
        },
        Result::Error(_) => {
            Assert.Fail("Convert.BytesToString should succeed");
        },
    };
}

test hex_encoding_smoke {
    bool smoke = true;
    Assert.True(smoke, "Hex encode/decode deferred until CLIF i8/i32 parity lands");
}

test base64_encoding_smoke {
    bool smoke = true;
    Assert.True(smoke, "Base64 encode/decode deferred until CLIF i8/i32 parity lands");
}
