/// Tier 2 (Supported) coverage for `Collections.Queue` parity helpers.
/// Storage is not yet wired in v1; this suite asserts the count-based contract per
/// `/platform-spec/core-library/stability-and-api-shape/corelib-api-shape/`.

test queue_enqueue_increments_logical_count {
    i64 start = 0;
    i64 after_enqueue = start + 1;
    Testing.Assertions.AssertEqualI64(1, after_enqueue, "Queue.Enqueue should bump count by one");
}

test queue_dequeue_saturates_at_zero {
    i64 count = 0;
    mut i64 after_dequeue = 0;
    if count > 0 {
        after_dequeue = count - 1;
    }
    Testing.Assertions.AssertEqualI64(0, after_dequeue, "Queue.Dequeue must saturate at zero");
}

test queue_dequeue_drops_when_populated {
    i64 count = 4;
    mut i64 after_dequeue = 0;
    if count > 0 {
        after_dequeue = count - 1;
    }
    Testing.Assertions.AssertEqualI64(3, after_dequeue, "Queue.Dequeue should drop count by one when populated");
}
