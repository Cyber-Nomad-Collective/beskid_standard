/// Syscall API contract checks for `Core.Syscall` read boundaries.

use Testing.Assert;
use Core.Syscall;
use Core.Results;


test syscall_read_rejects_unsupported_fd {
    Core.Results.Result<string, Core.Syscall.SyscallError> result =
        Core.Syscall.Read(99_i64, 8_i64);
    Assert.True(Results.IsError(result), "Read on non-stdin fd should fail");
}

test syscall_read_rejects_invalid_limit {
    Core.Results.Result<string, Core.Syscall.SyscallError> result =
        Core.Syscall.Read(Core.Syscall.StdinFd(), 0_i64);
    Assert.True(Results.IsError(result), "non-positive read limit should fail");
}
