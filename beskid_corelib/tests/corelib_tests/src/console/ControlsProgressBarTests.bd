/// Progress bar clamping, render, and incremental cursor output.
test progress_bar_clamps_percent {
    Console.Controls.ProgressBar.ProgressBar bar = Console.Controls.ProgressBar.ProgressBar.WithPercent(
        Console.Controls.ProgressBar.ProgressBar.New(),
        150
    );
    if bar.percent != 100 {
        __panic_str("expected percent clamped to 100");
    }
    Console.Controls.ProgressBar.ProgressBar low = Console.Controls.ProgressBar.ProgressBar.WithPercent(
        Console.Controls.ProgressBar.ProgressBar.New(),
        -5
    );
    if low.percent != 0 {
        __panic_str("expected percent clamped to 0");
    }
}

test progress_bar_render_includes_percent_label {
    Console.Controls.ProgressBar.ProgressBar bar = Console.Controls.ProgressBar.ProgressBar.WithPercent(
        Console.Controls.ProgressBar.ProgressBar.New(),
        42
    );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 20, rows: 5 };
    string out = Console.Controls.ProgressBar.ProgressBar.Render(bar, size);
    if !Core.String.Contains(out, "42%") {
        __panic_str("expected percent label in progress bar output");
    }
}

test progress_bar_incremental_emits_cursor_csi {
    Console.Controls.ProgressBar.ProgressBar bar = Console.Controls.ProgressBar.ProgressBar.WithPercent(
        Console.Controls.ProgressBar.ProgressBar.WithAnchor(
            Console.Controls.ProgressBar.ProgressBar.New(),
            2,
            3
        ),
        50
    );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 16, rows: 8 };
    string out = Console.Controls.ProgressBar.ProgressBar.RenderIncremental(bar, size);
    if !Core.String.Contains(out, "[") {
        __panic_str("expected CSI cursor prefix in incremental render");
    }
}

test progress_bar_live_tick_pulse {
    Console.Controls.LiveTick.LiveTickState state = Console.Controls.LiveTick.LiveTickState.RegisterProgressBar(
        Console.Controls.LiveTick.LiveTickState.New(),
        Console.Controls.ProgressBar.ProgressBar.WithPercent(
            Console.Controls.ProgressBar.ProgressBar.New(),
            10
        )
    );
    Console.Controls.LiveTick.LiveTickState next = Console.Controls.LiveTick.LiveTickState.Pulse(state);
    if !next.hasProgressBar {
        __panic_str("expected progress bar to remain registered after pulse");
    }
}
