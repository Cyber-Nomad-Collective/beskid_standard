/// Markdown subset parsing for `Console.Format` (plain strip + styled smoke).
use Console.Format;
use Console.Format.Scan;

test strip_bold_plain {
    string out = Console.Format.StripMarkup("**bold**");
    if out != "bold" {
        __panic_str("strip bold");
    }
}

test strip_italic_plain {
    string out = Console.Format.StripMarkup("*italic*");
    if out != "italic" {
        __panic_str("strip italic");
    }
}

test strip_underline_plain {
    string out = Console.Format.StripMarkup("__under__");
    if out != "under" {
        __panic_str("strip underline");
    }
}

test strip_strike_plain {
    string out = Console.Format.StripMarkup("~~x~~");
    if out != "x" {
        __panic_str("strip strike");
    }
}

test strip_link_plain {
    string out = Console.Format.StripMarkup("[label](https://example.com)");
    if out != "label" {
        __panic_str("strip link");
    }
}

test strip_attr_span_plain {
    string out = Console.Format.StripMarkup("&[fg=red](text)");
    if out != "text" {
        __panic_str("strip attr span");
    }
}

test strip_escape_star {
    string out = Console.Format.StripMarkup("\\*literal\\*");
    if out != "*literal*" {
        __panic_str("strip escaped star");
    }
}

test strip_nested_styles_plain {
    string out = Console.Format.StripMarkup("**b *i* b**");
    if out != "b i b" {
        __panic_str("strip nested");
    }
}

test format_plain_when_ansi_disabled_matches_strip {
    if !Console.Capabilities.ShouldEmitAnsi() {
        string stripped = Console.Format.StripMarkup("**x**");
        string formatted = Console.Format.Format("**x**");
        if formatted != stripped {
            __panic_str("Format should match StripMarkup when ANSI disabled");
        }
    }
}

test format_bold_emits_sgr_when_ansi_enabled {
    if Console.Capabilities.ShouldEmitAnsi() {
        string out = Console.Format.Format("**z**");
        if out == "z" {
            __panic_str("expected bold SGR when ANSI enabled");
        }
        if !Scan.ContainsSubstring(out, "[1m") {
            __panic_str("expected bold CSI in output");
        }
    }
}
