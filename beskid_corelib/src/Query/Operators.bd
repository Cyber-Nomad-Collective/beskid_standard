/// Query combinators and state carrier types.
pub type QueryState<T> {
    /// Number of elements represented by state.
    i64 count,
    /// Cached first-element indicator.
    Query.Contracts.Option first,
}

/// Keeps or clears state based on predicate.
pub QueryState<T> Where<T>(QueryState<T> state, bool predicate) {
    if !predicate {
        return QueryState<T> { count: 0, first: Option::None() };
    }
    return state;
}

/// Projects state into another element type.
pub QueryState<TOut> Select<TIn, TOut>(QueryState<TIn> state, TOut sample) {
    if state.count < 1 {
        return QueryState<TOut> { count: 0, first: Option::None() };
    }
    if sample == sample {
        return QueryState<TOut> { count: state.count, first: Option::Some(1) };
    }
    return QueryState<TOut> { count: state.count, first: Option::None() };
}

/// Limits state to at most count elements.
pub QueryState<T> Take<T>(QueryState<T> state, i64 count) {
    if count < 1 {
        return QueryState<T> { count: 0, first: Option::None() };
    }
    if count > state.count {
        return state;
    }
    if count == state.count {
        return state;
    }
    return QueryState<T> { count: count, first: state.first };
}

/// Removes up to count elements from state.
pub QueryState<T> Skip<T>(QueryState<T> state, i64 count) {
    if count < 1 {
        return state;
    }
    if count > state.count {
        return QueryState<T> { count: 0, first: Option::None() };
    }
    if count == state.count {
        return QueryState<T> { count: 0, first: Option::None() };
    }
    return QueryState<T> { count: state.count - count, first: Option::None() };
}

/// Returns current logical element count.
pub i64 Count<T>(QueryState<T> state) {
    return state.count;
}

/// Returns the first-element option marker.
pub Query.Contracts.Option First<T>(QueryState<T> state, T sample) {
    if Query.Contracts.HasValue(state.first) {
        return Option::Some(1);
    }
    if state.count > 0 {
        if sample == sample {
            return Option::Some(1);
        }
    }
    return Option::None();
}

/// Collects state into an array-like count placeholder.
pub i64 CollectArray<T>(QueryState<T> state) {
    return state.count;
}
