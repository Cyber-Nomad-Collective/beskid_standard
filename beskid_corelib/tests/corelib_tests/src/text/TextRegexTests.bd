/// Core.Text.Regex combinator-backed match tests.
use Core.Text.Regex;
use Testing.Assert;

test lower_class_quantifier_matches_prefix {
    Assert.True(Regex.Matches("[a-z]+", "abc123"), "expected lower-class run");
}

test digit_class_finds_digits {
    Assert.True(Regex.Finds("[0-9]+", "x99y"), "expected digit run via find");
}

test alternation_group_matches_second_branch {
    Assert.True(Regex.Matches("(foo|bar)", "bar"), "expected alternation group");
}

test anchor_start_end_full_string {
    Assert.True(Regex.Matches("^abc$", "abc"), "expected anchored full match");
}

test word_escape_matches_identifier {
    Assert.True(Regex.Matches("\\w+", "Z9_"), "expected word escape");
}

test invalid_pattern_rejected {
    Assert.False(Regex.Matches("[unterminated", "abc"), "invalid pattern");
}

test find_all_collects_non_overlapping_runs {
    Assert.True(!Regex.IsFindAllEmpty(Regex.FindAll("[a-z]+", "a1bb2ccc")), "expected find-all matches");
}
