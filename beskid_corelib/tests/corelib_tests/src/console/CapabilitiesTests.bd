/// `Console.Capabilities` color/TTY policy helpers.
use Console.Capabilities;
use Console.Capabilities.ColorModel;

test should_strip_when_no_color_set {
    Capabilities caps = Capabilities {
        isTty: true,
        colorDisabled: true,
        colorForced: false,
        model: ColorModel::Indexed256(),
    };
    Testing.Assertions.AssertTrue(ShouldStripColor(caps), "NO_COLOR should force strip");
}

test should_strip_when_not_tty_and_not_forced {
    Capabilities caps = Capabilities {
        isTty: false,
        colorDisabled: false,
        colorForced: false,
        model: ColorModel::TrueColor(),
    };
    Testing.Assertions.AssertTrue(ShouldStripColor(caps), "non-TTY without FORCE_COLOR should strip");
}

test should_not_strip_when_force_color_on_pipe {
    Capabilities caps = Capabilities {
        isTty: false,
        colorDisabled: false,
        colorForced: true,
        model: ColorModel::Indexed256(),
    };
    Testing.Assertions.AssertFalse(ShouldStripColor(caps), "FORCE_COLOR should allow ANSI on non-TTY");
}

test probe_stdout_returns_capabilities_record {
    Capabilities caps = ProbeStdout();
    Testing.Assertions.AssertTrue(
        caps.isTty || !caps.isTty,
        "ProbeStdout should return a populated capabilities record"
    );
}

test should_style_matches_should_emit_ansi {
    bool style = Console.ShouldStyle();
    bool emit = ShouldEmitAnsi();
    Testing.Assertions.AssertTrue(style == emit, "ShouldStyle should mirror ShouldEmitAnsi");
}
