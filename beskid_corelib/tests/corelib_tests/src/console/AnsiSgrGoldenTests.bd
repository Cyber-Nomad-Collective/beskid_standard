/// Golden tests for SGR and OSC escape sequences (ungated CSI/OSC builders).

use Ansi.Escape;
use Ansi.Sgr;
use Ansi.StyleChain;
use Testing.Assert;


test ansi_bold_golden {
    string esc = Ansi.Escape.Esc();
    string prefix = Ansi.StyleChain.IntoPrefix(
        Ansi.StyleChain.Bold(Ansi.StyleChain.New())
    );
    Assert.Contains(prefix, "${esc}[1m", "bold SGR should contain [1m");
}

test ansi_fg256_golden {
    string prefix = Ansi.StyleChain.IntoPrefix(
        Ansi.StyleChain.Fg256(Ansi.StyleChain.New(), 196)
    );
    Assert.Contains(prefix, "38;5;196", "256-color fg should contain 38;5;196");
}

test ansi_sgr_bold_prefix_golden {
    string esc = Ansi.Escape.Esc();
    string prefix = Ansi.Sgr.IntoPrefix(Ansi.Sgr.Bold(Ansi.Sgr.Start()));
    string reset = Ansi.Escape.Csi("0", "m");
    Assert.Contains(prefix, "[1m", "Sgr bold prefix should contain [1m");
    Assert.Contains(reset, "${esc}[0m", "reset CSI should contain [0m");
}

test ansi_osc_title_golden {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.OscSequence("0;beskid");
    Assert.Contains(seq, "${esc}]0;beskid", "OSC title should contain ]0;beskid");
}

test ansi_osc_hyperlink_contains_uri {
    string open = Ansi.Escape.OscSequence("8;;https://beskid.dev");
    string close = Ansi.Escape.OscSequence("8;;");
    string linked = "${open}link${close}";
    Assert.Contains(linked, "8;;https://beskid.dev", "hyperlink open should embed uri");
    Assert.Contains(linked, "link", "hyperlink should preserve label");
}
