/// Standard input read helpers (stdin-only via syscall layer).
/// @ref(System.Syscall.ReadWith) syscall-backed read path.

use System.Syscall.SyscallError;
use System.Syscall.Descriptor;
use System.Syscall.StandardStream;
use System.Syscall.ReadLimit;
use System.Syscall.ReadRequest;

/// Reads up to the default byte limit from standard input.
/// @returns Payload string or a `SyscallError`.
pub Core.Results.Result<string, SyscallError> Read() {
    StandardStream stream = StandardStream::Stdin();
    Descriptor descriptor = Descriptor::Standard(stream);
    return System.Syscall.ReadWith(
        ReadRequest {
            descriptor: descriptor,
            limit: ReadLimit::Default()
        }
    );
}

/// Reads a single byte from stdin (bounded read of one code unit).
pub Core.Results.Result<string, SyscallError> ReadByte() {
    StandardStream stream = StandardStream::Stdin();
    Descriptor descriptor = Descriptor::Standard(stream);
    return System.Syscall.ReadWith(
        ReadRequest {
            descriptor: descriptor,
            limit: ReadLimit::UpTo(1)
        }
    );
}

/// Reads a line from standard input until `\n` or EOF (excludes the newline).
/// @returns Payload string or a `SyscallError`.
pub Core.Results.Result<string, SyscallError> ReadLine() {
    string line = "";
    bool done = false;
    while !done {
        Core.Results.Result<string, SyscallError> chunk = ReadByte();
        match chunk {
            Result::Ok(byte) => {
                if Core.String.IsEmpty(byte) {
                    done = true;
                } else {
                    if byte == "
" {
                        done = true;
                    } else {
                        line = line + byte;
                    }
                }
            },
            Result::Error(err) => {
                return Result::Error(err);
            },
        };
    }
    return Result::Ok(line);
}
