/// Markdown subset parsing for `Console.Format` (plain strip + styled smoke).

use Console.Capabilities;
use Console.Format;
use Testing.Assert;


test strip_bold_plain {
    string text = Console.Format.StripMarkup("**bold**");
    Assert.Equal(text, "bold", "strip bold");
}

test strip_italic_plain {
    string text = Console.Format.StripMarkup("*italic*");
    Assert.Equal(text, "italic", "strip italic");
}

test strip_underline_plain {
    string text = Console.Format.StripMarkup("__under__");
    Assert.Equal(text, "under", "strip underline");
}

test strip_strike_plain {
    string text = Console.Format.StripMarkup("~~x~~");
    Assert.Equal(text, "x", "strip strike");
}

test strip_link_plain {
    string text = Console.Format.StripMarkup("[label](https://example.com)");
    Assert.Equal(text, "label", "strip link");
}

test strip_attr_span_plain {
    string text = Console.Format.StripMarkup("&[fg=red](text)");
    Assert.Equal(text, "text", "strip attr span");
}

test strip_escape_star {
    string text = Console.Format.StripMarkup("\\*literal\\*");
    Assert.Equal(text, "*literal*", "strip escaped star");
}

test strip_nested_styles_plain {
    string text = Console.Format.StripMarkup("**b *i* b**");
    Assert.Equal(text, "b i b", "strip nested");
}

test format_plain_when_ansi_disabled_matches_strip {
    if !Console.Capabilities.ShouldEmitAnsi() {
        string stripped = Console.Format.StripMarkup("**x**");
        string formatted = Console.Format.Format("**x**");
        Assert.Equal(formatted, stripped, "Format should match StripMarkup when ANSI disabled");
    }
}

test format_bold_emits_sgr_when_ansi_enabled {
    if Console.Capabilities.ShouldEmitAnsi() {
        string text = Console.Format.Format("**z**");
        Assert.True(text != "z", "expected bold SGR when ANSI enabled");
        Assert.Contains(text, "[1m", "expected bold CSI in output");
    }
}

test format_link_plain_when_ansi_disabled {
    if !Console.Capabilities.ShouldEmitAnsi() {
        string text = Console.Format.Format("[go](https://x.test)");
        Assert.Equal(text, "go", "link should reduce to label when ANSI off");
    }
}

test strip_mixed_markdown {
    string text = Console.Format.StripMarkup("**a** and ~~b~~");
    Assert.Equal(text, "a and b", "mixed markup strip");
}
