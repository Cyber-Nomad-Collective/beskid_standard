/// Tier 2 (Supported) smoke for `Core.Time` UTC civil helpers.

use Testing.Assert;
use Core.Time.Date;


test time_date_struct_smoke {
    Date date = Date { year: 1970, month: 1, day: 1 };
    Assert.Equal(date.year, 1970, "year");
}

test time_parse_smoke {
    bool smoke = true;
    Assert.True(smoke, "Core.Time.ParseIso8601Date deferred until Core.Results parity lands");
}
