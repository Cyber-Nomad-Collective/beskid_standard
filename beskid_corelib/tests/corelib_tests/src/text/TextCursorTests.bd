/// Core.Text.Cursor combinator substrate tests.
use Core.Text.Cursor;
use Testing.Assert;

test from_starts_at_zero {
    Cursor.TextCursor c = Cursor.From("abc");
    Assert.Equal(Cursor.Position(c), 0, "initial position");
}

test advance_moves_position {
    Cursor.TextCursor c = Cursor.Advance(Cursor.From("abc"), 2);
    Assert.Equal(Cursor.Position(c), 2, "advanced position");
}

test starts_with_prefix {
    Assert.True(Cursor.StartsWith(Cursor.From("hello"), "hel"), "prefix match");
}

test remaining_after_advance {
    Cursor.TextCursor c = Cursor.Advance(Cursor.From("abcdef"), 2);
    string rest = Cursor.Remaining(c);
    Assert.Equal(rest, "cdef", "remaining slice");
}
