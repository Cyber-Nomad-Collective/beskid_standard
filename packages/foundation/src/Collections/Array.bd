/// Collections.Array hub — slice helpers and iterators.
/// @tier(standard)
pub mod Collections.Array.ArrayIter;

use Collections.Array.ArrayIter;

/// Allocates a zero-length array for generic element type `T` (v1 uses 8-byte slots).
/// @tier(standard)
pub T[] Empty<T>() {
    return __array_new(8, 0);
}

/// Returns array length (element count).
/// @tier(standard)
pub i64 Len<T>(T[] values) {
    return __array_len(values);
}

/// Returns true when the array carries no readable elements.
/// @tier(standard)
pub bool IsEmpty<T>(T[] values) {
    return __array_len(values) == 0;
}

/// Creates an iterator at the first element.
/// @tier(standard)
pub ArrayIter<T> Iterate<T>(T[] values) {
    return ArrayIter<T> { index: 0, length: Len<T>(values) };
}

/// Returns true when an iterator has remaining elements.
/// @tier(standard)
pub bool HasNext<T>(ArrayIter<T> it) {
    return it.index < it.length;
}

/// Advance an iterator one element.
/// @tier(standard)
pub ArrayIter<T> Advance<T>(ArrayIter<T> it) {
    return ArrayIter<T> { index: it.index + 1, length: it.length };
}

/// Returns the iterator's current zero-based index.
/// @tier(standard)
pub i64 Index<T>(ArrayIter<T> it) {
    return it.index;
}

/// Returns the element at the given zero-based index.
/// @tier(standard)
pub T Get<T>(T[] values, i64 index) {
    return values[index];
}

/// Sets the element at the given zero-based index and returns the array.
/// @tier(standard)
pub T[] Set<T>(T[] values, i64 index, T value) {
    values[index] = value;
    return values;
}

/// Ensures `values` has logical length at least `minLength` (copy-on-grow when needed).
/// @tier(standard)
pub T[] EnsureCapacity<T>(T[] values, i64 minLength) {
    i64 current = Len<T>(values);
    if current >= minLength {
        return values;
    }
    return __array_new(8, minLength);
}

/// Appends one element, growing storage when `count` exceeds current length.
/// @tier(standard)
pub T[] AppendAt<T>(T[] values, i64 count, T value) {
    T[] grown = EnsureCapacity<T>(values, count);
    return Set<T>(grown, count - 1, value);
}

/// Appends one element at the tail of `values`.
/// @tier(standard)
pub T[] Append<T>(T[] values, T value) {
    i64 next = Len<T>(values) + 1;
    return AppendAt<T>(values, next, value);
}

/// Copies `len` elements from `src` at `srcOff` into `dst` at `dstOff`.
/// @tier(standard)
pub unit CopyRange<T>(T[] dst, i64 dstOff, T[] src, i64 srcOff, i64 len) {
    mut i64 i = 0;
    while i < len {
        Set<T>(dst, dstOff + i, Get<T>(src, srcOff + i));
        i = i + 1;
    }
    return;
}
