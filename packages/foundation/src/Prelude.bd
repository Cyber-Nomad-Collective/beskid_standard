/// Foundation package prelude: core types, collections, query helpers, and testing contracts.
/// Re-exports result and error carrier types.
pub mod Core.Results;
/// Re-exports structured error metadata.
pub mod Core.ErrorHandling;
/// Re-exports string helper functions.
pub mod Core.String;
/// Re-exports byte buffer primitives.
pub mod Core.Bytes;
/// Re-exports byte buffer slice helpers.
pub mod Core.Bytes.Slice;
/// Re-exports byte buffer error variants.
pub mod Core.Bytes.Errors;
/// Re-exports encoding hub and algorithms.
pub mod Core.Encoding;
pub mod Core.Encoding.Utf8;
pub mod Core.Encoding.Hex;
pub mod Core.Encoding.Base64;
/// Re-exports assertion-related contracts.
pub mod Testing.Contracts;
/// Re-exports assertion helper functions.
pub mod Testing.Assertions;
/// Re-exports query operator state and combinators (imports `Query.Contracts` internally).
pub mod Query.Operators;
/// Re-exports query contracts (Option type).
pub mod Query.Contracts;
/// Re-exports query execution helpers.
pub mod Query.Execution;
/// Re-exports growable array surface.
pub mod Collections.Array;
/// Re-exports list surface.
pub mod Collections.List;
/// Re-exports associative map surface.
pub mod Collections.Map;
/// Re-exports queue surface.
pub mod Collections.Queue;
/// Re-exports set surface.
pub mod Collections.Set;
/// Re-exports stack surface.
pub mod Collections.Stack;
