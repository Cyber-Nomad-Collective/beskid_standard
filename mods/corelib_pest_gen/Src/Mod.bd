/// Mod AOT entry — SDK Collector + Generator for Pest grammar combinator emit.
use Beskid.Compiler.Collect;
use Beskid.Compiler.Emitter;
use Targets;
use Emit;

pub type PestCollector : Collector {
    CollectTargetSet Collect(CollectRequest request) {
        return CollectTargetSet { targetIds: Targets.GrammarTargetIds() };
    }
}

pub type PestGen : Generator {
    GeneratedSyntaxContribution Generate(GenerationRequest request) {
        return Emit.BuildAll();
    }
}
