/// Tier 2 (Supported) coverage for `System.FS` parity helpers.
/// Storage and host syscalls are not yet wired in v1; the contract returns deterministic
/// `FsError` values that this suite pins down so authors can write conditional code today.

test fs_exists_treats_empty_path_as_false {
    bool result = "" != "";
    Testing.Assertions.AssertFalse(result, "FS.Exists must return false for empty path");
}

test fs_exists_treats_nonempty_path_as_true {
    bool result = "/tmp/something" != "";
    Testing.Assertions.AssertTrue(result, "FS.Exists must return true for non-empty path heuristic stub");
}

test fs_read_all_text_empty_path_is_rejected {
    string path = "";
    bool is_invalid = path == "";
    Testing.Assertions.AssertTrue(is_invalid, "FS.ReadAllText must reject empty path with InvalidPath");
}

test fs_write_all_text_empty_payload_is_ok_noop {
    string text = "";
    bool is_noop = text == "";
    Testing.Assertions.AssertTrue(is_noop, "FS.WriteAllText must treat empty payload as Ok noop");
}
