/// Platform terminal probes and env size parsing.

test parse_env_columns_known_values {
    Testing.Assertions.AssertEqualI64(120, Platform.Terminal.ParseEnvColumns("120", 80), "expected 120 columns");
    Testing.Assertions.AssertEqualI64(
        80,
        Platform.Terminal.ParseEnvColumns("unknown", 80),
        "unknown columns should keep default"
    );
}

test parse_env_rows_known_values {
    Testing.Assertions.AssertEqualI64(40, Platform.Terminal.ParseEnvRows("40", 24), "expected 40 rows");
    Testing.Assertions.AssertEqualI64(24, Platform.Terminal.ParseEnvRows("", 24), "empty rows should keep default");
}

test query_size_returns_positive_dimensions {
    Console.ConsoleSize size = Platform.Terminal.QuerySize();
    Testing.Assertions.AssertTrue(size.columns >= 1, "terminal columns should be positive");
    Testing.Assertions.AssertTrue(size.rows >= 1, "terminal rows should be positive");
}

test env_fallback_size_defaults {
    Console.ConsoleSize size = Platform.Terminal.EnvFallbackSize();
    Testing.Assertions.AssertTrue(size.columns >= 80, "fallback columns should be at least 80");
    Testing.Assertions.AssertTrue(size.rows >= 24, "fallback rows should be at least 24");
}
