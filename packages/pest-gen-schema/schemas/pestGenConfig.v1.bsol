profile "pestGenConfig.v1" {
  rule "pestGenConfig" {
    scope = top
    match = keyword
    keyword = pestGenConfig
    label = forbidden
    cardinality = zero_or_one
    field "ruleCallablePrefix" { type = quoted required = false }
    field "emitUseTerms" { type = enum_or_quoted values = [true, false] required = false }
  }
}
