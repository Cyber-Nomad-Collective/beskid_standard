/// Console terminal events use `Channel<ConsoleMessage>` (M7).
use Console;
use Console.ConsoleMessage;
use Concurrency.Channel;

test messages_channel_factory {
    Channel<ConsoleMessage> messages = Console.MessagesChannel();
    Console.ConsoleSize size = Console.ConsoleSize { columns: 80, rows: 24 };
    Core.Results.Result<Concurrency.Channel.SendOk, Concurrency.ChannelError> sent =
        messages.Send(ConsoleMessage::Resize(size));
    match sent {
        Result::Ok(_) => {},
        Result::Error(_) => __panic_str("resize Send should succeed on open channel"),
    }
}
