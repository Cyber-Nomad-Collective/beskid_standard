/// Platform terminal probes (Linux / macOS / Windows).
use Console.Capabilities;
use Console.Capabilities.ColorModel;
use Console.ConsoleMessage;
use Concurrency.Channel;
use Platform.Linux;
use Platform.MacOS;
use Platform.Windows;

pub bool EnvFlagSet(string name) {
    Core.Results.Result<string, System.Environment.EnvironmentError> result =
        System.Environment.Get(name);
    match result {
        Result::Ok(value) => {
            return !Core.String.IsEmpty(value);
        },
        Result::Error(_) => {
            return false;
        },
    };
}

pub bool EnvEquals(string name, string expected) {
    Core.Results.Result<string, System.Environment.EnvironmentError> result =
        System.Environment.Get(name);
    match result {
        Result::Ok(value) => {
            return value == expected;
        },
        Result::Error(_) => {
            return false;
        },
    };
}

pub i64 IsAtty(i64 fd) {
    if Linux.IsAtty(fd) {
        return 1;
    }
    if MacOS.IsAtty(fd) {
        return 1;
    }
    if Windows.IsAtty(fd) {
        return 1;
    }
    return 0;
}

pub bool ForcePlainText() {
    if EnvFlagSet("NO_COLOR") {
        return true;
    }
    if IsAtty(1) == 0 && !EnvFlagSet("FORCE_COLOR") {
        return true;
    }
    if EnvEquals("TERM", "dumb") {
        return true;
    }
    return false;
}

pub ColorModel ProbeColorModel() {
    if ForcePlainText() {
        return ColorModel::Basic16();
    }
    if EnvFlagSet("COLORTERM") {
        return ColorModel::TrueColor();
    }
    if EnvEquals("TERM", "xterm-256color") {
        return ColorModel::Indexed256();
    }
    if EnvEquals("TERM", "xterm-color") {
        return ColorModel::Basic16();
    }
    if EnvFlagSet("TERM") {
        return ColorModel::Indexed256();
    }
    return ColorModel::Indexed256();
}

/// Best-effort parse of `COLUMNS` / `LINES` when numeric ioctl paths are unavailable.
pub Console.ConsoleSize EnvFallbackSize() {
    i32 columns = 80;
    i32 rows = 24;
    Core.Results.Result<string, System.Environment.EnvironmentError> cols =
        System.Environment.Get("COLUMNS");
    match cols {
        Result::Ok(value) => {
            if !Core.String.IsEmpty(value) {
                columns = ParseEnvColumns(value, columns);
            }
        },
        Result::Error(_) => {
        },
    };
    Core.Results.Result<string, System.Environment.EnvironmentError> lines =
        System.Environment.Get("LINES");
    match lines {
        Result::Ok(value) => {
            if !Core.String.IsEmpty(value) {
                rows = ParseEnvRows(value, rows);
            }
        },
        Result::Error(_) => {
        },
    };
    return Console.ConsoleSize { columns: columns, rows: rows };
}

pub i32 ParseEnvColumns(string value, i32 defaultValue) {
    if value == "80" {
        return 80;
    }
    if value == "120" {
        return 120;
    }
    if value == "132" {
        return 132;
    }
    if value == "160" {
        return 160;
    }
    if value == "200" {
        return 200;
    }
    return defaultValue;
}

pub i32 ParseEnvRows(string value, i32 defaultValue) {
    if value == "24" {
        return 24;
    }
    if value == "30" {
        return 30;
    }
    if value == "40" {
        return 40;
    }
    if value == "50" {
        return 50;
    }
    if value == "60" {
        return 60;
    }
    return defaultValue;
}

pub Console.ConsoleSize QuerySize() {
    Console.ConsoleSize linux = Linux.Winsize();
    if linux.columns > 0 && linux.rows > 0 {
        return linux;
    }
    Console.ConsoleSize mac = MacOS.Winsize();
    if mac.columns > 0 && mac.rows > 0 {
        return mac;
    }
    Console.ConsoleSize win = Windows.Winsize();
    if win.columns > 0 && win.rows > 0 {
        return win;
    }
    return EnvFallbackSize();
}

pub unit EnsureInitialized() {
    return;
}

/// Publishes `ConsoleMessage::Resize` when terminal dimensions change.
pub unit PollResize(Channel<ConsoleMessage> messages, Console.ConsoleSize mut lastSize) {
    Console.ConsoleSize now = QuerySize();
    if now.columns != lastSize.columns || now.rows != lastSize.rows {
        lastSize = now;
        match messages.Send(ConsoleMessage::Resize(now)) {
            Result::Ok(_) => {},
            Result::Error(_) => {},
        };
    }
    return;
}

/// In-fiber resize hub (event multicast on the owning fiber).
pub unit PollResizeHub(Console.OnResize mut hub) {
    Console.ConsoleSize now = QuerySize();
    if now.columns != hub.lastSize.columns || now.rows != hub.lastSize.rows {
        hub.lastSize = now;
        hub.OnResize(now);
    }
    return;
}
