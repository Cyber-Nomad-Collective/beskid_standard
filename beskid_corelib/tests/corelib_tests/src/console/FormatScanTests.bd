/// Markup scanner helpers (`Console.Format.Scan`).

test slice_returns_substring {
    string part = Console.Format.Scan.Slice("abcdef", 2, 3);
    Testing.Assert.Equal(part, "cde", "Slice middle segment");
}

test index_of_finds_needle {
    i64 idx = Console.Format.Scan.IndexOfFrom("foo-bar", 0, "bar");
    Testing.Assert.Equal(idx, 4, "IndexOfFrom bar");
}

test trim_strips_spaces {
    string t = Console.Format.Scan.Trim("  hi  ");
    Testing.Assert.Equal(t, "hi", "Trim spaces");
}

test starts_with_prefix {
    Testing.Assert.True(Console.Format.Scan.StartsWith("&[fg=", "&["), "StartsWith attr opener");
}

test contains_substring {
    Testing.Assert.True(Console.Format.Scan.ContainsSubstring("abc[1m", "[1m"), "ContainsSubstring CSI");
}
