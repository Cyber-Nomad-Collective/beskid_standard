/// Attribute span color parsing for `Console.Format.Attributes`.

test parse_named_red {
    Console.Format.Attributes.ParsedRgb rgb = Console.Format.Attributes.ParseColor("red");
    Testing.Assertions.AssertTrue(rgb.ok && rgb.r == 205, "named red");
}

test parse_hex_six_digits {
    Console.Format.Attributes.ParsedRgb rgb = Console.Format.Attributes.ParseColor("#ff0000");
    Testing.Assertions.AssertTrue(
        rgb.ok && rgb.r == 255 && rgb.g == 0 && rgb.b == 0,
        "hex #ff0000"
    );
}

test parse_rgb_triplet {
    Console.Format.Attributes.ParsedRgb rgb = Console.Format.Attributes.ParseColor("rgb(10,20,30)");
    Testing.Assertions.AssertTrue(
        rgb.ok && rgb.r == 10 && rgb.g == 20 && rgb.b == 30,
        "rgb(10,20,30)"
    );
}

test apply_attr_list_fg_and_bg {
    Ansi.StyleChain chain = Console.Format.Attributes.ApplyAttrList(
        Ansi.StyleChain.New(),
        "fg=red, bg=blue"
    );
    string prefix = Ansi.StyleChain.IntoPrefix(chain);
    if Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertContains(prefix, "38;", "fg attr should emit foreground CSI");
        Testing.Assertions.AssertContains(prefix, "48;", "bg attr should emit background CSI");
    }
}

test format_attr_span_plain_strip {
    string text = Console.Format.StripMarkup("&[fg=red, bg=blue](hi)");
    Testing.Assertions.AssertEqualString("hi", text, "attr span strip");
}

test format_attr_span_styled_when_enabled {
    if Console.Capabilities.ShouldEmitAnsi() {
        string text = Console.Format.Format("&[fg=red](x)");
        Testing.Assertions.AssertTrue(text != "x", "attr span should apply color when ANSI enabled");
    }
}
