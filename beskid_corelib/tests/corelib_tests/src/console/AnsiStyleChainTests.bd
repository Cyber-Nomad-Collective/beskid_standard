/// Golden prefix sequences for `Ansi.StyleChain` and `Ansi.Sgr` (ungated CSI builders).

use Ansi.Escape;
use Ansi.Sgr;
use Ansi.StyleChain;
use Testing.Assert;


test style_chain_bold_wraps {
    string esc = Ansi.Escape.Esc();
    string prefix = Ansi.StyleChain.IntoPrefix(
        Ansi.StyleChain.Bold(Ansi.StyleChain.New())
    );
    string expected = "${esc}[1m";
    Assert.Equal(prefix, expected, "bold style-chain prefix");
}

test style_chain_inverse_prefix {
    string esc = Ansi.Escape.Esc();
    string prefix = Ansi.StyleChain.IntoPrefix(
        Ansi.StyleChain.Inverse(Ansi.StyleChain.New())
    );
    Assert.Contains(prefix, "${esc}[7m", "inverse SGR should contain [7m");
}

test sgr_builder_fg_basic_golden {
    string esc = Ansi.Escape.Esc();
    string prefix = Ansi.Sgr.IntoPrefix(
        Ansi.Sgr.FgBasic(Ansi.Sgr.Start(), 31)
    );
    Assert.Contains(prefix, "${esc}[31m", "basic red fg should contain [31m");
}
