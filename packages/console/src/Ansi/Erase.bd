/// Fluent erase builder implementing `Ansi.Contracts.AnsiEraseStep` shapes.
use Ansi.Escape;

pub type EraseBuilder {
    string parts,
}

pub EraseBuilder Start() {
    return EraseBuilder { parts: "" };
}

pub EraseBuilder DisplayFromCursor(EraseBuilder self) {
    return Append(self, Escape.Csi("0", "J"));
}

pub EraseBuilder DisplayToCursor(EraseBuilder self) {
    return Append(self, Escape.Csi("1", "J"));
}

pub EraseBuilder DisplayAll(EraseBuilder self) {
    return Append(self, Escape.Csi("2", "J"));
}

pub EraseBuilder DisplaySaved(EraseBuilder self) {
    return Append(self, Escape.Csi("3", "J"));
}

pub EraseBuilder LineFromCursor(EraseBuilder self) {
    return Append(self, Escape.Csi("0", "K"));
}

pub EraseBuilder LineToCursor(EraseBuilder self) {
    return Append(self, Escape.Csi("1", "K"));
}

pub EraseBuilder LineAll(EraseBuilder self) {
    return Append(self, Escape.Csi("2", "K"));
}

pub string IntoSequence(EraseBuilder self) {
    return Escape.WhenEnabled(self.parts);
}

pub EraseBuilder Append(EraseBuilder self, string fragment) {
    return EraseBuilder { parts: "${self.parts}${fragment}" };
}
