/// Syscall write smoke tests via `Core.Syscall` facade.

use Testing.Assert;
use Core.Syscall;
use Core.Results;


test syscall_write_empty_string_returns_non_negative {
    Core.Results.Result<i64, Core.Syscall.SyscallError> result =
        Core.Syscall.Write(Core.Syscall.StdoutFd(), "");
    Assert.True(Results.IsOk(result), "empty Write should succeed");
    match result {
        Result::Ok(written) => {
            Assert.True(written >= 0, "empty write byte count should be non-negative");
        },
        Result::Error(_) => {},
    };
}

test syscall_write_stdout_smoke {
    Core.Results.Result<i64, Core.Syscall.SyscallError> result =
        Core.Syscall.Write(Core.Syscall.StdoutFd(), "corelib");
    Assert.True(Results.IsOk(result), "stdout Write should succeed");
    match result {
        Result::Ok(written) => {
            Assert.True(written >= 1, "non-empty write should return at least one byte");
        },
        Result::Error(_) => {},
    };
}

test syscall_write_prints_newline {
    Core.Results.Result<i64, Core.Syscall.SyscallError> letter =
        Core.Syscall.Write(Core.Syscall.StdoutFd(), "a");
    Core.Results.Result<i64, Core.Syscall.SyscallError> newline =
        Core.Syscall.Write(Core.Syscall.StdoutFd(), "
");
    Assert.True(Results.IsOk(letter), "letter write should succeed");
    Assert.True(Results.IsOk(newline), "newline write should succeed");
    match letter {
        Result::Ok(written) => {
            Assert.True(written >= 1, "expected one byte for letter a");
        },
        Result::Error(_) => {},
    };
    match newline {
        Result::Ok(written) => {
            Assert.True(written >= 1, "expected one byte for newline");
        },
        Result::Error(_) => {},
    };
}
