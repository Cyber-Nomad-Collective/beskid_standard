/// macOS terminal probes via libc Extern (`isatty`, best-effort `ioctl` winsize).
[Extern(Abi:"C", Library:"libc")]
pub contract Libc {
    i32 isatty(i32 fd);
    /// `TIOCGWINSZ` (0x40087468 on macOS); `arg` is `struct winsize*` when host linking is enabled.
    i32 ioctl(i32 fd, i64 request, i64 arg);
}

pub type WinSize {
    i32 ws_row,
    i32 ws_col,
    i32 ws_xpixel,
    i32 ws_ypixel,
}

pub bool IsAtty(i64 fd) {
    if fd < 0 {
        return false;
    }
    if fd > 2147483647 {
        return false;
    }
    return Libc.isatty(fd as i32) == 1;
}

pub Console.ConsoleSize Winsize() {
    if !IsAtty(1) {
        return Console.ConsoleSize { columns: 0, rows: 0 };
    }
    i64 request = 1074295912;
    i64 arg = 0;
    i32 rc = Libc.ioctl(1, request, arg);
    if rc != 0 {
        return Console.ConsoleSize { columns: 0, rows: 0 };
    }
    return Console.ConsoleSize { columns: 0, rows: 0 };
}
