/// Markup formatter: `**bold**`, `*italic*`, `__underline__`, `~~strike~~`, links, `&[fg=…](…)`.
use Console.Capabilities;
use Console.Format.Markdown;

/// Renders markup to a styled string (plain text when ANSI disabled).
/// @arg(source) Markup input.
pub string Format(string source) {
    if !Console.Capabilities.ShouldEmitAnsi() {
        return StripMarkup(source);
    }
    return Markdown.RenderStyled(source);
}

/// Strips markup delimiters and emits visible text only.
/// @arg(source) Markup input.
pub string StripMarkup(string source) {
    return Markdown.RenderPlain(source);
}
