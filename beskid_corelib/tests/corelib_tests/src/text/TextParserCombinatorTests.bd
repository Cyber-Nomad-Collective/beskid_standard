/// Combinator smoke over Core.Text.Parser (PascalCase surface).

use Core.Text.Cursor;
use Core.Text.Parser;
use Testing.Assert;


test literal_matches_prefix {
    Cursor.TextCursor c = Cursor.From("hello");
    Parser.TextParseResult<string> parsed = Parser.Literal(c, "hel", "literal");
    Assert.True(Parser.IsOk(parsed), "literal prefix should succeed");
    Cursor.TextCursor rest = Parser.RestOnOk(parsed, c);
    Assert.Equal(Cursor.Position(rest), 3, "literal advances cursor");
}

test choice2_tries_second_branch {
    Cursor.TextCursor c = Cursor.From("b");
    Parser.TextParseResult<string> first = Parser.Literal(c, "a", "pick");
    Parser.TextParseResult<string> second = Parser.Literal(c, "b", "pick");
    Parser.TextParseResult<string> picked = Parser.Choice2(c, "pick", first, second);
    Assert.True(Parser.IsOk(picked), "Choice2 should take second branch");
}

test satisfy_reads_one_code_unit {
    Cursor.TextCursor c = Cursor.From("x");
    Parser.TextParseResult<string> parsed = Parser.Satisfy(c, "any");
    Assert.True(Parser.IsOk(parsed), "Satisfy should read one unit");
}
