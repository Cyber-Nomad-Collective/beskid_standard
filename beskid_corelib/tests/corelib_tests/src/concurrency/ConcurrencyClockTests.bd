/// Scheduler clock and yield wrappers.

use Concurrency;
use Testing.Assert;


test now_millis_non_negative {
    i64 now = Concurrency.NowMillis();
    Assert.True(now >= 0, "NowMillis should be non-negative");
}

test processor_count_positive {
    i64 count = Concurrency.ProcessorCount();
    Assert.True(count >= 1, "ProcessorCount should be at least 1");
}

test yield_invokes_builtin {
    Concurrency.Yield();
    return;
}
