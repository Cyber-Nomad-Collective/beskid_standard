/// Channel wrapper surface (requires `__channel_*` builtins and runtime M1).

test channel_create_unbounded_default {
    Concurrency.Channel<i64> ch = Concurrency.Channel<i64>.Create();
    Core.Results.Result<Concurrency.Channel.SendOk, Concurrency.ChannelError> sent = ch.Send(42);
    Testing.Assertions.AssertTrue(
        Core.Results.IsOk(sent),
        "Send should succeed on open channel"
    );
    Core.Results.Result<i64, Concurrency.ChannelError> received = ch.Receive();
    match received {
        Result::Ok(value) => {
            Testing.Assertions.AssertEqualI64(42, value, "Receive value mismatch");
        },
        Result::Error(_) => {
            Testing.Assertions.Fail("Receive should succeed");
        }
    };
}

test channel_bounded_options_factory {
    Concurrency.ChannelOptions options = Concurrency.ChannelOptions.Bounded(4);
    Concurrency.Channel<i64> ch = Concurrency.Channel<i64>.CreateWithOptions(options);
    Core.Results.Result<Concurrency.Channel.SendOk, Concurrency.ChannelError> sent = ch.Send(1);
    Testing.Assertions.AssertTrue(
        Core.Results.IsOk(sent),
        "bounded channel Send should succeed"
    );
}

test channel_single_reader_writer_factories {
    Concurrency.Channel<i64> readers = Concurrency.Channel<i64>.CreateWithOptions(Concurrency.ChannelOptions.SingleReader());
    Concurrency.Channel<i64> writers = Concurrency.Channel<i64>.CreateWithOptions(Concurrency.ChannelOptions.SingleWriter());
    Testing.Assertions.AssertTrue(
        Core.Results.IsOk(readers.Send(1)),
        "single-reader channel Send should succeed"
    );
    Testing.Assertions.AssertTrue(
        Core.Results.IsOk(writers.Send(2)),
        "single-writer channel Send should succeed"
    );
}

test channel_try_receive_empty_returns_none {
    Concurrency.Channel<i64> ch = Concurrency.Channel<i64>.Create();
    Query.Contracts.Option<i64> got = ch.TryReceive();
    match got {
        Option::None => {},
        Option::Some(_) => {
            Testing.Assertions.Fail("TryReceive on empty channel should be None");
        }
    };
}

test channel_close_drains_then_reports_closed {
    Concurrency.Channel<i64> ch = Concurrency.Channel<i64>.CreateWithOptions(Concurrency.ChannelOptions.Bounded(1));
    Testing.Assertions.AssertTrue(
        Core.Results.IsOk(ch.Send(7)),
        "bounded channel initial Send should succeed"
    );
    ch.Close();

    Core.Results.Result<i64, Concurrency.ChannelError> drained = ch.Receive();
    match drained {
        Result::Ok(value) => {
            Testing.Assertions.AssertEqualI64(7, value, "closed channel should drain queued value");
        },
        Result::Error(_) => {
            Testing.Assertions.Fail("closed channel should drain before reporting closed");
        }
    };

    Core.Results.Result<i64, Concurrency.ChannelError> closed = ch.Receive();
    Testing.Assertions.AssertTrue(
        Core.Results.IsError(closed),
        "closed drained channel should report an error"
    );
    Testing.Assertions.AssertTrue(
        Core.Results.IsError(ch.Send(8)),
        "send after close should report an error"
    );
}
