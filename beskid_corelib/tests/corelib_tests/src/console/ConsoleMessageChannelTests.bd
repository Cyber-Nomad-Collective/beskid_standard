/// Console terminal events use `Channel<ConsoleMessage>` (M7).
use Console;
use Console.ConsoleMessage;
use Concurrency.Channel;

test messages_channel_factory {
    Channel<ConsoleMessage> messages = Console.MessagesChannel();
    Console.ConsoleSize size = Console.ConsoleSize { columns: 80, rows: 24 };
    Core.Results.Result<Concurrency.Channel.SendOk, Concurrency.ChannelError> sent =
        messages.Send(ConsoleMessage::Resize(size));
    Testing.Assertions.AssertTrue(
        Core.Results.IsOk(sent),
        "resize Send should succeed on open channel"
    );
}

test messages_channel_accepts_tick {
    Channel<ConsoleMessage> messages = Console.MessagesChannel();
    Core.Results.Result<Concurrency.Channel.SendOk, Concurrency.ChannelError> sent =
        messages.Send(ConsoleMessage::Tick());
    Testing.Assertions.AssertTrue(
        Core.Results.IsOk(sent),
        "Tick Send should succeed on open channel"
    );
}

test poll_resize_does_not_fail {
    Channel<ConsoleMessage> messages = Console.MessagesChannel();
    Console.ConsoleSize last = Console.QuerySize();
    Platform.Terminal.PollResize(messages, last);
}

test resize_and_tick_variants_constructible {
    Console.ConsoleSize size = Console.ConsoleSize { columns: 100, rows: 50 };
    ConsoleMessage resize = ConsoleMessage::Resize(size);
    ConsoleMessage tick = ConsoleMessage::Tick();
    Testing.Assertions.AssertTrue(true, "console message variants constructible");
}
