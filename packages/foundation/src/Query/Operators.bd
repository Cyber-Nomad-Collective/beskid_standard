/// Query combinators over iterator-backed `QueryState`.
/// @tier(supported)
use Collections.Array;
use Core.Optional.Option;
use Query.QueryState;

/// Builds query state from a source array.
/// @tier(supported)
pub QueryState<T> FromArray<T>(T[] source) {
    i64 length = Array.Len<T>(source);
    Option<T> first = Option::None();
    if length > 0 {
        first = Option::Some(Array.Get<T>(source, 0));
    }
    return QueryState<T> {
        source: source,
        index: 0,
        length: length,
        first: first,
    };
}

/// Filters elements using a predicate evaluated at the current index.
/// @tier(supported)
pub QueryState<T> Where<T>(QueryState<T> state, bool predicate) {
    if !predicate {
        return QueryState<T> {
            source: state.source,
            index: state.length,
            length: state.length,
            first: Option::None(),
        };
    }
    return state;
}

/// Projects the current element into `TOut` for downstream pipelines.
/// @tier(supported)
pub QueryState<TOut> Select<TIn, TOut>(QueryState<TIn> state, TOut sample) {
    if state.index >= state.length {
        return QueryState<TOut> {
            source: Array.Empty<TOut>(),
            index: 0,
            length: 0,
            first: Option::None(),
        };
    }
    return QueryState<TOut> {
        source: Array.Empty<TOut>(),
        index: 0,
        length: state.length - state.index,
        first: Option::Some(sample),
    };
}

/// Limits remaining elements to at most `count`.
/// @tier(supported)
pub QueryState<T> Take<T>(QueryState<T> state, i64 count) {
    if count < 1 {
        return QueryState<T> {
            source: state.source,
            index: state.length,
            length: state.length,
            first: Option::None(),
        };
    }
    i64 remaining = state.length - state.index;
    if count < remaining {
        remaining = count;
    }
    return QueryState<T> {
        source: state.source,
        index: state.index,
        length: state.index + remaining,
        first: state.first,
    };
}

/// Skips up to `count` elements from the logical front.
/// @tier(supported)
pub QueryState<T> Skip<T>(QueryState<T> state, i64 count) {
    if count < 1 {
        return state;
    }
    i64 nextIndex = state.index + count;
    if nextIndex > state.length {
        nextIndex = state.length;
    }
    Option<T> first = Option::None();
    if nextIndex < state.length {
        first = Option::Some(Array.Get<T>(state.source, nextIndex));
    }
    return QueryState<T> {
        source: state.source,
        index: nextIndex,
        length: state.length,
        first: first,
    };
}

/// Returns remaining logical element count.
/// @tier(supported)
pub i64 Count<T>(QueryState<T> state) {
    if state.index >= state.length {
        return 0;
    }
    return state.length - state.index;
}

/// Returns the optional first element for the current window.
/// @tier(supported)
pub Option<T> First<T>(QueryState<T> state) {
    return state.first;
}

/// Materializes the remaining window into a new array.
/// @tier(supported)
pub T[] ToList<T>(QueryState<T> state) {
    i64 remaining = Count<T>(state);
    if remaining < 1 {
        return Array.Empty<T>();
    }
    mut T[] result = Array.EnsureCapacity<T>(Array.Empty<T>(), remaining);
    mut i64 outIndex = 0;
    mut i64 srcIndex = state.index;
    while outIndex < remaining {
        result = Array.Set<T>(result, outIndex, Array.Get<T>(state.source, srcIndex));
        outIndex = outIndex + 1;
        srcIndex = srcIndex + 1;
    }
    return result;
}

/// Returns true when any element in the remaining window equals `value`.
/// @tier(supported)
pub bool Any<T>(QueryState<T> state, T value) {
    mut i64 i = state.index;
    while i < state.length {
        if Array.Get<T>(state.source, i) == value {
            return true;
        }
        i = i + 1;
    }
    return false;
}

/// Returns true when every element in the window equals `value` (empty window returns true).
/// @tier(supported)
pub bool All<T>(QueryState<T> state, T value) {
    if state.index >= state.length {
        return true;
    }
    mut i64 i = state.index;
    while i < state.length {
        if Array.Get<T>(state.source, i) != value {
            return false;
        }
        i = i + 1;
    }
    return true;
}

/// Sorts the remaining window ascending or descending (v1: `i64` elements).
/// @tier(supported)
pub QueryState<i64> OrderBy(QueryState<i64> state, bool ascending) {
    i64[] materialized = ToList<i64>(state);
    i64 n = Array.Len<i64>(materialized);
    if n < 2 {
        return FromArray<i64>(materialized);
    }
    mut i64[] sorted = Array.EnsureCapacity<i64>(Array.Empty<i64>(), n);
    mut i64 copyIndex = 0;
    while copyIndex < n {
        sorted = Array.Set<i64>(sorted, copyIndex, Array.Get<i64>(materialized, copyIndex));
        copyIndex = copyIndex + 1;
    }
    mut i64 outer = 0;
    while outer < n {
        mut i64 inner = 0;
        while inner + 1 < n - outer {
            i64 left = Array.Get<i64>(sorted, inner);
            i64 right = Array.Get<i64>(sorted, inner + 1);
            bool shouldSwap = false;
            if ascending && left > right {
                shouldSwap = true;
            }
            if !ascending && left < right {
                shouldSwap = true;
            }
            if shouldSwap {
                sorted = Array.Set<i64>(sorted, inner, right);
                sorted = Array.Set<i64>(sorted, inner + 1, left);
            }
            inner = inner + 1;
        }
        outer = outer + 1;
    }
    return FromArray<i64>(sorted);
}

/// Returns materialized element count for the remaining window.
/// @tier(supported)
pub i64 CollectArray<T>(QueryState<T> state) {
    return Array.Len<T>(ToList<T>(state));
}
