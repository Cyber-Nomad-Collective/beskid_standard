/// Allocates a zero-filled byte buffer with `len` elements.
/// @tier(standard)
/// @returns `u8[]` via `__array_new(1, len)`.
pub u8[] New(i64 len) {
    if len < 0 {
        return __array_new(1, 0);
    }
    return __array_new(1, len);
}

/// Returns element count of a byte buffer.
pub i64 Len(u8[] handle) {
    return __array_len(handle);
}

pub bool IsEmpty(u8[] handle) {
    return Len(handle) == 0;
}

/// Returns the byte at `index`.
pub u8 Get(u8[] handle, i64 index) {
    return handle[index];
}

pub u8[] Set(u8[] handle, i64 index, u8 value) {
    handle[index] = value;
    return handle;
}

pub unit Copy(u8[] dst, i64 dstOff, u8[] src, i64 srcOff, i64 len) {
    __bytes_copy(dst, dstOff, src, srcOff, len);
    return;
}

pub i64 Compare(u8[] left, u8[] right) {
    return __bytes_compare(left, right);
}

pub u8[] Fill(u8[] handle, i64 offset, i64 len, u8 value) {
    mut i64 i = 0;
    while i < len {
        Set(handle, offset + i, value);
        i = i + 1;
    }
    return handle;
}

pub u8[] SubSlice(u8[] handle, i64 offset, i64 count) {
    i64 total = Len(handle);
    if offset < 0 {
        offset = 0;
    }
    if count < 0 {
        count = 0;
    }
    if offset > total {
        return New(0);
    }
    i64 available = total - offset;
    if count > available {
        count = available;
    }
    u8[] buf = New(count);
    if count > 0 {
        Copy(buf, 0, handle, offset, count);
    }
    return buf;
}
