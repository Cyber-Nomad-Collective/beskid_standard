/// Core library prelude: modules re-exported for dependents.
///
/// Status: partial — surface grows as modules gain implementations.

pub mod Core.Results;
pub mod Core.ErrorHandling;
pub mod Core.String;
pub mod Testing.Contracts;
pub mod Testing.Assertions;

pub mod System.Syscall;
pub mod System.IO;

test syscall_write_empty_string_returns_non_negative {
    i64 n = __syscall_write(1, "");
    i64 zero = 0;
    if n < zero {
        __panic_str("empty syscall_write should not return negative");
    }
}

test syscall_write_stdout_smoke {
    i64 n = __syscall_write(1, "corelib");
    i64 threshold = 1;
    if n < threshold {
        __panic_str("syscall_write should return at least one byte for non-empty string");
    }
}

test syscall_write_prints_newline {
    i64 threshold = 1;
    i64 a = __syscall_write(1, "a");
    i64 b = __syscall_write(1, "
");
    if a < threshold {
        __panic_str("expected one byte for letter a");
    }
    if b < threshold {
        __panic_str("expected one byte for newline");
    }
}
