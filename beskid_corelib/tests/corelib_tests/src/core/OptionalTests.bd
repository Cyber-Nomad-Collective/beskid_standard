/// Coverage for `Core.Optional` helpers.

use Core.Optional;
use Testing.Assert;


test option_has_value_reports_some_and_none {
    Option<i64> present = Option::Some(7);
    Option<i64> absent = Option::None();
    Assert.True(HasValue(present), "Some should report HasValue");
    Assert.False(HasValue(absent), "None should not report HasValue");
}

test option_unwrap_or_returns_payload_or_default {
    Option<i64> present = Option::Some(3);
    Option<i64> absent = Option::None();
    Assert.Equal(UnwrapOr(present, 99), 3, "UnwrapOr should return Some payload");
    Assert.Equal(UnwrapOr(absent, 99), 99, "UnwrapOr should return default for None");
}
