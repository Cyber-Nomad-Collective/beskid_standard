/// High-level stdout output. `Print` writes raw UTF-8; `PrintLine` appends a newline using only `System.Syscall.Write`.
///
/// Status: implemented

pub unit Print(string text) {
    System.Syscall.Write(System.Syscall.StdoutFd(), text);
}

pub unit PrintLine(string text) {
    Print(text);
    System.Syscall.Write(System.Syscall.StdoutFd(), "
");
}
