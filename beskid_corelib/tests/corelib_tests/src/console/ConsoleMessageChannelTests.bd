/// Console terminal events smoke for `Channel<ConsoleMessage>`.

use Concurrency.Channel;
use Console;
use Console.ConsoleMessage;
use Testing.Assert;


test messages_channel_factory_smoke {
    Concurrency.Channel<ConsoleMessage> messages = Console.MessagesChannel();
    Assert.True(true, "MessagesChannel factory smoke");
}

test messages_channel_send_smoke {
    bool smoke = true;
    Assert.True(smoke, "Channel Send deferred until Core.Results parity lands");
}

test poll_resize_does_not_fail {
    bool smoke = true;
    Assert.True(smoke, "PollResize API import smoke");
}

test resize_and_tick_variants_smoke {
    bool smoke = true;
    Assert.True(smoke, "ConsoleMessage variants deferred until ConsoleSize parity lands");
}
