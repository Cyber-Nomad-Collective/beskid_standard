/// Parse/analyze smoke for Mod SDK workspace/catalog surfaces via aggregate corelib.

use Beskid.Compiler.ModCatalog;
use Beskid.Compiler.ModPackage;
use Beskid.Compiler.Workspace;
use Collections.Array;
use Testing.Assert;


test workspace_facade_version_is_stable {
    Assert.Equal(WorkspaceFacadeVersion(), "0.1.0", "Workspace SDK facade version");
}

test catalog_facade_version_is_stable {
    Assert.Equal(ModCatalogFacadeVersion(), "0.1.0", "ModCatalog SDK facade version");
}

test package_facade_version_is_stable {
    Assert.Equal(ModPackageFacadeVersion(), "0.1.0", "ModPackage SDK facade version");
}

test workspace_member_fields_are_constructible {
    WorkspaceMember member = WorkspaceMember {
        memberId: "member-a",
        projectName: "demo",
        projectRoot: "/tmp/demo",
        sourceRoot: "/tmp/demo/src",
    };
    Assert.Equal(member.projectName, "demo", "WorkspaceMember project name");
}

test catalog_packages_array_is_constructible {
    ModPackage[] packages = Array.Empty<ModPackage>();
    ModCatalog catalog = ModCatalog { packages: packages };
    Assert.Equal(Array.Len<ModPackage>(catalog.packages), 0, "empty ModCatalog packages");
}

test workspace_summary_fields_are_constructible {
    Workspace workspace = Workspace {
        rootPath: "/tmp/ws",
        members: Array.Empty<WorkspaceMember>(),
        lockHash: "lock-1",
    };
    Assert.Equal(workspace.lockHash, "lock-1", "Workspace lock hash");
}
