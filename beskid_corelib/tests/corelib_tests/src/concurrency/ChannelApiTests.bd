/// Channel wrapper surface (language-owned `__channel_*` dispatch; ABI v4 std profile).
use Concurrency.Channel;
use Concurrency.ChannelError;
use Concurrency.ChannelOptions;
use Core.Results;
use Testing.Assert;

test channel_create_unbounded_default {
    Channel<i64> ch = Channel<i64>.Create();
    Testing.Assert.True(
        Core.Results.IsOk(ch.Send(42)),
        "Send should succeed on open channel"
    );
    Core.Results.Result<i64, ChannelError> received = ch.Receive();
    match received {
        Result::Ok(value) => {
            Testing.Assert.Equal(value, 42, "Receive value mismatch");
        },
        Result::Error(_) => {
            Testing.Assert.Fail("Receive should succeed");
        }
    };
}

test channel_bounded_options_factory {
    ChannelOptions options = ChannelOptions.Bounded(4);
    Channel<i64> ch = Channel<i64>.CreateWithOptions(options);
    Testing.Assert.True(
        Core.Results.IsOk(ch.Send(1)),
        "bounded channel Send should succeed"
    );
}

test channel_single_reader_writer_factories {
    Channel<i64> readers = Channel<i64>.CreateWithOptions(ChannelOptions.SingleReader());
    Channel<i64> writers = Channel<i64>.CreateWithOptions(ChannelOptions.SingleWriter());
    Testing.Assert.True(
        Core.Results.IsOk(readers.Send(1)),
        "single-reader channel Send should succeed"
    );
    Testing.Assert.True(
        Core.Results.IsOk(writers.Send(2)),
        "single-writer channel Send should succeed"
    );
}

test channel_close_drains_then_reports_closed {
    Channel<i64> ch = Channel<i64>.CreateWithOptions(ChannelOptions.Bounded(1));
    Testing.Assert.True(
        Core.Results.IsOk(ch.Send(7)),
        "bounded channel initial Send should succeed"
    );
    ch.Close();

    Core.Results.Result<i64, ChannelError> drained = ch.Receive();
    match drained {
        Result::Ok(value) => {
            Testing.Assert.Equal(value, 7, "closed channel should drain queued value");
        },
        Result::Error(_) => {
            Testing.Assert.Fail("closed channel should drain before reporting closed");
        }
    };

    Core.Results.Result<i64, ChannelError> closed = ch.Receive();
    Testing.Assert.True(
        Core.Results.IsError(closed),
        "closed drained channel should report an error"
    );
    Testing.Assert.True(
        Core.Results.IsError(ch.Send(8)),
        "send after close should report an error"
    );
}
