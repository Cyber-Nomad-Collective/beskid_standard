/// Growable list surface and placeholder operations.
pub type List<T> {
    /// Number of logical elements.
    i64 count,
}

/// Creates an empty list.
pub List<T> New<T>() {
    return List<T> { count: 0 };
}

/// Returns the logical element count.
pub i64 Count<T>(List<T> list) {
    return list.count;
}

/// Returns an indexed element or an error.
pub Core.Results.Result<T, string> Get<T>(List<T> list, i64 index) {
    if index < 0 {
        return Result::Error("index out of range");
    }
    if list.count > index {
        return Result::Error("list storage is not implemented");
    }
    return Result::Error("index out of range");
}
