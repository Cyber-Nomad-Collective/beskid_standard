/// Time types for durations and instants (stubs).
///
/// Status: stub

pub type Instant {
    i64 ticks,
}

pub type Duration {
    i64 milliseconds,
}

pub Instant NowUtc() {
    return Instant { ticks: 0 };
}

pub Instant MonotonicNow() {
    return Instant { ticks: 0 };
}

pub Duration FromMilliseconds(i64 ms) {
    return Duration { milliseconds: ms };
}
