/// ABI contract for `Concurrency.Status` i64 constants used by channel/hub/mutex builtins.

use Concurrency.Status;
use Testing.Assert;


test status_ok_is_zero {
    Assert.Equal(Status.Ok(), 0, "Status.Ok ABI");
}

test status_closed_is_one {
    Assert.Equal(Status.Closed(), 1, "Status.Closed ABI");
}

test status_cancelled_is_two {
    Assert.Equal(Status.Cancelled(), 2, "Status.Cancelled ABI");
}

test status_would_block_is_three {
    Assert.Equal(Status.WouldBlock(), 3, "Status.WouldBlock ABI");
}

test status_hub_empty_is_four {
    Assert.Equal(Status.HubEmpty(), 4, "Status.HubEmpty ABI");
}

test status_hub_limit_is_five {
    Assert.Equal(Status.HubLimit(), 5, "Status.HubLimit ABI");
}

test status_hub_not_found_is_six {
    Assert.Equal(Status.HubNotFound(), 6, "Status.HubNotFound ABI");
}

test status_mutex_busy_aliases_closed {
    Assert.Equal(Status.MutexBusy(), Status.Closed(), "Status.MutexBusy aliases Closed");
}
