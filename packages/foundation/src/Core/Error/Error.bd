/// Standard error write helpers.
/// @tier(standard)
/// @ref(Core.Syscall.WriteWith) syscall-backed write path.

use Core.Syscall.SyscallError;
use Core.Syscall.Descriptor;
use Core.Syscall.StandardStream;
use Core.Syscall.WriteRequest;

/// Writes text to standard error without a trailing newline.
/// @arg(text) UTF-8 payload.
pub unit Write(string text) {
    StandardStream stream = StandardStream::Stderr();
    Descriptor descriptor = Descriptor::Standard(stream);
    Core.Results.Result<i64, SyscallError> result =
        Core.Syscall.WriteWith(
            WriteRequest {
                descriptor: descriptor,
                data: text
            }
        );
    match result {
        Result::Ok(_) => {},
        Result::Error(_) => __panic_str("Core.Error.Write failed"),
    };
    return;
}

/// Writes text followed by a platform newline to standard error.
/// @arg(text) UTF-8 payload written before the newline.
pub unit WriteLine(string text) {
    Write(text);
    Write("
");
}
