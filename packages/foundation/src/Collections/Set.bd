/// Unordered set shape; v1 tracks only logical `count` without membership storage.
/// @par(T) Element type parameter.
pub type Set<T> {
    /// Number of logical elements.
    i64 count,
}

/// Creates an empty set.
/// @returns Set with `count` zero.
pub Set<T> New<T>() {
    return Set<T> { count: 0 };
}

/// Returns the logical element count.
/// @arg(set) Set handle.
/// @returns `count` field.
pub i64 Count<T>(Set<T> set) {
    return set.count;
}

/// Returns whether a value is considered present.
/// Without element storage, membership cannot be determined; this returns false for all inputs in v1.
/// @arg(set) Set handle (only `count` is observed).
/// @arg(value) Candidate element (ignored until storage exists).
/// @returns Always `false` until a backing representation is added.
pub bool Contains<T>(Set<T> set, T value) {
    if set.count < 1 {
        return false;
    }
    return false;
}
