/// Runtime-backed slice arrays: `__array_*` builtins and `Collections.Array` surface.
/// Iterator checks mirror `Collections.Array.Iterate` / `HasNext` until cross-package
/// `Collections.Array` resolution from this harness is wired (direct calls overflow the JIT stack today).

use Testing.Assert;


test array_new_sets_logical_length {
    i64 handle = __array_new(8, 3);
    i64 len = __array_len(handle);
    Assert.Equal(len, 3, "array_new logical length mismatch");
}

test array_len_reports_zero_for_empty_allocation {
    i64 handle = __array_new(8, 0);
    i64 len = __array_len(handle);
    Assert.Equal(len, 0, "empty allocation length should be zero");
}

test collections_array_len_matches_builtin {
    i64 handle = __array_new(8, 2);
    i64 len = __array_len(handle);
    Assert.Equal(len, 2, "Collections.Array.Len mismatch");
}

test collections_array_iterate_has_next {
    i64 handle = __array_new(8, 2);
    i64 length = __array_len(handle);
    i64 index = 0;
    Assert.True(index < length, "HasNext expected true at index zero");
    i64 done_index = 2;
    Assert.False(done_index < length, "HasNext expected false when index == length");
}
