/// Iterator-backed `Query.Operators` coverage.

use Collections.Array;
use Query.Operators;
use Testing.Assert;


test query_from_array_reports_length {
    mut i64[] source = Array.EnsureCapacity<i64>(Array.Empty<i64>(), 2);
    source = Array.Set<i64>(source, 0, 5);
    source = Array.Set<i64>(source, 1, 9);
    QueryState<i64> state = Operators.FromArray<i64>(source);
    Assert.Equal(Operators.Count<i64>(state), 2, "FromArray logical count");
}

test query_take_truncates_remaining_window {
    i64[] source = Array.EnsureCapacity<i64>(Array.Empty<i64>(), 3);
    QueryState<i64> state = Operators.FromArray<i64>(source);
    QueryState<i64> taken = Operators.Take<i64>(state, 1);
    Assert.Equal(Operators.Count<i64>(taken), 1, "Take should limit remaining count");
}

test query_skip_reduces_remaining_count {
    i64[] source = Array.EnsureCapacity<i64>(Array.Empty<i64>(), 2);
    QueryState<i64> state = Operators.FromArray<i64>(source);
    QueryState<i64> skipped = Operators.Skip<i64>(state, 1);
    Assert.Equal(Operators.Count<i64>(skipped), 1, "Skip should drop one element");
}

test query_to_list_materializes_window {
    mut i64[] source = Array.EnsureCapacity<i64>(Array.Empty<i64>(), 2);
    source = Array.Set<i64>(source, 0, 3);
    source = Array.Set<i64>(source, 1, 7);
    QueryState<i64> state = Operators.FromArray<i64>(source);
    i64[] list = Operators.ToList<i64>(state);
    Assert.Equal(Array.Len<i64>(list), 2, "ToList length");
    Assert.Equal(Array.Get<i64>(list, 0), 3, "ToList first element");
    Assert.Equal(Array.Get<i64>(list, 1), 7, "ToList second element");
}

test query_any_all_scan_window {
    mut i64[] source = Array.EnsureCapacity<i64>(Array.Empty<i64>(), 3);
    source = Array.Set<i64>(source, 0, 5);
    source = Array.Set<i64>(source, 1, 5);
    source = Array.Set<i64>(source, 2, 9);
    QueryState<i64> state = Operators.FromArray<i64>(source);
    Assert.True(Operators.Any<i64>(state, 9), "Any should find matching element");
    Assert.False(Operators.Any<i64>(state, 1), "Any should miss absent value");
    mut i64[] uniform = Array.EnsureCapacity<i64>(Array.Empty<i64>(), 2);
    uniform = Array.Set<i64>(uniform, 0, 5);
    uniform = Array.Set<i64>(uniform, 1, 5);
    QueryState<i64> uniformState = Operators.FromArray<i64>(uniform);
    Assert.True(Operators.All<i64>(uniformState, 5), "All should pass when every element matches");
    Assert.False(Operators.All<i64>(state, 9), "All should fail on mixed values");
}

test query_order_by_sorts_remaining_window {
    mut i64[] source = Array.EnsureCapacity<i64>(Array.Empty<i64>(), 3);
    source = Array.Set<i64>(source, 0, 9);
    source = Array.Set<i64>(source, 1, 3);
    source = Array.Set<i64>(source, 2, 7);
    QueryState<i64> state = Operators.FromArray<i64>(source);
    QueryState<i64> ordered = Operators.OrderBy(state, true);
    i64[] list = Operators.ToList<i64>(ordered);
    Assert.Equal(Array.Get<i64>(list, 0), 3, "OrderBy ascending first");
    Assert.Equal(Array.Get<i64>(list, 1), 7, "OrderBy ascending middle");
    Assert.Equal(Array.Get<i64>(list, 2), 9, "OrderBy ascending last");
}
