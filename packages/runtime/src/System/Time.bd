/// UTC and monotonic time helpers backed by runtime clock builtins.
/// Types are split under `System/Time/` with one type per file.
/// @tier(supported)

use System.Time.Instant;
use System.Time.Duration;
use System.Time.Date;
use System.Time.TimeOfDay;
use System.Time.DateTime;
use System.Time.TimeError;

pub i64 NanosPerSecond() {
    return 1000000000;
}

pub i64 NanosPerMillisecond() {
    return 1000000;
}

pub i64 MillisPerSecond() {
    return 1000;
}

pub i64 SecondsPerDay() {
    return 86400;
}

/// UTC wall-clock nanoseconds since Unix epoch.
pub Instant NowUtc() {
    return Instant { nanos: __clock_realtime_nanos() };
}

/// Monotonic nanoseconds since process start (best effort).
pub Instant MonotonicNow() {
    return Instant { nanos: __clock_monotonic_nanos() };
}

pub Duration FromMilliseconds(i64 ms) {
    return Duration { nanos: ms * NanosPerMillisecond() };
}

pub Duration FromNanoseconds(i64 nanos) {
    return Duration { nanos: nanos };
}

pub Duration FromSeconds(i64 seconds) {
    return Duration { nanos: seconds * NanosPerSecond() };
}

pub i64 DurationToMilliseconds(Duration value) {
    return value.nanos / NanosPerMillisecond();
}

pub i64 DurationToNanoseconds(Duration value) {
    return value.nanos;
}

pub Instant AddDuration(Instant instant, Duration delta) {
    return Instant { nanos: instant.nanos + delta.nanos };
}

pub Duration SubtractInstants(Instant later, Instant earlier) {
    return Duration { nanos: later.nanos - earlier.nanos };
}

pub DateTime ToUtcDateTime(Instant instant) {
    i64 seconds = instant.nanos / NanosPerSecond();
    i64 nanos = instant.nanos % NanosPerSecond();
    if nanos < 0 {
        nanos = nanos + NanosPerSecond();
        seconds = seconds - 1;
    }
    i64 days = seconds / SecondsPerDay();
    if seconds < 0 && seconds % SecondsPerDay() != 0 {
        days = days - 1;
    }
    i64 daySeconds = seconds % SecondsPerDay();
    if daySeconds < 0 {
        daySeconds = daySeconds + SecondsPerDay();
    }
    Date date = DateFromUnixDays(days);
    TimeOfDay time = TimeOfDay {
        hour: daySeconds / 3600,
        minute: (daySeconds % 3600) / 60,
        second: daySeconds % 60,
        nanosecond: nanos,
    };
    return DateTime { date: date, time: time };
}

pub Instant FromUtcDateTime(DateTime value) {
    i64 days = UnixDaysFromDate(value.date);
    i64 seconds = days * SecondsPerDay()
        + value.time.hour * 3600
        + value.time.minute * 60
        + value.time.second;
    i64 nanos = seconds * NanosPerSecond() + value.time.nanosecond;
    return Instant { nanos: nanos };
}

pub string FormatIso8601Utc(DateTime value) {
    string year = I64ToDecimal(value.date.year);
    string month = Pad2(value.date.month);
    string day = Pad2(value.date.day);
    string hour = Pad2(value.time.hour);
    string minute = Pad2(value.time.minute);
    string second = Pad2(value.time.second);
    return year + "-" + month + "-" + day + "T" + hour + ":" + minute + ":" + second + "Z";
}

pub string FormatDateIso(Date value) {
    return I64ToDecimal(value.year) + "-" + Pad2(value.month) + "-" + Pad2(value.day);
}

pub Core.Results.Result<Date, TimeError> ParseIso8601Date(string input) {
    if Core.String.Len(input) != 10 {
        return Result::Error(TimeError::InvalidFormat(input));
    }
    if Core.String.ByteAt(input, 4) != 45 || Core.String.ByteAt(input, 7) != 45 {
        return Result::Error(TimeError::InvalidFormat(input));
    }
    Core.Results.Result<i64, TimeError> year = ParseFixedDigits(input, 0, 4);
    match year {
        Result::Error(err) => {
            return Result::Error(err);
        },
        Result::Ok(yearValue) => {
            Core.Results.Result<i64, TimeError> month = ParseFixedDigits(input, 5, 2);
            match month {
                Result::Error(err) => {
                    return Result::Error(err);
                },
                Result::Ok(monthValue) => {
                    Core.Results.Result<i64, TimeError> day = ParseFixedDigits(input, 8, 2);
                    match day {
                        Result::Error(err) => {
                            return Result::Error(err);
                        },
                        Result::Ok(dayValue) => {
                            if monthValue < 1 || monthValue > 12 {
                                return Result::Error(TimeError::OutOfRange("month"));
                            }
                            if dayValue < 1 || dayValue > DaysInMonth(yearValue, monthValue) {
                                return Result::Error(TimeError::OutOfRange("day"));
                            }
                            return Result::Ok(Date { year: yearValue, month: monthValue, day: dayValue });
                        },
                    };
                },
            };
        },
    };
}

pub bool IsLeapYear(i64 year) {
    if year % 400 == 0 {
        return true;
    }
    if year % 100 == 0 {
        return false;
    }
    if year % 4 == 0 {
        return true;
    }
    return false;
}

pub i64 DaysInMonth(i64 year, i64 month) {
    if month == 2 {
        if IsLeapYear(year) {
            return 29;
        }
        return 28;
    }
    if month == 4 || month == 6 || month == 9 || month == 11 {
        return 30;
    }
    return 31;
}

pub i64 DaysInYear(i64 year) {
    if IsLeapYear(year) {
        return 366;
    }
    return 365;
}

Date DateFromUnixDays(i64 daysSinceEpoch) {
    i64 remaining = daysSinceEpoch;
    i64 year = 1970;
    while remaining >= DaysInYear(year) {
        remaining = remaining - DaysInYear(year);
        year = year + 1;
    }
    while remaining < 0 {
        year = year - 1;
        remaining = remaining + DaysInYear(year);
    }
    i64 month = 1;
    while remaining >= DaysInMonth(year, month) {
        remaining = remaining - DaysInMonth(year, month);
        month = month + 1;
    }
    i64 day = remaining + 1;
    return Date { year: year, month: month, day: day };
}

i64 UnixDaysFromDate(Date value) {
    i64 year = 1970;
    i64 days = 0;
    while year < value.year {
        days = days + DaysInYear(year);
        year = year + 1;
    }
    while year > value.year {
        year = year - 1;
        days = days - DaysInYear(year);
    }
    i64 month = 1;
    while month < value.month {
        days = days + DaysInMonth(value.year, month);
        month = month + 1;
    }
    days = days + value.day - 1;
    return days;
}

Core.Results.Result<i64, TimeError> ParseFixedDigits(string input, i64 start, i64 count) {
    i64 value = 0;
    i64 index = 0;
    while index < count {
        i64 digit = ParseDigitAt(input, start + index);
        if digit < 0 {
            return Result::Error(TimeError::InvalidFormat(input));
        }
        value = value * 10 + digit;
        index = index + 1;
    }
    return Result::Ok(value);
}

i64 ParseDigitAt(string input, i64 index) {
    u8 byte = Core.String.ByteAt(input, index);
    if byte >= 48 && byte <= 57 {
        return byte - 48;
    }
    return -1;
}

string Pad2(i64 value) {
    if value < 10 {
        return "0" + DigitChar(value);
    }
    i64 tens = value / 10;
    i64 ones = value % 10;
    return DigitChar(tens) + DigitChar(ones);
}

string DigitChar(i64 digit) {
    if digit == 0 {
        return "0";
    }
    if digit == 1 {
        return "1";
    }
    if digit == 2 {
        return "2";
    }
    if digit == 3 {
        return "3";
    }
    if digit == 4 {
        return "4";
    }
    if digit == 5 {
        return "5";
    }
    if digit == 6 {
        return "6";
    }
    if digit == 7 {
        return "7";
    }
    if digit == 8 {
        return "8";
    }
    return "9";
}

string I64ToDecimal(i64 value) {
    if value == 0 {
        return "0";
    }
    bool negative = value < 0;
    i64 remaining = value;
    if negative {
        remaining = -remaining;
    }
    string digits = "";
    while remaining > 0 {
        i64 digit = remaining % 10;
        digits = DigitChar(digit) + digits;
        remaining = remaining / 10;
    }
    if negative {
        return "-" + digits;
    }
    return digits;
}
