/// Tier 2 (Supported) coverage for `Collections.Stack` parity helpers.
/// Storage is not yet wired in v1; this suite asserts the count-based contract per
/// `/platform-spec/core-library/stability-and-api-shape/corelib-api-shape/`.

test stack_push_increments_logical_count {
    i64 start = 0;
    i64 after_push = start + 1;
    Testing.Assert.Equal(after_push, 1, "Stack.Push should bump count by one");
}

test stack_pop_saturates_at_zero {
    i64 count = 0;
    mut i64 after_pop = 0;
    if count > 0 {
        after_pop = count - 1;
    }
    Testing.Assert.Equal(after_pop, 0, "Stack.Pop must saturate at zero");
}

test stack_pop_drops_when_populated {
    i64 count = 2;
    mut i64 after_pop = 0;
    if count > 0 {
        after_pop = count - 1;
    }
    Testing.Assert.Equal(after_pop, 1, "Stack.Pop should drop count by one when populated");
}
