/// Shouldly-style assertion helpers for Beskid `test` blocks and user tests.
/// Prefer actual-first argument order: `Testing.Assert.equal(len, 3, "because")`.

use Core.String;

/// Emits a message and forces a runtime crash.
unit trigger_failure(string message) {
    __panic_str(message);
}

/// Unconditionally fails the current test.
/// @arg(message) Failure reason surfaced to the user.
pub unit Fail(string message) {
    trigger_failure("Assertion failed: ${message}");
}

unit fail_with_because(string headline, string because) {
    if because == "" {
        Fail(headline);
        return;
    }
    // Multi-hole interpolation is not yet ISLE-lowerable. After CYB-129, statements
    // after a bare if remain reachable, so keep the nonempty path without `else`.
    Fail(headline);
    Fail(because);
}

/// Fails when actual and expected values differ.
/// @par(T) Type of values being compared.
/// @arg(actual) Observed value.
/// @arg(expected) Expected value.
/// @arg(because) Optional diagnostic context (pass `""` when omitted).
pub unit Equal<T>(T actual, T expected, string because) {
    if actual == expected {
        return;
    }
    fail_with_because("should equal the expected value", because);
}

/// Fails when actual and expected values are equal.
/// @par(T) Type of values being compared.
/// @arg(actual) Observed value.
/// @arg(expected) Value that must differ from `actual`.
/// @arg(because) Optional diagnostic context (pass `""` when omitted).
pub unit NotEqual<T>(T actual, T expected, string because) {
    if actual != expected {
        return;
    }
    fail_with_because("should not equal the expected value", because);
}

/// Fails when condition is not true.
/// @arg(condition) Predicate that must hold.
/// @arg(because) Optional diagnostic context (pass `""` when omitted).
pub unit True(bool condition, string because) {
    if condition {
        return;
    }
    fail_with_because("should be true but was false", because);
}

/// Fails when condition is true.
/// @arg(condition) Predicate that must be false.
/// @arg(because) Optional diagnostic context (pass `""` when omitted).
pub unit False(bool condition, string because) {
    if !condition {
        return;
    }
    fail_with_because("should be false but was true", because);
}

/// Fails when needle is not found in text.
/// @arg(text) Haystack UTF-8 string.
/// @arg(needle) Needle UTF-8 string.
/// @arg(because) Optional diagnostic context (pass `""` when omitted).
pub unit Contains(string text, string needle, string because) {
    if Core.String.Contains(text, needle) {
        return;
    }
    fail_with_because("should contain the needle", because);
}
