/// Channel wrapper surface (requires `__channel_*` builtins and runtime M1).
use Concurrency.Channel;
use Concurrency.ChannelError;
use Concurrency.ChannelOptions;

test channel_create_unbounded_default {
    Channel<i64> ch = Channel<i64>.Create();
    Core.Results.Result<Concurrency.Channel.SendOk, ChannelError> sent = ch.Send(42);
    match sent {
        Result::Ok(_) => {},
        Result::Error(_) => __panic_str("Send should succeed on open channel"),
    }
    Core.Results.Result<i64, ChannelError> received = ch.Receive();
    match received {
        Result::Ok(value) => {
            if value != 42 {
                __panic_str("Receive value mismatch");
            }
        },
        Result::Error(_) => __panic_str("Receive should succeed"),
    }
}

test channel_bounded_options_factory {
    ChannelOptions options = ChannelOptions.Bounded(4);
    Channel<i64> ch = Channel<i64>.CreateWithOptions(options);
    Core.Results.Result<Concurrency.Channel.SendOk, ChannelError> sent = ch.Send(1);
    match sent {
        Result::Ok(_) => {},
        Result::Error(_) => __panic_str("bounded channel Send should succeed"),
    }
}

test channel_try_receive_empty_returns_none {
    Channel<i64> ch = Channel<i64>.Create();
    Query.Contracts.Option<i64> got = ch.TryReceive();
    match got {
        Option::None => {},
        Option::Some(_) => __panic_str("TryReceive on empty channel should be None"),
    }
}
