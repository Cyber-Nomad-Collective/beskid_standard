/// Golden CSI framing checks for `Ansi.Escape`.
test ansi_csi_bold_red {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.CsiSequence("1;31", "m");
    string expected = "${esc}[1;31m";
    Testing.Assertions.AssertEqualString(expected, seq, "expected CSI bold red sequence");
}

test ansi_reset {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.CsiSequence("0", "m");
    string expected = "${esc}[0m";
    Testing.Assertions.AssertEqualString(expected, seq, "expected CSI reset sequence");
}

test ansi_private_alt_screen {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.PrivateMode("1049", true);
    string expected = "${esc}[?1049h";
    Testing.Assertions.AssertEqualString(expected, seq, "expected alt-screen enable sequence");
}

test ansi_dec_save_cursor {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.DecSaveCursor();
    Testing.Assertions.AssertEqualString("${esc}7", seq, "expected DEC save cursor");
}

test ansi_cursor_builder_home {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Cursor.IntoSequence(
        Ansi.Cursor.Home(Ansi.Cursor.Start())
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertEqualString("", seq, "cursor home should be empty when ANSI disabled");
        return;
    }
    string expected = "${esc}[H";
    Testing.Assertions.AssertEqualString(expected, seq, "expected cursor home CSI");
}

test ansi_erase_display_all {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Erase.IntoSequence(
        Ansi.Erase.DisplayAll(Ansi.Erase.Start())
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertEqualString("", seq, "erase should be empty when ANSI disabled");
        return;
    }
    string expected = "${esc}[2J";
    Testing.Assertions.AssertEqualString(expected, seq, "expected erase display all");
}

test ansi_screen_scroll_region {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Screen.IntoSequence(
        Ansi.Screen.ScrollRegion(Ansi.Screen.Start(), 2, 10)
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertEqualString("", seq, "scroll region should be empty when ANSI disabled");
        return;
    }
    string expected = "${esc}[2;10r";
    Testing.Assertions.AssertEqualString(expected, seq, "expected scroll region CSI");
}

test ansi_input_mouse_enable {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.InputMode.IntoSequence(
        Ansi.InputMode.EnableMouseClick(Ansi.InputMode.Start())
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertEqualString("", seq, "mouse enable should be empty when ANSI disabled");
        return;
    }
    string expected = "${esc}[?1000h";
    Testing.Assertions.AssertEqualString(expected, seq, "expected mouse click enable");
}
