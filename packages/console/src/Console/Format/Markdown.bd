/// Markdown-subset renderer for console markup (parse via MarkupParser, render here).
use Ansi.Osc;
use Ansi.StyleChain;
use Console.Format.Attributes;
use Console.Format.MarkupParser;
use Core.Text.Cursor;

pub string RenderPlain(string source) {
    return RenderInner(source, false);
}

pub string RenderStyled(string source) {
    return RenderInner(source, true);
}

pub string RenderInner(string s, bool ansi) {
    i64 n = Core.String.Len(s);
    if n == 0 {
        return "";
    }

    MarkupParser.MarkupMatch m = MarkupParser.TryParse(s);
    if m.consumed < 1 {
        return "";
    }

    string tail = Cursor.Slice(Cursor.From(s), m.consumed, n - m.consumed);

    if m.kind == MarkupParser.MarkupKind::Escape {
        return "${m.body}${RenderInner(tail, ansi)}";
    }
    if m.kind == MarkupParser.MarkupKind::Literal {
        return "${m.body}${RenderInner(tail, ansi)}";
    }

    string inner = RenderInner(m.body, ansi);

    if m.kind == MarkupParser.MarkupKind::Bold {
        if ansi {
            inner = StyleChain.Apply(StyleChain.Bold(StyleChain.New()), inner);
        }
        return "${inner}${RenderInner(tail, ansi)}";
    }
    if m.kind == MarkupParser.MarkupKind::Italic {
        if ansi {
            inner = StyleChain.Apply(StyleChain.Italic(StyleChain.New()), inner);
        }
        return "${inner}${RenderInner(tail, ansi)}";
    }
    if m.kind == MarkupParser.MarkupKind::Underline {
        if ansi {
            inner = StyleChain.Apply(StyleChain.Underline(StyleChain.New()), inner);
        }
        return "${inner}${RenderInner(tail, ansi)}";
    }
    if m.kind == MarkupParser.MarkupKind::Strike {
        if ansi {
            inner = StyleChain.Apply(StyleChain.Strike(StyleChain.New()), inner);
        }
        return "${inner}${RenderInner(tail, ansi)}";
    }
    if m.kind == MarkupParser.MarkupKind::AttrSpan {
        if ansi {
            StyleChain chain = Attributes.ApplyAttrList(StyleChain.New(), m.attrs);
            inner = StyleChain.Apply(chain, inner);
        }
        return "${inner}${RenderInner(tail, ansi)}";
    }
    if m.kind == MarkupParser.MarkupKind::PaletteTag {
        if ansi {
            StyleChain chain = Attributes.ApplyPaletteTag(StyleChain.New(), m.tagName);
            inner = StyleChain.Apply(chain, inner);
        }
        return "${inner}${RenderInner(tail, ansi)}";
    }
    if m.kind == MarkupParser.MarkupKind::Link {
        if ansi {
            inner = Osc.Hyperlink(m.url, inner);
        }
        return "${inner}${RenderInner(tail, ansi)}";
    }

    return "${inner}${RenderInner(tail, ansi)}";
}
