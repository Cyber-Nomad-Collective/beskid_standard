use Core.Bytes.Convert;
use Testing.Assert;


test utf8_module_import_smoke {
    bool smoke = true;
    Assert.True(smoke, "Core.Encoding.Utf8 import smoke");
}

test utf8_convert_smoke {
    u8[] bytes = Convert.StringToBytes("hi");
    Assert.True(true, "Convert.StringToBytes smoke");
}

test hex_encoding_smoke {
    bool smoke = true;
    Assert.True(smoke, "Hex encode/decode deferred until CLIF i8/i32 parity lands");
}

test base64_encoding_smoke {
    bool smoke = true;
    Assert.True(smoke, "Base64 encode/decode deferred until CLIF i8/i32 parity lands");
}
