/// Markup scanner helpers (`Console.Format.Scan`).

test slice_returns_substring {
    string part = Console.Format.Scan.Slice("abcdef", 2, 3);
    Testing.Assertions.AssertEqualString("cde", part, "Slice middle segment");
}

test index_of_finds_needle {
    i64 idx = Console.Format.Scan.IndexOfFrom("foo-bar", 0, "bar");
    Testing.Assertions.AssertEqualI64(4, idx, "IndexOfFrom bar");
}

test trim_strips_spaces {
    string t = Console.Format.Scan.Trim("  hi  ");
    Testing.Assertions.AssertEqualString("hi", t, "Trim spaces");
}

test starts_with_prefix {
    Testing.Assertions.AssertTrue(Console.Format.Scan.StartsWith("&[fg=", "&["), "StartsWith attr opener");
}

test contains_substring {
    Testing.Assertions.AssertTrue(Console.Format.Scan.ContainsSubstring("abc[1m", "[1m"), "ContainsSubstring CSI");
}
