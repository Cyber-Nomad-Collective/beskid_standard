/// Panel measure/render and frame selection.
test panel_ascii_frame_uses_plus_corners {
    Console.Controls.Panel.Panel p = Console.Controls.Panel.Panel.WithAsciiFrame(
        Console.Controls.Panel.Panel.WithTitle(Console.Controls.Panel.Panel.New("hello"), "Title")
    );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 20, rows: 10 };
    string rendered = Console.Controls.Panel.Panel.Render(p, size);
    Testing.Assertions.AssertContains(rendered, "+", "expected ASCII frame corners");
}

test panel_measure_respects_available_width {
    Console.Controls.Panel.Panel p = Console.Controls.Panel.Panel.New("body");
    Console.ConsoleSize available = Console.ConsoleSize { columns: 40, rows: 20 };
    Console.ConsoleSize measured = Console.Controls.Panel.Panel.Measure(p, available);
    Testing.Assertions.AssertTrue(
        measured.columns <= available.columns,
        "panel measure should not exceed available columns"
    );
    Testing.Assertions.AssertTrue(measured.rows >= 3, "panel measure should include border rows");
}

test panel_title_left_in_top_border {
    Console.Controls.Panel.Panel p = Console.Controls.Panel.Panel.WithTitle(
        Console.Controls.Panel.Panel.New("x"),
        "Hi"
    );
    Console.ConsoleSize size = Console.ConsoleSize { columns: 16, rows: 8 };
    string rendered = Console.Controls.Panel.Panel.Render(p, size);
    Testing.Assertions.AssertContains(rendered, "Hi", "expected title in rendered panel");
}
