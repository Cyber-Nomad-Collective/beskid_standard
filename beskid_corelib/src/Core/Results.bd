/// Discriminated success or failure carrier used across corelib.
pub enum Result<TValue, TError> {
    /// Carries the successful payload.
    Ok(TValue value),
    /// Carries the failure payload.
    Error(TError error),
}

/// Returns true when result carries `Ok`.
pub bool IsOk<TValue, TError>(Result<TValue, TError> value) {
    return match value {
        Result::Ok(_) => true,
        Result::Error(_) => false,
    };
}

/// Returns true when result carries `Error`.
pub bool IsError<TValue, TError>(Result<TValue, TError> value) {
    return match value {
        Result::Ok(_) => false,
        Result::Error(_) => true,
    };
}
