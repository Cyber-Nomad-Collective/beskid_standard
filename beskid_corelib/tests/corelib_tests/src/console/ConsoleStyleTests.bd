/// Layout enums for console controls (`Console.Style`).
use Console.Style;

test resolve_size_small_medium_large {
    i64 small = Style.ResolveSize(Style.Size::Small(), 80);
    i64 medium = Style.ResolveSize(Style.Size::Medium(), 80);
    i64 large = Style.ResolveSize(Style.Size::Large(), 80);
    Testing.Assertions.AssertEqualI64(1, small, "small size");
    Testing.Assertions.AssertEqualI64(2, medium, "medium size");
    Testing.Assertions.AssertEqualI64(4, large, "large size");
}

test resolve_padding_sized_and_value {
    i64 none = Style.ResolvePadding(Style.Padding::None(), 80);
    i64 sized = Style.ResolvePadding(Style.Padding::Sized(Style.Size::Medium()), 80);
    i64 explicit = Style.ResolvePadding(Style.Padding::Value(5), 80);
    Testing.Assertions.AssertEqualI64(0, none, "none padding");
    Testing.Assertions.AssertEqualI64(2, sized, "sized padding");
    Testing.Assertions.AssertEqualI64(5, explicit, "explicit padding");
}

test resolve_margin_value {
    i64 margin = Style.ResolveMargin(Style.Margin::Value(3), 100);
    Testing.Assertions.AssertEqualI64(3, margin, "explicit margin");
}

test clamp_width_bounds {
    i64 min = Style.ClampWidth(0, 1, 10);
    i64 max = Style.ClampWidth(99, 1, 10);
    i64 passthrough = Style.ClampWidth(5, 1, 10);
    Testing.Assertions.AssertEqualI64(1, min, "clamp min");
    Testing.Assertions.AssertEqualI64(10, max, "clamp max");
    Testing.Assertions.AssertEqualI64(5, passthrough, "clamp passthrough");
}