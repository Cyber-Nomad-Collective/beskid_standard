/// Fiber handle runtime wrapper tests.
use Concurrency.Fiber;
use Concurrency.FiberError;

i64 child_value() {
    return 42;
}

test fiber_spawn_join_returns_value {
    Fiber<i64> fiber = spawn child_value;
    Core.Results.Result<i64, FiberError> joined = fiber.Join();
    match joined {
        Result::Ok(value) => {
            Testing.Assertions.AssertEqualI64(42, value, "fiber join value mismatch");
        },
        Result::Error(_) => {
            Testing.Assertions.Fail("fiber join should succeed");
        }
    };
}
