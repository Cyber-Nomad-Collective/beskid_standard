/// ABI status codes returned by `__fiber_join`.
pub i64 Ok() {
    return 0;
}

pub i64 Cancelled() {
    return 1;
}

pub i64 Panicked() {
    return 2;
}

pub i64 StackOverflow() {
    return 3;
}

pub i64 NotDone() {
    return 4;
}
