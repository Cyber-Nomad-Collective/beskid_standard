/// Smoke for checked-in regex.pest materialization (grammar roots + generated rules).

use Core.Text.Cursor;
use Core.Text.Parser;
use Core.Text.Regex.Generated;
use Testing.Assert;


test parse_grammar_rules_reads_digit_rule {
    Cursor.TextCursor c = Cursor.From("5");
    Assert.True(Parser.IsOk(Generated.ParseDigit(c)), "ParseDigit should match subject digit");
}

test parse_grammar_rules_reads_lower_run_rule {
    Cursor.TextCursor c = Cursor.From("abc");
    Assert.True(Parser.IsOk(Generated.ParseLowerRun(c)), "ParseLowerRun should match lowercase run");
}
