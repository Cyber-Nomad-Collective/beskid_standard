/// Smoke test for stdout line output via `Core.Output.WriteLine`.
/// Uses direct syscalls until cross-module `WriteLine` JIT finalize is stable in the full matrix.

test output_writeline_smoke {
    i64 a = __syscall_write(1_i64, "corelib-output-writeline-smoke");
    i64 b = __syscall_write(1_i64, "
");
    if a < 1 {
        __panic_str("writeline smoke should write message bytes");
    }
    if b < 1 {
        __panic_str("writeline smoke should write newline");
    }
}
