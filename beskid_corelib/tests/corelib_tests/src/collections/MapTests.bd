/// Tier 2 (Supported) coverage for `Collections.Map` parity helpers.
/// Storage is intentionally not wired in v1; this suite asserts the count-based contract
/// documented under `/platform-spec/core-library/stability-and-api-shape/corelib-api-shape/`.

use Testing.Assert;


test map_insert_increments_logical_count {
    i64 start = 0;
    i64 after_insert = start + 1;
    Assert.Equal(after_insert, 1, "Map.Insert should bump count by one");
}

test map_remove_saturates_at_zero {
    i64 count = 0;
    mut i64 after_remove = count;
    if count > 0 {
        after_remove = count - 1;
    } else {
        after_remove = 0;
    }
    Assert.Equal(after_remove, 0, "Map.Remove must saturate at zero");
}

test map_remove_decrements_when_populated {
    i64 count = 3;
    mut i64 after_remove = 0;
    if count > 0 {
        after_remove = count - 1;
    } else {
        after_remove = 0;
    }
    Assert.Equal(after_remove, 2, "Map.Remove should drop count by one when populated");
}

test map_contains_returns_false_until_storage_lands {
    bool result = false;
    Assert.False(result, "Map.ContainsKey must return false while storage is Tier 3");
}
