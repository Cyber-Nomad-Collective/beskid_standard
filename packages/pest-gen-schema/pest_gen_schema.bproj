pest_gen_schema {
  name = "pest_gen_schema"
  version = "0.1.0"
  type = Bsol
  schemas {
    export configuration {
      profile = "configuration.v1"
      path = "schemas/configuration.v1.bsol"
    }
    export pestGenConfig {
      profile = "pestGenConfig.v1"
      path = "schemas/pestGenConfig.v1.bsol"
    }
  }
}
