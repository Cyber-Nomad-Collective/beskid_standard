/// Predicate helpers on `Core.Results.Result`.
test result_is_ok_detects_ok {
    Core.Results.Result<i64, string> ok = Result::Ok(7);
    Testing.Assertions.AssertTrue(Core.Results.IsOk(ok), "IsOk expected true for Ok");
}

test result_is_ok_detects_error {
    Core.Results.Result<i64, string> err = Result::Error("e");
    Testing.Assertions.AssertFalse(Core.Results.IsOk(err), "IsOk expected false for Error");
}

test result_is_error_detects_error {
    Core.Results.Result<i64, string> err = Result::Error("e");
    Testing.Assertions.AssertTrue(Core.Results.IsError(err), "IsError expected true for Error");
}

test result_is_error_detects_ok {
    Core.Results.Result<i64, string> ok = Result::Ok(1);
    Testing.Assertions.AssertFalse(Core.Results.IsError(ok), "IsError expected false for Ok");
}
