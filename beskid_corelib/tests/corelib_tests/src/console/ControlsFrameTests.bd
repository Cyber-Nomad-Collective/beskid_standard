/// Frame glyphs and repeat helper for bordered controls.

use Console;
use Console.Capabilities;
use Console.Controls.Frame;
use Console.Controls.Panel;
use Testing.Assert;


test unicode_frame_corners {
    Console.Controls.Frame.FrameChars chars = Console.Controls.Frame.Unicode();
    Assert.Equal(chars.topLeft, "┌", "unicode top-left");
    Assert.Equal(chars.side, "│", "unicode side");
}

test ascii_frame_corners {
    Console.Controls.Frame.FrameChars chars = Console.Controls.Frame.Ascii();
    Assert.Equal(chars.topLeft, "+", "ascii top-left");
    Assert.Equal(chars.top, "-", "ascii horizontal");
}

test repeat_builds_string {
    string line = Console.Controls.Frame.Repeat("-", 4);
    Assert.Equal(line, "----", "Repeat four dashes");
}

test prefer_unicode_follows_ansi_capability {
    bool prefer = Console.Controls.Frame.PreferUnicodeFrame();
    bool emit = Console.Capabilities.ShouldEmitAnsi();
    Assert.True(
        prefer == emit,
        "PreferUnicodeFrame should track ShouldEmitAnsi"
    );
}

test panel_unicode_frame_when_preferred {
    Console.Controls.Panel.Panel p = Console.Controls.Panel.Panel.WithTitle(
        Console.Controls.Panel.Panel.New("body"),
        "T"
    );
    ConsoleSize size = ConsoleSize { columns: 24, rows: 8 };
    string rendered = Console.Controls.Panel.Panel.Render(p, size);
    if Console.Capabilities.ShouldEmitAnsi() {
        Assert.Contains(
            rendered,
            "┌",
            "unicode panel should use box drawing when ANSI enabled"
        );
    }
}
