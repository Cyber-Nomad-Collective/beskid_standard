/// Language-owned runtime handler: lexicographic byte-array compare.
[Runtime(DispatchTag: 0, Returns: I64)]
pub i64 Compare(u8[] left, u8[] right) {
    return __bytes_compare(left, right);
}

/// Language-owned runtime handler: indexed byte access.
[Runtime(DispatchTag: 1, Returns: I64)]
pub i64 Get(u8[] value, u64 index) {
    return __bytes_get(value, index);
}
