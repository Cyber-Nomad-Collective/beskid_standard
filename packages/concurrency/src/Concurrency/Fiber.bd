/// Cooperative fiber handle returned by `spawn`.
use Concurrency.FiberError;
use Concurrency.Status;

/// Runtime fiber handle; declares cancellation event on the handle only.
pub struct Fiber<T> {
    i64 handle,
    event OnCancelled(),
}

/// Waits for completion and returns the entry value or a `FiberError`.
pub Core.Results.Result<T, FiberError> Join<T>(Fiber<T> self) {
    i64 status = __fiber_join(self.handle);
    if status == Status.Ok() {
        return Result::Ok(__fiber_join_value(self.handle));
    }
    return Result::Error(MapJoinError(status));
}

/// Waives parent shutdown join; child panic still aborts the process in v1.
pub unit Detach<T>(Fiber<T> self) {
    __fiber_detach(self.handle);
    return;
}

/// Sets cancellation flag and raises `OnCancelled` on the child fiber.
pub unit Cancel<T>(Fiber<T> self) {
    __fiber_cancel(self.handle);
    return;
}

pub FiberError MapJoinError(i64 status) {
    if status == Status.Cancelled() {
        return FiberError::Cancelled();
    }
    if status == Status.StackOverflow() {
        return FiberError::StackOverflow();
    }
    if status == Status.Panicked() {
        return FiberError::Panicked(status);
    }
    return FiberError::Panicked(status);
}
