/// Query execution helpers for deferred state checks and materialization.
use Core.Optional.Option;
use Query.Operators;
use Query.QueryState;

/// Returns true when the state reports elements but no concrete `first` value yet.
pub bool IsDeferred<T>(QueryState<T> state) {
    if Query.Operators.Count<T>(state) < 1 {
        return false;
    }
    return !Core.Optional.Option.HasValue<T>(state.first);
}

/// Materializes and returns element count.
pub i64 MaterializeCount<T>(QueryState<T> state) {
    return Query.Operators.Count<T>(state);
}
