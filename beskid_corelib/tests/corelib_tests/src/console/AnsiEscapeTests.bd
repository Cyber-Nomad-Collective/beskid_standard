/// Golden CSI framing checks for `Ansi.Escape` only (builders live in AnsiBuildersTests.bd).

use Ansi.Escape;
use Testing.Assert;

test ansi_csi_bold_red {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.CsiSequence("1;31", "m");
    string expected = "${esc}[1;31m";
    Assert.Equal(seq, expected, "expected CSI bold red sequence");
}

test ansi_reset {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.CsiSequence("0", "m");
    string expected = "${esc}[0m";
    Assert.Equal(seq, expected, "expected CSI reset sequence");
}

test ansi_private_alt_screen {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.PrivateMode("1049", true);
    string expected = "${esc}[?1049h";
    Assert.Equal(seq, expected, "expected alt-screen enable sequence");
}

test ansi_dec_save_cursor {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.DecSaveCursor();
    Assert.Equal(seq, "${esc}7", "expected DEC save cursor");
}
