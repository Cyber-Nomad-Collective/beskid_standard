/// Cross-platform fd write (`syscall_write`) and reserved read surface.
///
/// Status: partial — `Write` implemented; `Read` stub.

pub i64 StdoutFd() {
    return 1;
}

pub i64 StdinFd() {
    return 0;
}

pub i64 StderrFd() {
    return 2;
}

pub i64 Write(i64 fd, string data) {
    return __syscall_write(fd, data);
}

pub i64 Read(i64 fd) {
    __panic_str("Syscall.Read is not implemented");
}
