use Core.String;
use System.IO;

unit trigger_failure(string message) {
    System.IO.Println(message);
    i32 zero = 0;
    i32 crash = 1 / zero;
    System.IO.Println("${crash}");
}

pub unit Fail(string message) {
    trigger_failure("Assertion failed: ${message}");
}

pub unit AssertTrue(bool condition, string message) {
    if condition {
        return;
    }
    Fail(message);
}

pub unit AssertFalse(bool condition, string message) {
    AssertTrue(!condition, message);
}

pub unit AssertEqualI64(i64 expected, i64 actual, string message) {
    if expected == actual {
        return;
    }
    Fail("${message} (expected=${expected}, actual=${actual})");
}

pub unit AssertEqualString(string expected, string actual, string message) {
    if expected == actual {
        return;
    }
    Fail("${message} (expected=${expected}, actual=${actual})");
}

pub unit AssertNotEqualI64(i64 left, i64 right, string message) {
    if left != right {
        return;
    }
    Fail("${message} (left=${left}, right=${right})");
}

pub unit AssertContains(string text, string needle, string message) {
    if Core.String.Contains(text, needle) {
        return;
    }
    Fail("${message} (needle=${needle})");
}
