/// Deprecated assertion helpers. Prefer Testing.Assert (actual-first argument order).

pub unit Fail(string message) {
    Testing.Assert.Fail(message);
}

pub unit AssertTrue(bool condition, string message) {
    Testing.Assert.True(condition, message);
}

pub unit AssertFalse(bool condition, string message) {
    Testing.Assert.False(condition, message);
}

pub unit AssertEqual<T>(T expected, T actual, string message) {
    Testing.Assert.Equal(actual, expected, message);
}

pub unit AssertNotEqual<T>(T left, T right, string message) {
    Testing.Assert.NotEqual(left, right, message);
}

pub unit AssertContains(string text, string needle, string message) {
    Testing.Assert.Contains(text, needle, message);
}
