/// LIFO stack shape; v1 tracks only logical `count`. Tier 2 until runtime stack storage ships;
/// signatures are stable so authors can call parity helpers today.
/// @tier(supported)
/// @par(T) Element type parameter.
pub type Stack<T> {
    /// Number of logical elements.
    i64 count,
}

/// Creates an empty stack.
/// @tier(supported)
/// @returns Stack with `count` zero.
pub Stack<T> New<T>() {
    return Stack<T> { count: 0 };
}

/// Returns the logical element count.
/// @tier(supported)
/// @arg(stack) Stack handle.
/// @returns `count` field.
pub i64 Count<T>(Stack<T> stack) {
    return stack.count;
}

/// Returns true when the stack is empty.
/// @tier(supported)
/// @arg(stack) Stack handle.
/// @returns `true` when `count == 0`.
pub bool IsEmpty<T>(Stack<T> stack) {
    return stack.count == 0;
}

/// Logical push: returns a new stack with `count + 1`; storage is not yet wired so the value
/// payload is not retained between calls.
/// @tier(supported)
/// @arg(stack) Source stack handle.
/// @arg(value) Element to push (observed only via count in v1).
/// @returns Stack with `count` incremented.
pub Stack<T> Push<T>(Stack<T> stack, T value) {
    return Stack<T> { count: stack.count + 1 };
}

/// Logical pop: returns a new stack with `count - 1` or zero when empty.
/// @tier(supported)
/// @arg(stack) Source stack handle.
/// @returns Stack with `count` decremented; saturates at zero.
pub Stack<T> Pop<T>(Stack<T> stack) {
    if stack.count <= 0 {
        return Stack<T> { count: 0 };
    }
    return Stack<T> { count: stack.count - 1 };
}

/// Returns the top element without removing it, or an error when empty / unbacked.
/// Tier 3 until runtime stack storage ships; signature stays stable.
/// @tier(unstable)
/// @arg(stack) Stack handle.
/// @returns `Error` while runtime storage is not yet wired.
pub Core.Results.Result<T, string> Peek<T>(Stack<T> stack) {
    if stack.count <= 0 {
        return Result::Error("stack is empty");
    }
    return Result::Error("stack storage is not implemented");
}
