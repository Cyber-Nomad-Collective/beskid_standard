/// Identifier casing conversions for text tooling and codegen.
use Core.String;

pub bool IsAsciiLower(u8 b) {
    return b >= 97 && b <= 122;
}

pub bool IsAsciiUpper(u8 b) {
    return b >= 65 && b <= 90;
}

pub bool IsAsciiDigit(u8 b) {
    return b >= 48 && b <= 57;
}

pub bool IsSnakePartChar(u8 b, bool first) {
    if first {
        return IsAsciiLower(b) || IsAsciiUpper(b) || b == 95;
    }
    return IsAsciiLower(b) || IsAsciiUpper(b) || IsAsciiDigit(b) || b == 95;
}

/// `lower_run` → `LowerRun`.
pub string SnakeToPascal(string snake) {
    mut string out = "";
    mut bool upperNext = true;
    mut i64 i = 0;
    i64 len = String.Len(snake);
    while i < len {
        u8 b = String.ByteAt(snake, i);
        if b == 95 {
            upperNext = true;
            i = i + 1;
            continue;
        }
        string ch = String.CodeUnitChar(b);
        if upperNext {
            if IsAsciiLower(b) {
                out = out + String.UpperChar(b - 97);
            } else {
                out = out + ch;
            }
            upperNext = false;
        } else {
            out = out + ch;
        }
        i = i + 1;
    }
    return out;
}

/// `LowerRun` → `lower_run`.
pub string PascalToSnake(string pascal) {
    mut string out = "";
    mut i64 i = 0;
    i64 len = String.Len(pascal);
    while i < len {
        u8 b = String.ByteAt(pascal, i);
        if IsAsciiUpper(b) {
            if String.Len(out) > 0 {
                out = out + "_";
            }
            out = out + String.CodeUnitChar(b + 32);
        } else {
            out = out + String.CodeUnitChar(b);
        }
        i = i + 1;
    }
    return out;
}

/// `lower_run` → `lowerRun`.
pub string SnakeToCamel(string snake) {
    string pascal = SnakeToPascal(snake);
    i64 len = String.Len(pascal);
    if len < 1 {
        return "";
    }
    u8 lead = String.ByteAt(pascal, 0);
    if IsAsciiUpper(lead) {
        return String.CodeUnitChar(lead + 32) + String.SubSlice(pascal, 1, len - 1);
    }
    return pascal;
}

/// `lowerRun` → `lower_run`.
pub string CamelToSnake(string camel) {
    mut string out = "";
    mut i64 i = 0;
    i64 len = String.Len(camel);
    while i < len {
        u8 b = String.ByteAt(camel, i);
        if IsAsciiUpper(b) {
            if String.Len(out) > 0 {
                out = out + "_";
            }
            out = out + String.CodeUnitChar(b + 32);
        } else {
            out = out + String.CodeUnitChar(b);
        }
        i = i + 1;
    }
    return out;
}

/// `lower_run` with prefix `Parse` → `ParseLowerRun`.
pub string CallableFromSnake(string snake, string prefix) {
    return prefix + SnakeToPascal(snake);
}
