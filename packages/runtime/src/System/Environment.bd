/// Process environment variable helpers.
/// @ref(Query.Contracts.Option) optional lookup surface for `TryGet`.
/// @ref(Core.Results.Result) result envelopes for strict getters/setters.
/// @variant(InvalidName) Name rejected as empty or malformed.
/// @variant(NotFound) Variable is not available in this host snapshot.
/// @variant(UnsupportedMutation) Writes are not permitted on this surface.
pub enum EnvironmentError {
    /// Variable name is empty or invalid.
    InvalidName(string name),
    /// Variable is not available.
    NotFound(string name),
    /// Mutation is not supported.
    UnsupportedMutation,
}

/// Returns a variable value or an error.
/// @arg(name) Environment variable name.
/// @returns `Error` for unsupported hosts in v1.
pub Core.Results.Result<string, EnvironmentError> Get(string name) {
    if name == "" {
        return Result::Error(EnvironmentError::InvalidName(name));
    }
    return Result::Error(EnvironmentError::NotFound(name));
}

/// Returns an optional variable value.
/// @arg(name) Environment variable name.
/// @returns `None` when unavailable or invalid in v1.
pub Query.Contracts.Option<string> TryGet(string name) {
    if name == "" {
        return Option::None();
    }
    return Option::None();
}

/// Attempts to set a variable.
/// @arg(name) Environment variable name.
/// @arg(value) Desired value.
/// @returns `Error` for unsupported mutation paths in v1.
pub Core.Results.Result<bool, EnvironmentError> Set(string name, string value) {
    if name == "" {
        return Result::Error(EnvironmentError::InvalidName(name));
    }
    if value == "" {
        return Result::Error(EnvironmentError::UnsupportedMutation());
    }
    return Result::Error(EnvironmentError::UnsupportedMutation());
}

/// Alias for Get.
/// @arg(name) Environment variable name.
pub Core.Results.Result<string, EnvironmentError> GetVariable(string name) {
    return Get(name);
}

/// Returns the current working directory path.
/// @returns Placeholder `"."` until host integration lands.
pub string CurrentDirectory() {
    return ".";
}
