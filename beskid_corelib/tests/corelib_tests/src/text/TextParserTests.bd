/// Core.Text.Parser combinator tests.
use Core.Text.Cursor;
use Core.Text.Parser;
use Testing.Assert;

test literal_matches_using_cursor {
    Cursor.TextCursor c = Cursor.From("abc");
    Assert.True(Cursor.StartsWith(c, "ab"), "cursor prefix");
    Assert.True(Parser.IsOk(Parser.Literal(Cursor.From("abc"), "ab", "test")), "literal parse");
}

test choice_second_branch {
    Cursor.TextCursor c = Cursor.From("z");
    Parser.Result.TextParseResult<string> a = Parser.Literal(Cursor.From("z"), "a", "a");
    Parser.Result.TextParseResult<string> z = Parser.Literal(Cursor.From("z"), "z", "z");
    Assert.True(!Parser.IsOk(a), "wrong branch fails");
    Assert.True(Parser.IsOk(z), "z branch ok");
    Assert.True(Parser.IsOk(Parser.Choice2(Cursor.From("z"), "choice", a, z)), "choice ok");
}
