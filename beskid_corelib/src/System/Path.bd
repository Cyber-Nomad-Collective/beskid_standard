/// Path string composition helpers.
/// Composes two path segments with a slash separator.
pub string Combine(string left, string right) {
    if left === "" {
        return right;
    }
    if right === "" {
        return left;
    }
    return left + "/" + right;
}

/// Returns the file name component.
pub string FileName(string path) {
    return path;
}

/// Returns the extension component.
pub string Extension(string path) {
    return path;
}
