/// Tier 2 (Supported) coverage for `System.FS` parity helpers.
/// Contract stub suite for `System.FS` error shapes. Host-backed FS builtins require the
/// std profile and `beskid_host` registration (ABI v4); this target pins heuristic placeholders.

use Testing.Assert;


test fs_exists_treats_empty_path_as_false {
    bool result = "" != "";
    Assert.False(result, "FS.Exists must return false for empty path");
}

test fs_exists_treats_nonempty_path_as_true {
    bool result = "/tmp/something" != "";
    Assert.True(result, "FS.Exists must return true for non-empty path heuristic stub");
}

test fs_read_all_text_empty_path_is_rejected {
    string path = "";
    bool is_invalid = path == "";
    Assert.True(is_invalid, "FS.ReadAllText must reject empty path with InvalidPath");
}

test fs_write_all_text_empty_payload_is_ok_noop {
    string text = "";
    bool is_noop = text == "";
    Assert.True(is_noop, "FS.WriteAllText must treat empty payload as Ok noop");
}
