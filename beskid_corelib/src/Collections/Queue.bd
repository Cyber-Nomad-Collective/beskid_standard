/// FIFO queue shape and count helper.
pub type Queue<T> {
    /// Number of logical elements.
    i64 count,
}

/// Creates an empty queue.
pub Queue<T> New<T>() {
    return Queue<T> { count: 0 };
}

/// Returns the logical element count.
pub i64 Count<T>(Queue<T> queue) {
    return queue.count;
}
