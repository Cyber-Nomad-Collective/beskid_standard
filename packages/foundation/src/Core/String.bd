/// UTF-8 string helpers backed by runtime string builtins (`__str_len`).
/// Returns the number of UTF-8 code units in text.
/// @arg(text) UTF-8 string handle.
/// @returns Code unit count as `i64`.
pub i64 Len(string text) {
    return __str_len(text);
}

/// Returns true when text is empty.
/// @arg(text) UTF-8 string handle.
/// @returns `true` when `Len` is zero.
pub bool IsEmpty(string text) {
    return Len(text) == 0;
}

/// Returns the zero-based byte index of `needle` in `haystack` starting at `start`, or `-1`.
pub i64 IndexOfFrom(string haystack, i64 start, string needle) {
    i64 hlen = Len(haystack);
    i64 nlen = Len(needle);
    if nlen == 0 {
        return start;
    }
    if start < 0 {
        start = 0;
    }
    i64 i = start;
    while !(i + nlen > hlen) {
        i64 j = 0;
        bool matched = true;
        while j < nlen {
            if ByteAt(haystack, i + j) != ByteAt(needle, j) {
                matched = false;
                break;
            }
            j = j + 1;
        }
        if matched {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

/// Returns true when `needle` occurs as a substring of `text`.
pub bool Contains(string text, string needle) {
    return !(IndexOfFrom(text, 0, needle) < 0);
}

/// Returns the byte at the given zero-based index in the UTF-8 representation.
/// Out-of-bounds access triggers a runtime error.
/// @tier(standard)
/// @arg(text) Source string.
/// @arg(index) Zero-based byte offset.
/// @returns Byte value as u8.
pub u8 ByteAt(string text, i64 index) {
    return text[index];
}
