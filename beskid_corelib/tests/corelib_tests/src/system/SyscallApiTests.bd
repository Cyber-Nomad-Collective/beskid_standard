/// Syscall API contract checks for read and write boundaries.
/// Validates raw read builtin shape.
test syscall_read_builtin_returns_string {
    string text = __syscall_read(99_i64, 8_i64);
    i64 len = __str_len(text);
    if len < 0 {
        __panic_str("string length should be non-negative");
    }
}
