/// Incremental render context cursor/erase prefixes.
use Console.Controls.RenderContext;

test render_context_move_to_emits_csi {
    RenderContext.RenderContext ctx = RenderContext.New(2, 4);
    string seq = RenderContext.MoveTo(ctx, 2, 4);
    if Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertContains(seq, "[2;4H", "MoveTo should position cursor");
    }
}

test render_context_without_incremental_is_plain {
    RenderContext.RenderContext ctx = RenderContext.WithoutIncremental(1, 1);
    string rendered = RenderContext.RenderAt(ctx, "line");
    Testing.Assertions.AssertEqualString("line", rendered, "non-incremental RenderAt should return text only");
}

test render_context_erase_line_and_render {
    RenderContext.RenderContext ctx = RenderContext.New(1, 1);
    string rendered = RenderContext.EraseLineAndRender(ctx, "x");
    if Console.Capabilities.ShouldEmitAnsi() {
        Testing.Assertions.AssertContains(rendered, "[2K", "EraseLineAndRender should clear line");
        Testing.Assertions.AssertContains(rendered, "x", "EraseLineAndRender should append text");
    }
}

test render_context_advance_row {
    RenderContext.RenderContext ctx = RenderContext.New(1, 1);
    RenderContext.RenderContext next = RenderContext.AdvanceRow(ctx);
    Testing.Assertions.AssertEqualI64(2, next.cursorRow, "AdvanceRow should increment cursor row");
}
