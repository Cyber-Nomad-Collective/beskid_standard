/// Vertical stack container control.
use Console;
use Console.Style;
use Console.Controls.Contracts;
use Console.Controls.RenderContext;

pub type VerticalStack : Contracts.Container, Contracts.ConsoleControl {
    string childBodies,
    i64 childCount,
}

pub VerticalStack New() {
    return VerticalStack { childBodies: "", childCount: 0 };
}

pub VerticalStack WithChild(VerticalStack stack, string body) {
    string joined = stack.childBodies;
    if joined != "" {
        joined = "${joined}
";
    }
    joined = "${joined}${body}";
    return VerticalStack { childBodies: joined, childCount: stack.childCount + 1 };
}

pub i64 ChildCount(VerticalStack stack) {
    return stack.childCount;
}

pub Console.ConsoleSize Measure(VerticalStack stack, Console.ConsoleSize available) {
    i32 rows = stack.childCount;
    if rows < 1 {
        rows = 1;
    }
    return Console.ConsoleSize { columns: available.columns, rows: rows };
}

pub string Render(VerticalStack stack, Console.ConsoleSize size) {
    if stack.childBodies == "" {
        return "";
    }
    return stack.childBodies;
}

pub string RenderWithContext(VerticalStack stack, Console.ConsoleSize size, RenderContext.RenderContext ctx) {
    return RenderContext.RenderAt(ctx, Render(stack, size));
}
