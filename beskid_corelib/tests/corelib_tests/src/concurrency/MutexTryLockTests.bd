/// Mutex wrapper surface.

use Concurrency.Mutex;
use Core.Optional;
use Testing.Assert;



test mutex_try_lock_reports_busy_until_unlock {
    Mutex mutex = Mutex.Create();
    Option<Concurrency.MutexGuard> first = mutex.TryLock();
    match first {
        Option::Some(guard) => {
            Option<Concurrency.MutexGuard> second = mutex.TryLock();
            match second {
                Option::None => {},
                Option::Some(_) => {
                    Assert.Fail("second TryLock should report busy");
                }
            };
            Concurrency.Mutex.Unlock(guard);
        },
        Option::None => {
            Assert.Fail("first TryLock should succeed");
        }
    };
}

/// Mutex.TryLock maps runtime status to `Option<MutexGuard>`.
test mutex_try_lock_returns_guard_or_none {
    Mutex mutex = Mutex.Create();
    Option<Concurrency.MutexGuard> guard = mutex.TryLock();
    match guard {
        Option::Some(acquired) => {
            Concurrency.Mutex.Unlock(acquired);
        },
        Option::None => {},
    };
}
