/// Golden tests for SGR escape sequences.
use Ansi.StyleChain;
use Ansi.Sgr;

test ansi_bold_golden {
    string styled = StyleChain.Apply(StyleChain.Bold(StyleChain.New()), "x");
    if Console.Capabilities.ShouldEmitAnsi() && !Core.String.Contains(styled, "[1m") {
        __panic_str("bold SGR should contain [1m");
    }
}

test ansi_fg256_golden {
    string styled = StyleChain.Apply(
        StyleChain.Fg256(StyleChain.New(), 196),
        "y"
    );
    if Console.Capabilities.ShouldEmitAnsi() && !Core.String.Contains(styled, "38;5;196") {
        __panic_str("256-color fg should contain 38;5;196");
    }
}

test ansi_sgr_apply_reset {
    string styled = Sgr.ApplyTo(Sgr.Bold(Sgr.Start()), "z");
    if Console.Capabilities.ShouldEmitAnsi() {
        if !Core.String.Contains(styled, "[1m") {
            __panic_str("Sgr.ApplyTo bold should contain [1m");
        }
        if !Core.String.Contains(styled, "[0m") {
            __panic_str("Sgr.ApplyTo should end with reset [0m");
        }
    }
}

test ansi_osc_title_golden {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Osc.IntoSequence(
        Ansi.Osc.SetTitle(Ansi.Osc.Start(), "beskid")
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        if seq != "" {
            __panic_str("OSC title should be empty when ANSI disabled");
        }
        return;
    }
    if !Core.String.Contains(seq, "${esc}]0;beskid") {
        __panic_str("OSC title should contain ]0;beskid");
    }
}

test ansi_osc_hyperlink_contains_uri {
    string linked = Ansi.Osc.Hyperlink("https://beskid.dev", "link");
    if Console.Capabilities.ShouldEmitAnsi() {
        if !Core.String.Contains(linked, "8;;https://beskid.dev") {
            __panic_str("hyperlink open should embed uri");
        }
        if !Core.String.Contains(linked, "link") {
            __panic_str("hyperlink should preserve label");
        }
    }
}
