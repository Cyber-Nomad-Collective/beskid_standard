/// Tier 2 (Supported) coverage for `Collections.Set` parity helpers.
/// Storage is not yet wired in v1; this suite asserts the count-based contract per
/// `/platform-spec/core-library/stability-and-api-shape/corelib-api-shape/`.

test set_add_increments_logical_count {
    i64 start = 0;
    i64 after_add = start + 1;
    Testing.Assertions.AssertEqualI64(1, after_add, "Set.Add should bump count by one");
}

test set_remove_saturates_at_zero {
    i64 count = 0;
    i64 after_remove = 0;
    if count > 0 {
        after_remove = count - 1;
    }
    Testing.Assertions.AssertEqualI64(0, after_remove, "Set.Remove must saturate at zero");
}

test set_contains_returns_false_until_storage_lands {
    bool result = false;
    Testing.Assertions.AssertFalse(result, "Set.Contains must return false while storage is Tier 3");
}
