/// File system helper API backed by runtime `fs_*` builtins.
/// @tier(supported)
/// @ref(Core.Results.Result) envelopes for read/write helpers.
pub enum FsError {
    NotFound(string path),
    PermissionDenied(string path),
    AlreadyExists(string path),
    InvalidPath(string path),
    Unknown(string message),
}

pub Core.Results.Result<string, FsError> ReadAllText(string path) {
    if path == "" {
        return Result::Error(FsError::InvalidPath(path));
    }
    string text = __fs_read_text(path);
    if text == "" && !Exists(path) {
        return Result::Error(FsError::NotFound(path));
    }
    return Result::Ok(text);
}

pub Core.Results.Result<bool, FsError> WriteAllText(string path, string text) {
    if path == "" {
        return Result::Error(FsError::InvalidPath(path));
    }
    if text == "" {
        i64 rc = __fs_write_text(path, "");
        if rc == 0 {
            return Result::Ok(true);
        }
        return Result::Error(FsError::Unknown("WriteAllText failed"));
    }
    i64 rc = __fs_write_text(path, text);
    if rc == 0 {
        return Result::Ok(true);
    }
    return Result::Error(FsError::Unknown("WriteAllText failed"));
}

pub Core.Results.Result<bool, FsError> Delete(string path) {
    if path == "" {
        return Result::Error(FsError::InvalidPath(path));
    }
    if __fs_delete(path) == 0 {
        return Result::Ok(true);
    }
    return Result::Error(FsError::Unknown("Delete failed"));
}

pub Core.Results.Result<bool, FsError> CreateDirectory(string path) {
    if path == "" {
        return Result::Error(FsError::InvalidPath(path));
    }
    if __fs_mkdir(path) == 0 {
        return Result::Ok(true);
    }
    return Result::Error(FsError::Unknown("CreateDirectory failed"));
}

pub bool Exists(string path) {
    if path == "" {
        return false;
    }
    return __fs_exists(path) == 1;
}
