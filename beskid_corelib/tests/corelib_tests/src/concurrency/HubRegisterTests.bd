/// Hub registration and homogeneous channel typing.

use Concurrency.Hub;
use Core.Results;
use Testing.Assert;


test hub_register_accepts_channel {
    Hub<i64> hub = Hub<i64>.Create();
    Concurrency.Channel<i64> ch = CreateMemberChannel();
    i64 index = 0;
    Core.Results.Result<Concurrency.Channel.SendOk, Concurrency.HubError> reg = hub.Register(index, ch);
    Assert.True(
        Core.Results.IsOk(reg),
        "hub register should succeed"
    );
}

test hub_wait_receive_returns_registered_index_and_value {
    Hub<i64> hub = Hub<i64>.Create();
    Concurrency.Channel<i64> ch = CreateMemberChannel();
    i64 index = 5;
    Assert.True(
        Core.Results.IsOk(hub.Register(index, ch)),
        "hub register should succeed"
    );
    Assert.True(
        Core.Results.IsOk(ch.Send(77)),
        "channel send should succeed before hub wait"
    );

    Core.Results.Result<Concurrency.HubReceiveResult<i64>, Concurrency.HubError> received = hub.WaitReceive();
    match received {
        Result::Ok(value) => {
            Assert.Equal(value.index, index, "hub receive index mismatch");
            Assert.Equal(value.value, 77, "hub receive value mismatch");
        },
        Result::Error(_) => {
            Assert.Fail("hub wait receive should succeed");
        }
    };
}
