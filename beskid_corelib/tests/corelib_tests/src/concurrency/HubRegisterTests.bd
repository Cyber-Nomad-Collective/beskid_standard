/// Hub registration and homogeneous channel typing.
use Concurrency.Channel;
use Concurrency.Hub;

test hub_register_accepts_channel {
    Hub<i64> hub = Hub<i64>.Create();
    Channel<i64> ch = Channel<i64>.Create();
    Core.Results.Result<Concurrency.Channel.SendOk, Concurrency.HubError> reg = hub.Register(0, ch);
    match reg {
        Result::Ok(_) => {},
        Result::Error(_) => __panic_str("hub register should succeed"),
    }
}
