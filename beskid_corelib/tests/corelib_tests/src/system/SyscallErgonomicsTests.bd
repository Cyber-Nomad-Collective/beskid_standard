/// Runtime-backed syscall contract checks via `Core.Syscall` typed requests.

use Testing.Assert;
use Core.Syscall;
use Core.Syscall.Descriptor;
use Core.Syscall.StandardStream;
use Core.Syscall.WriteRequest;
use Core.Syscall.ReadRequest;
use Core.Syscall.ReadLimit;
use Core.Results;


test syscall_write_stdout_typed_smoke {
    StandardStream stream = StandardStream::Stdout();
    Descriptor descriptor = Descriptor::Standard(stream);
    Core.Results.Result<i64, Core.Syscall.SyscallError> result =
        Core.Syscall.WriteWith(
            WriteRequest {
                descriptor: descriptor,
                data: "ergonomic-write"
            }
        );
    Assert.True(Results.IsOk(result), "stdout WriteWith should succeed");
    match result {
        Result::Ok(written) => {
            Assert.True(written >= 1, "stdout write should return at least one byte");
        },
        Result::Error(_) => {},
    };
}

test syscall_read_unsupported_fd_returns_error {
    StandardStream stream = StandardStream::Stdout();
    Descriptor descriptor = Descriptor::Standard(stream);
    Core.Results.Result<string, Core.Syscall.SyscallError> result =
        Core.Syscall.ReadWith(
            ReadRequest {
                descriptor: descriptor,
                limit: ReadLimit::UpTo(4_i64)
            }
        );
    Assert.True(Results.IsError(result), "read from stdout should fail in v1");
}

test syscall_write_invalid_fd_returns_error {
    Core.Results.Result<i64, Core.Syscall.SyscallError> result =
        Core.Syscall.Write(-1_i64, "x");
    Assert.True(Results.IsError(result), "invalid fd write should return error");
}
