/// Array-backed collections integration coverage.

use Collections.List;
use Collections.Stack;
use Testing.Assert;


test list_push_pop_updates_count {
    mut List<i64> list = List.New<i64>();
    list = List.Push(list, 10);
    list = List.Push(list, 20);
    Assert.Equal(List.Count(list), 2, "List.Count after two pushes");
    list = List.Pop(list);
    Assert.Equal(List.Count(list), 1, "List.Count after pop");
}

test stack_push_updates_count {
    mut Stack<i64> stack = Stack.New<i64>();
    stack = Stack.Push(stack, 42);
    Assert.Equal(Stack.Count(stack), 1, "Stack.Count after push");
}

test array_empty_reports_zero_length {
    i64 handle = __array_new(8, 0);
    i64 len = __array_len(handle);
    Assert.Equal(len, 0, "empty array length");
}
