/// Golden CSI framing checks for `Ansi.Escape`.
test ansi_csi_bold_red {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.CsiSequence("1;31", "m");
    string expected = "${esc}[1;31m";
    if seq != expected {
        __panic_str("expected CSI bold red sequence");
    }
}

test ansi_reset {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.CsiSequence("0", "m");
    string expected = "${esc}[0m";
    if seq != expected {
        __panic_str("expected CSI reset sequence");
    }
}

test ansi_private_alt_screen {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.PrivateMode("1049", true);
    string expected = "${esc}[?1049h";
    if seq != expected {
        __panic_str("expected alt-screen enable sequence");
    }
}

test ansi_dec_save_cursor {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Escape.DecSaveCursor();
    if seq != "${esc}7" {
        __panic_str("expected DEC save cursor");
    }
}

test ansi_cursor_builder_home {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Cursor.IntoSequence(
        Ansi.Cursor.Home(Ansi.Cursor.Start())
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        if seq != "" {
            __panic_str("cursor home should be empty when ANSI disabled");
        }
        return;
    }
    string expected = "${esc}[H";
    if seq != expected {
        __panic_str("expected cursor home CSI");
    }
}

test ansi_erase_display_all {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Erase.IntoSequence(
        Ansi.Erase.DisplayAll(Ansi.Erase.Start())
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        if seq != "" {
            __panic_str("erase should be empty when ANSI disabled");
        }
        return;
    }
    string expected = "${esc}[2J";
    if seq != expected {
        __panic_str("expected erase display all");
    }
}

test ansi_screen_scroll_region {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.Screen.IntoSequence(
        Ansi.Screen.ScrollRegion(Ansi.Screen.Start(), 2, 10)
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        if seq != "" {
            __panic_str("scroll region should be empty when ANSI disabled");
        }
        return;
    }
    string expected = "${esc}[2;10r";
    if seq != expected {
        __panic_str("expected scroll region CSI");
    }
}

test ansi_input_mouse_enable {
    string esc = Ansi.Escape.Esc();
    string seq = Ansi.InputMode.IntoSequence(
        Ansi.InputMode.EnableMouseClick(Ansi.InputMode.Start())
    );
    if !Console.Capabilities.ShouldEmitAnsi() {
        if seq != "" {
            __panic_str("mouse enable should be empty when ANSI disabled");
        }
        return;
    }
    string expected = "${esc}[?1000h";
    if seq != expected {
        __panic_str("expected mouse click enable");
    }
}
