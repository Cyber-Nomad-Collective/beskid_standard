/// Growable list backed by `T[]` storage and `Collections.Array` helpers.
/// @tier(supported)
/// @par(T) Element type stored in the list.
use Collections.Array;
use Core.Results;

pub type List<T> {
    T[] storage,
    i64 count,

    pub i64 Count() {
        return count;
    }

    pub bool IsEmpty() {
        return count == 0;
    }

    pub List<T> Push(T value) {
        i64 next = count + 1;
        T[] nextStorage = Array.AppendAt<T>(storage, next, value);
        return List<T> { storage: nextStorage, count: next };
    }

    pub List<T> Pop() {
        if count <= 0 {
            return List<T> { storage: storage, count: 0 };
        }
        return List<T> { storage: storage, count: count - 1 };
    }

    pub Result<T, string> Get(i64 index) {
        if index < 0 {
            return Result::Error("index out of range");
        }
        if index >= count {
            return Result::Error("index out of range");
        }
        return Result::Ok(Array.Get<T>(storage, index));
    }
}

pub List<T> New<T>() {
    return List<T> { storage: Array.Empty<T>(), count: 0 };
}

pub i64 Count<T>(List<T> list) {
    return list.Count();
}

pub bool IsEmpty<T>(List<T> list) {
    return list.IsEmpty();
}

pub List<T> Push<T>(List<T> list, T value) {
    return list.Push(value);
}

pub List<T> Pop<T>(List<T> list) {
    return list.Pop();
}

pub Result<T, string> Get<T>(List<T> list, i64 index) {
    return list.Get(index);
}
