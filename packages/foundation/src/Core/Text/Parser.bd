/// Low-level parser combinator primitives over Core.Text.Cursor.
use Core.Text.Cursor;

pub enum ParseErrorKind {
    ExpectedLiteral,
    ExpectedRule,
    ZeroWidthRepeat,
    ChoiceFailed,
}

pub type ParseError {
    i64 offset,
    ParseErrorKind kind,
    string rule,
}

pub enum TextParseResult<T> {
    Ok(T value, Cursor.TextCursor rest),
    Err(ParseError error),
}

pub bool IsOk(TextParseResult<string> result) {
    return match result {
        TextParseResult::Ok(_, _) => true,
        TextParseResult::Err(_) => false,
    };
}

pub TextParseResult<string> Pure(string value, Cursor.TextCursor c) {
    return TextParseResult<string>::Ok(value, c);
}

pub TextParseResult<string> Fail(Cursor.TextCursor c, ParseErrorKind kind, string rule) {
    ParseError err = ParseError { offset: Cursor.Position(c), kind: kind, rule: rule };
    return TextParseResult<string>::Err(err);
}

pub TextParseResult<string> Literal(Cursor.TextCursor c, string text, string rule) {
    if Cursor.StartsWith(c, text) {
        i64 n = Core.String.Len(text);
        Cursor.TextCursor rest = Cursor.Advance(c, n);
        return TextParseResult<string>::Ok(text, rest);
    }
    return Fail(c, ParseErrorKind::ExpectedLiteral, rule);
}

pub TextParseResult<string> Satisfy(Cursor.TextCursor c, string rule) {
    if Cursor.AtEnd(c) {
        return Fail(c, ParseErrorKind::ExpectedRule, rule);
    }
    string ch = Cursor.Slice(c, c.pos, 1);
    Cursor.TextCursor rest = Cursor.Advance(c, 1);
    return TextParseResult<string>::Ok(ch, rest);
}

pub TextParseResult<string> Choice2(
    Cursor.TextCursor c,
    string rule,
    TextParseResult<string> first,
    TextParseResult<string> second
) {
    if IsOk(first) {
        return first;
    }
    if IsOk(second) {
        return second;
    }
    return Fail(c, ParseErrorKind::ChoiceFailed, rule);
}

pub Cursor.TextCursor RestOnOk(TextParseResult<string> result, Cursor.TextCursor fallback) {
    return match result {
        TextParseResult::Ok(_, rest) => rest,
        TextParseResult::Err(_) => fallback,
    };
}
