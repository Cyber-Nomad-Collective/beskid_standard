/// File system helper API.
/// @ref(Core.Results.Result) envelopes for read/write helpers.
/// @variant(NotFound) Requested path is missing in this v1 stub.
/// @variant(PermissionDenied) Host denied access to the path.
/// @variant(Unknown) Catch-all for unimplemented or internal failures.
pub enum FsError {
    /// Path cannot be found.
    NotFound(string path),
    /// Access rights are insufficient.
    PermissionDenied(string path),
    /// Uncategorized file system failure.
    Unknown(string message),
}

/// Reads full text content from a path.
/// @arg(path) Filesystem path to read.
/// @returns File contents or an `FsError` (stub returns `Unknown` today).
pub Core.Results.Result<string, FsError> ReadAllText(string path) {
    if path == "" {
        return Result::Error(FsError::NotFound(path));
    }
    return Result::Error(FsError::Unknown("not implemented"));
}

/// Writes full text content to a path.
/// @arg(path) Target filesystem path.
/// @arg(text) Payload to persist.
/// @returns `Ok(true)` for empty payloads; otherwise `Unknown` until implemented.
pub Core.Results.Result<bool, FsError> WriteAllText(string path, string text) {
    if path == "" {
        return Result::Error(FsError::NotFound(path));
    }
    if text == "" {
        return Result::Ok(true);
    }
    return Result::Error(FsError::Unknown("not implemented"));
}

/// Reports whether a path is considered to exist.
/// @arg(path) Candidate path string.
/// @returns `true` when non-empty in this v1 heuristic stub.
pub bool Exists(string path) {
    return path != "";
}
