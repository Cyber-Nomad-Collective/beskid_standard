/// Tier 2 (Supported) coverage for `Collections.List` parity helpers.
/// Storage is not yet wired in v1; `Get` stays Tier 3 and returns deterministic errors.

use Testing.Assert;


test list_push_increments_logical_count {
    i64 start = 0;
    i64 afterPush = start + 1;
    Assert.Equal(afterPush, 1, "List.Push should bump count by one");
}

test list_pop_saturates_at_zero {
    i64 count = 0;
    mut i64 afterPop = 0;
    if count > 0 {
        afterPop = count - 1;
    }
    Assert.Equal(afterPop, 0, "List.Pop must saturate at zero");
}

test list_is_empty_predicate_matches_zero {
    i64 count = 0;
    bool isEmpty = count == 0;
    Assert.True(isEmpty, "List.IsEmpty must agree with count == 0");

    i64 populated = 1;
    bool populatedEmpty = populated == 0;
    Assert.False(populatedEmpty, "List.IsEmpty must be false for non-zero count");
}
