/// Low-level parser combinator primitives over Core.Text.Cursor.
pub mod Core.Text.Parser.Result;
pub mod Core.Text.Parser.Context;
pub mod Core.Text.Parser.Literals;
pub mod Core.Text.Parser.Terms;
pub mod Core.Text.Parser.Combine;
pub mod Core.Text.Parser.Cardinality;
pub mod Core.Text.Parser.Coordination;
pub mod Core.Text.Parser.Flow;

use Core.Text.Cursor;
use Core.Text.Parser.Result;
use Core.Text.Parser.Literals;
use Core.Text.Parser.Flow;
use Core.Text.Parser.Combine;

/// Flat `Parser.*` helpers. Defined here (not via `pub use`) so import-closure
/// consumers and generated parsers resolve them directly. Types remain at
/// `Parser.Result.*`.

pub bool IsOk(TextParseResult<string> result) {
    return Result.IsOk(result);
}

pub Cursor.TextCursor RestOnOk(TextParseResult<string> result, Cursor.TextCursor fallback) {
    return Result.RestOnOk(result, fallback);
}

pub TextParseResult<string> Fail(Cursor.TextCursor c, ParseErrorKind kind, string rule) {
    return Literals.Fail(c, kind, rule);
}

pub TextParseResult<string> Pure(string value, Cursor.TextCursor c) {
    return Flow.Pure(value, c);
}

pub TextParseResult<string> Literal(Cursor.TextCursor c, string text, string rule) {
    return Literals.Text(c, text, rule);
}

pub TextParseResult<string> Satisfy(Cursor.TextCursor c, string rule) {
    return Literals.Any(c, rule);
}

pub TextParseResult<string> Choice2(
    Cursor.TextCursor c,
    string rule,
    TextParseResult<string> left,
    TextParseResult<string> right
) {
    return Combine.Or(c, rule, left, right);
}
