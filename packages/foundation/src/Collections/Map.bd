/// Key/value map backed by `MapEntry[]` linear scan.
/// @tier(supported)
pub mod Collections.Map.MapEntry;

use Collections.Array;
use Collections.Map.MapEntry;
use Core.Results;

pub type Map<TKey, TValue> {
    MapEntry<TKey, TValue>[] entries,
    i64 count,

    pub i64 Count() {
        return count;
    }

    pub bool IsEmpty() {
        return count == 0;
    }

    pub Map<TKey, TValue> Insert(TKey key, TValue value) {
        mut i64 i = 0;
        while i < count {
            MapEntry<TKey, TValue> entry = Array.Get<MapEntry<TKey, TValue>>(entries, i);
            if entry.key == key {
                MapEntry<TKey, TValue> updated = MapEntry<TKey, TValue> { key: key, value: value };
                MapEntry<TKey, TValue>[] nextEntries = Array.Set<MapEntry<TKey, TValue>>(entries, i, updated);
                return Map<TKey, TValue> { entries: nextEntries, count: count };
            }
            i = i + 1;
        }
        i64 next = count + 1;
        MapEntry<TKey, TValue> fresh = MapEntry<TKey, TValue> { key: key, value: value };
        MapEntry<TKey, TValue>[] grown = Array.AppendAt<MapEntry<TKey, TValue>>(entries, next, fresh);
        return Map<TKey, TValue> { entries: grown, count: next };
    }

    pub Result<TValue, string> Get(TKey key) {
        mut i64 i = 0;
        while i < count {
            MapEntry<TKey, TValue> entry = Array.Get<MapEntry<TKey, TValue>>(entries, i);
            if entry.key == key {
                return Result::Ok(entry.value);
            }
            i = i + 1;
        }
        return Result::Error("key not found");
    }

    pub bool ContainsKey(TKey key) {
        mut i64 i = 0;
        while i < count {
            MapEntry<TKey, TValue> entry = Array.Get<MapEntry<TKey, TValue>>(entries, i);
            if entry.key == key {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    pub Map<TKey, TValue> Remove(TKey key) {
        mut i64 i = 0;
        while i < count {
            MapEntry<TKey, TValue> entry = Array.Get<MapEntry<TKey, TValue>>(entries, i);
            if entry.key == key {
                MapEntry<TKey, TValue> tail = Array.Get<MapEntry<TKey, TValue>>(entries, count - 1);
                MapEntry<TKey, TValue>[] nextEntries = Array.Set<MapEntry<TKey, TValue>>(entries, i, tail);
                return Map<TKey, TValue> { entries: nextEntries, count: count - 1 };
            }
            i = i + 1;
        }
        return Map<TKey, TValue> { entries: entries, count: count };
    }
}

pub Map<TKey, TValue> New<TKey, TValue>() {
    return Map<TKey, TValue> { entries: Array.Empty<MapEntry<TKey, TValue>>(), count: 0 };
}
