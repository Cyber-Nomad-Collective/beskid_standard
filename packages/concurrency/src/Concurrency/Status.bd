/// ABI status codes returned by `__fiber_*`, `__channel_*`, `__hub_*`, and `__mutex_*` builtins.
pub i64 Ok() {
    return 0;
}

pub i64 Closed() {
    return 1;
}

pub i64 Cancelled() {
    return 2;
}

pub i64 WouldBlock() {
    return 3;
}

pub i64 HubLimit() {
    return 4;
}

pub i64 StackOverflow() {
    return 5;
}

pub i64 Panicked() {
    return 6;
}

pub i64 MutexBusy() {
    return 7;
}
