/// High-level stdout output helpers.

use System.Syscall.SyscallError;

/// Writes text to standard output.
pub unit Print(string text) {
    Core.Results.Result<i64, SyscallError> result =
        System.Syscall.Write(System.Syscall.StdoutFd(), text);
    match result {
        Result::Ok(_) => {},
        Result::Error(_) => __panic_str("System.IO.Print failed"),
    };
    return;
}

/// Writes text followed by a newline.
pub unit PrintLine(string text) {
    Print(text);
    Print("
");
}
