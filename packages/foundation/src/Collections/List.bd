/// Growable list surface; v1 tracks only logical `count` because the runtime does not yet
/// expose backing storage. Indexed access (`Get`) is intentionally Tier 3 until `array_get` /
/// `array_set` runtime builtins land.
/// @tier(supported)
/// @par(T) Element type stored conceptually in the list.
pub type List<T> {
    /// Number of logical elements.
    i64 count,
}

/// Creates an empty list.
/// @tier(supported)
/// @returns Zero-length list.
pub List<T> New<T>() {
    return List<T> { count: 0 };
}

/// Returns the logical element count.
/// @tier(supported)
/// @arg(list) List handle.
/// @returns `count` field.
pub i64 Count<T>(List<T> list) {
    return list.count;
}

/// Returns true when the list carries no logical elements.
/// @tier(supported)
/// @arg(list) List handle.
/// @returns `true` when `count == 0`.
pub bool IsEmpty<T>(List<T> list) {
    return list.count == 0;
}

/// Logical append: returns a new list with `count + 1`; backing storage is not yet wired.
/// @tier(supported)
/// @arg(list) Source list handle.
/// @arg(value) Value to record (currently observed only via count).
/// @returns List with `count` incremented.
pub List<T> Push<T>(List<T> list, T value) {
    return List<T> { count: list.count + 1 };
}

/// Logical pop: returns a new list with `count - 1` or zero when empty.
/// @tier(supported)
/// @arg(list) Source list handle.
/// @returns List with `count` decremented; saturates at zero.
pub List<T> Pop<T>(List<T> list) {
    if list.count <= 0 {
        return List<T> { count: 0 };
    }
    return List<T> { count: list.count - 1 };
}

/// Returns an indexed element or an error when storage is unavailable.
/// @tier(unstable)
/// @arg(list) List handle.
/// @arg(index) Zero-based index.
/// @returns `Error` while runtime storage is not yet wired; eventually `Ok(value)` for valid indices.
pub Core.Results.Result<T, string> Get<T>(List<T> list, i64 index) {
    if index < 0 {
        return Result::Error("index out of range");
    }
    if list.count > index {
        return Result::Error("list storage is not implemented");
    }
    return Result::Error("index out of range");
}
