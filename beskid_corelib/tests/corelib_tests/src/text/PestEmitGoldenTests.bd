/// Golden naming gate: generated callables are PascalCase (no Parse_snake_case).

use Core.Text.Cursor;
use Core.Text.Parser;
use Core.Text.Regex.Generated;
use Testing.Assert;


test emit_includes_parse_pat_callable {
    Cursor.TextCursor c = Cursor.From("a|b");
    Assert.True(Parser.IsOk(Generated.ParsePat(c)), "ParsePat callable should parse pattern branch");
}

test emit_includes_parse_digit_callable {
    Cursor.TextCursor c = Cursor.From("9");
    Assert.True(Parser.IsOk(Generated.ParseDigit(c)), "ParseDigit callable should parse digit atom");
}
