/// Testing.Assert hub — forwards to `Testing.Assert.Assert` helpers.
pub mod Testing.Assert.Assert;

use Testing.Assert.Assert;

pub unit Fail(string message) {
    Assert.Fail(message);
}

pub unit Equal<T>(T actual, T expected, string because) {
    Assert.Equal(actual, expected, because);
}

pub unit NotEqual<T>(T actual, T expected, string because) {
    Assert.NotEqual(actual, expected, because);
}

pub unit True(bool condition, string because) {
    Assert.True(condition, because);
}

pub unit False(bool condition, string because) {
    Assert.False(condition, because);
}

pub unit Contains(string text, string needle, string because) {
    Assert.Contains(text, needle, because);
}
