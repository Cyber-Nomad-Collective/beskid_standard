/// ABI status codes returned by channel, hub, mutex, and wait-group builtins.
pub i64 Ok() {
    return 0;
}

pub i64 Closed() {
    return 1;
}

pub i64 Cancelled() {
    return 2;
}

pub i64 WouldBlock() {
    return 3;
}

pub i64 HubEmpty() {
    return 4;
}

pub i64 HubLimit() {
    return 5;
}

pub i64 HubNotFound() {
    return 6;
}

pub i64 MutexBusy() {
    return 1;
}
