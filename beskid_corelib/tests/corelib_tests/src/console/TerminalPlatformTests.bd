/// Platform terminal probes and env size parsing.

use Console;
use Platform.Terminal;
use Testing.Assert;


test parse_env_columns_known_values {
    Assert.Equal(Platform.Terminal.ParseEnvColumns("120", 80), 120, "expected 120 columns");
    Assert.Equal(Platform.Terminal.ParseEnvColumns("unknown", 80), 80, "unknown columns should keep default");
}

test parse_env_rows_known_values {
    Assert.Equal(Platform.Terminal.ParseEnvRows("40", 24), 40, "expected 40 rows");
    Assert.Equal(Platform.Terminal.ParseEnvRows("", 24), 24, "empty rows should keep default");
}

test query_size_returns_positive_dimensions {
    ConsoleSize size = Platform.Terminal.QuerySize();
    Assert.True(size.columns >= 1, "terminal columns should be positive");
    Assert.True(size.rows >= 1, "terminal rows should be positive");
}

test env_fallback_size_defaults {
    ConsoleSize size = Platform.Terminal.EnvFallbackSize();
    Assert.True(size.columns >= 80, "fallback columns should be at least 80");
    Assert.True(size.rows >= 24, "fallback rows should be at least 24");
}
