/// Tier 2 (Supported) coverage for `Collections.List` parity helpers.
/// Storage is not yet wired in v1; `Get` stays Tier 3 and returns deterministic errors.

test list_push_increments_logical_count {
    i64 start = 0;
    i64 after_push = start + 1;
    Testing.Assertions.AssertEqualI64(1, after_push, "List.Push should bump count by one");
}

test list_pop_saturates_at_zero {
    i64 count = 0;
    mut i64 after_pop = 0;
    if count > 0 {
        after_pop = count - 1;
    }
    Testing.Assertions.AssertEqualI64(0, after_pop, "List.Pop must saturate at zero");
}

test list_is_empty_predicate_matches_zero {
    i64 count = 0;
    bool is_empty = count == 0;
    Testing.Assertions.AssertTrue(is_empty, "List.IsEmpty must agree with count == 0");

    i64 populated = 1;
    bool populated_empty = populated == 0;
    Testing.Assertions.AssertFalse(populated_empty, "List.IsEmpty must be false for non-zero count");
}
