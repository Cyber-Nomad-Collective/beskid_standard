/// Hub registration and homogeneous channel typing.

test hub_register_accepts_channel {
    Concurrency.Hub<i64> hub = Concurrency.Hub<i64>.Create();
    Concurrency.Channel<i64> ch = Concurrency.Channel<i64>.Create();
    Core.Results.Result<Concurrency.Channel.SendOk, Concurrency.HubError> reg = hub.Register(0, ch);
    Testing.Assert.True(
        Core.Results.IsOk(reg),
        "hub register should succeed"
    );
}

test hub_wait_receive_returns_registered_index_and_value {
    Concurrency.Hub<i64> hub = Concurrency.Hub<i64>.Create();
    Concurrency.Channel<i64> ch = Concurrency.Channel<i64>.Create();
    Testing.Assert.True(
        Core.Results.IsOk(hub.Register(5, ch)),
        "hub register should succeed"
    );
    Testing.Assert.True(
        Core.Results.IsOk(ch.Send(77)),
        "channel send should succeed before hub wait"
    );

    Core.Results.Result<Concurrency.HubReceiveResult<i64>, Concurrency.HubError> received = hub.WaitReceive();
    match received {
        Result::Ok(value) => {
            Testing.Assert.Equal(value.index, 5, "hub receive index mismatch");
            Testing.Assert.Equal(value.value, 77, "hub receive value mismatch");
        },
        Result::Error(_) => {
            Testing.Assert.Fail("hub wait receive should succeed");
        }
    };
}
