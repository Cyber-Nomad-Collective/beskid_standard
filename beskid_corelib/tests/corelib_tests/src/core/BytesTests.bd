use Core.Bytes.Convert;
use Core.Bytes.Slice;
use Testing.Assert;


test bytes_new_has_length {
    u8[] buf = Slice.New(4);
    i64 len = Slice.Len(buf);
    Assert.Equal(len, 4, "bytes New length mismatch");
}

test bytes_from_string_matches_utf8_length {
    u8[] buf = Convert.StringToBytes("abc");
    Assert.Equal(Slice.Len(buf), 3, "StringToBytes byte length");
    Assert.Equal(Slice.Get(buf, 0), 97, "first byte");
}

test bytes_fill_sets_range {
    u8[] buf = Slice.New(4);
    Slice.Fill(buf, 0, 4, 42);
    Assert.Equal(Slice.Get(buf, 0), 42, "Fill first byte");
    Assert.Equal(Slice.Get(buf, 3), 42, "Fill last byte");
}

test bytes_subslice_copies_window {
    u8[] buf = Convert.StringToBytes("hello");
    u8[] sub = Slice.SubSlice(buf, 1, 3);
    Assert.Equal(Slice.Len(sub), 3, "SubSlice length");
    Assert.Equal(Slice.Get(sub, 0), 101, "SubSlice first byte is e");
}

test bytes_compare_lexicographic {
    u8[] left = Convert.StringToBytes("abc");
    u8[] right = Convert.StringToBytes("abd");
    Assert.Equal(Slice.Compare(left, right), -1, "Compare less");
}

test bytes_copy_range {
    u8[] dst = Slice.New(3);
    u8[] src = Convert.StringToBytes("xyz");
    Slice.Copy(dst, 0, src, 0, 3);
    Assert.Equal(Slice.Get(dst, 2), 122, "Copy third byte");
}
