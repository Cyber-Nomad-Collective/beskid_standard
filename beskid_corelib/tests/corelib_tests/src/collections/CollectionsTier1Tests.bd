/// Canonical Tier 1 regression for the corelib API-shape surface (`Collections.Array`).
/// Spec: `/platform-spec/core-library/stability-and-api-shape/corelib-api-shape/` — Tier 1 invariants.
///
/// These tests mirror the `Collections.Array.Iterate` / `HasNext` semantics via the runtime
/// builtins so the harness avoids the cross-package JIT stack overflow noted in `ArrayTests.bd`.

test array_tier1_len_round_trips_through_runtime_header {
    i64 handle = __array_new(8, 5);
    i64 len = __array_len(handle);
    Testing.Assertions.AssertEqualI64(5, len, "tier1 array length mismatch");
}

test array_tier1_empty_allocation_has_zero_length {
    i64 handle = __array_new(8, 0);
    i64 len = __array_len(handle);
    Testing.Assertions.AssertEqualI64(0, len, "tier1 empty allocation length should be zero");
}

test array_tier1_is_empty_matches_zero_length {
    i64 empty_handle = __array_new(8, 0);
    i64 empty_len = __array_len(empty_handle);
    Testing.Assertions.AssertEqualI64(0, empty_len, "tier1 IsEmpty must match zero length");
}

test array_tier1_len_one_for_one_element_allocation {
    i64 one_handle = __array_new(8, 1);
    i64 one_len = __array_len(one_handle);
    Testing.Assertions.AssertEqualI64(1, one_len, "tier1 single-element allocation must report length 1");
}

test array_tier1_iterator_walks_to_end {
    i64 handle = __array_new(8, 3);
    i64 length = __array_len(handle);
    mut i64 index = 0;
    Testing.Assertions.AssertTrue(index < length, "tier1 iterator HasNext at 0 expected true");
    index = index + 1;
    Testing.Assertions.AssertTrue(index < length, "tier1 iterator HasNext at 1 expected true");
    index = index + 1;
    Testing.Assertions.AssertTrue(index < length, "tier1 iterator HasNext at 2 expected true");
    index = index + 1;
    Testing.Assertions.AssertFalse(index < length, "tier1 iterator HasNext at length expected false");
}

test array_tier1_advance_increments_logical_index {
    i64 start = 0;
    i64 advanced = start + 1;
    Testing.Assertions.AssertEqualI64(1, advanced, "tier1 Advance must increment by one");
}
